---
export const prerender = true;
import PersonaPixels from '../components/PersonaPixels.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Remote Hustler — Your Income Stack Protocol | ExpatBuildr</title>
<meta name="description" content="Scale remote income from anywhere. Your complete income stack protocol starts here."/>
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<PersonaPixels persona="remote-hustler" magnet="remote-jobs-pack" />
<style>
:root{--bg:#060810;--bg2:#090c18;--accent:#00e5ff;--accent2:#3b6fff;--accent3:#f5c842;--glass:rgba(255,255,255,0.03);--border:rgba(255,255,255,0.07);--text:#f0f4ff;--muted:#8892b0;--font-d:'Bebas Neue',sans-serif;--font-b:'Syne',sans-serif;--font-m:'JetBrains Mono',monospace;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--font-b);overflow-x:hidden;line-height:1.6;}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:0.35;}
.stars{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;}
.star{position:absolute;border-radius:50%;background:#fff;animation:twinkle var(--d,3s) ease-in-out infinite var(--delay,0s);}
@keyframes twinkle{0%,100%{opacity:var(--op,0.3);}50%{opacity:0.05;}}
.orb{position:fixed;border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;}
.orb1{width:600px;height:600px;background:rgba(0,229,255,0.06);top:-200px;right:-200px;animation:pulse 7s ease-in-out infinite;}
.orb2{width:400px;height:400px;background:rgba(59,111,255,0.06);bottom:-100px;left:-100px;animation:pulse 7s ease-in-out infinite 3.5s;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.4;}}
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:18px 40px;display:flex;align-items:center;justify-content:space-between;background:rgba(6,8,16,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
.nav-brand{font-family:var(--font-d);font-size:1.2rem;letter-spacing:0.12em;color:var(--text);text-decoration:none;}
.nav-brand span{color:var(--accent);}
.nav-back{font-family:var(--font-m);font-size:0.72rem;color:var(--muted);text-decoration:none;letter-spacing:0.08em;transition:color 0.2s;}
.nav-back:hover{color:var(--accent);}
.nav-pill{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:100px;background:rgba(0,229,255,0.08);border:1px solid rgba(0,229,255,0.2);font-family:var(--font-m);font-size:0.65rem;letter-spacing:0.15em;color:var(--accent);text-transform:uppercase;}
.dot{width:5px;height:5px;border-radius:50%;background:var(--accent);animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.2;}}
.progress-nav{position:fixed;top:61px;left:0;right:0;z-index:99;background:rgba(6,8,16,0.9);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);padding:12px 40px;display:flex;align-items:center;gap:0;overflow-x:auto;}
.prog-step{display:flex;align-items:center;gap:8px;flex-shrink:0;}
.prog-dot{width:28px;height:28px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--font-m);font-size:0.65rem;color:var(--muted);transition:all 0.3s;cursor:pointer;}
.prog-dot.active{border-color:var(--accent);color:var(--accent);box-shadow:0 0 12px rgba(0,229,255,0.3);}
.prog-dot.done{border-color:rgba(0,233,163,0.5);background:rgba(0,233,163,0.08);color:#00e9a3;}
.prog-label{font-family:var(--font-m);font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);transition:color 0.3s;}
.prog-label.active{color:var(--accent);}
.prog-line{width:40px;height:1px;background:var(--border);margin:0 4px;flex-shrink:0;}
@media(max-width:600px){.prog-label{display:none;}.prog-line{width:20px;}}
.wrap{max-width:1100px;margin:0 auto;padding:0 24px;position:relative;z-index:1;}
.section{padding:120px 0 80px;min-height:100vh;display:flex;align-items:center;}
.section:first-of-type{padding-top:160px;}
.step-num{font-family:var(--font-d);font-size:clamp(8rem,20vw,16rem);line-height:1;color:rgba(0,229,255,0.04);position:absolute;top:-40px;left:-20px;pointer-events:none;user-select:none;z-index:0;}
.step-badge{display:inline-flex;align-items:center;gap:10px;margin-bottom:24px;}
.step-badge-num{width:40px;height:40px;border-radius:50%;border:2px solid var(--accent);display:flex;align-items:center;justify-content:center;font-family:var(--font-m);font-size:0.8rem;color:var(--accent);box-shadow:0 0 20px rgba(0,229,255,0.2);}
.step-badge-label{font-family:var(--font-m);font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);}
.step-connector{width:2px;height:80px;background:linear-gradient(to bottom,rgba(0,229,255,0.3),transparent);margin:0 auto;position:relative;z-index:1;}
.step-connector::after{content:'';position:absolute;bottom:-4px;left:50%;transform:translateX(-50%);width:8px;height:8px;border-radius:50%;background:rgba(0,229,255,0.3);}
.card{background:var(--glass);border:1px solid var(--border);border-radius:28px;backdrop-filter:blur(12px);padding:40px;}
.display{font-family:var(--font-d);line-height:0.92;letter-spacing:0.02em;}
.text-cyan{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.btn{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;border-radius:100px;font-family:var(--font-b);font-weight:800;font-size:0.9rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;border:none;cursor:pointer;transition:all 0.3s;}
.btn-cyan{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#000;box-shadow:0 0 40px rgba(0,229,255,0.15);}
.btn-cyan:hover{transform:translateY(-2px);box-shadow:0 0 60px rgba(0,229,255,0.3);}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--text);}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);}
.hero-tag{display:inline-flex;align-items:center;gap:8px;padding:8px 18px;border-radius:100px;background:rgba(0,229,255,0.08);border:1px solid rgba(0,229,255,0.2);font-family:var(--font-m);font-size:0.7rem;letter-spacing:0.18em;color:var(--accent);text-transform:uppercase;margin-bottom:32px;}
.hero-title{font-family:var(--font-d);font-size:clamp(5rem,15vw,11rem);line-height:0.88;letter-spacing:0.02em;margin-bottom:24px;}
.hero-sub{font-size:1.1rem;color:var(--muted);max-width:560px;line-height:1.8;margin-bottom:48px;}
.stats-row{display:flex;gap:32px;flex-wrap:wrap;margin-top:48px;}
.stat-item{text-align:center;}
.stat-num{font-family:var(--font-d);font-size:3.5rem;letter-spacing:0.04em;line-height:1;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.stat-label{font-family:var(--font-m);font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);margin-top:4px;}
.form-row{display:flex;gap:12px;margin-top:28px;}
.form-input{flex:1;padding:14px 24px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:100px;color:var(--text);font-family:var(--font-b);font-size:0.9rem;outline:none;transition:border-color 0.2s;}
.form-input::placeholder{color:var(--muted);}
.form-input:focus{border-color:var(--accent);}
.form-note{font-family:var(--font-m);font-size:0.68rem;color:var(--muted);margin-top:12px;letter-spacing:0.06em;}
@media(max-width:500px){.form-row{flex-direction:column;}}
.get-list{margin-top:32px;display:flex;flex-direction:column;gap:12px;}
.get-item{display:flex;align-items:flex-start;gap:14px;padding:16px 20px;background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:16px;}
.get-icon{font-size:1.4rem;flex-shrink:0;margin-top:2px;}
.get-text strong{display:block;font-size:0.9rem;font-weight:800;color:var(--text);margin-bottom:2px;}
.get-text span{font-size:0.82rem;color:var(--muted);}
.quiz-q{margin-bottom:32px;}
.quiz-q-label{font-family:var(--font-m);font-size:0.68rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;}
.quiz-q-text{font-weight:800;font-size:1.05rem;color:var(--text);margin-bottom:16px;}
.quiz-options{display:flex;flex-direction:column;gap:8px;}
.quiz-opt{display:flex;align-items:center;gap:12px;padding:14px 20px;background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:14px;cursor:pointer;transition:all 0.2s;font-size:0.88rem;color:var(--muted);}
.quiz-opt:hover{border-color:var(--accent);color:var(--text);}
.quiz-opt.selected{border-color:var(--accent);background:rgba(0,229,255,0.05);color:var(--text);}
.quiz-opt-radio{width:18px;height:18px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;transition:all 0.2s;display:flex;align-items:center;justify-content:center;}
.quiz-opt.selected .quiz-opt-radio{border-color:var(--accent);background:var(--accent);}
.quiz-opt.selected .quiz-opt-radio::after{content:'';width:6px;height:6px;border-radius:50%;background:#000;}
.result-card{display:none;padding:32px;background:rgba(0,229,255,0.03);border:1px solid rgba(0,229,255,0.12);border-radius:24px;margin-top:24px;}
.result-card.show{display:block;animation:fadein 0.5s ease;}
@keyframes fadein{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}
.result-link{display:flex;align-items:center;gap:10px;padding:12px 16px;background:var(--glass);border:1px solid var(--border);border-radius:12px;text-decoration:none;color:var(--muted);font-size:0.85rem;transition:all 0.2s;margin-top:8px;}
.result-link:hover{border-color:var(--accent);color:var(--accent);}
.result-link::before{content:'→';color:var(--accent);font-family:var(--font-m);}
.magnet-card{max-width:640px;padding:48px;}
.magnet-icon-wrap{width:80px;height:80px;border-radius:24px;background:rgba(0,229,255,0.08);border:1px solid rgba(0,229,255,0.2);display:flex;align-items:center;justify-content:center;font-size:2.4rem;margin-bottom:28px;}
.inside-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:24px 0;}
.inside-item{display:flex;align-items:center;gap:8px;font-size:0.82rem;color:var(--muted);padding:10px 14px;background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:10px;}
.inside-item::before{content:'✓';color:var(--accent);font-family:var(--font-m);font-size:0.7rem;flex-shrink:0;}
.referral-section{margin-top:32px;padding:28px;background:rgba(59,111,255,0.03);border:1px solid rgba(59,111,255,0.1);border-radius:20px;}
.referral-section h4{font-weight:800;font-size:0.95rem;color:var(--text);margin-bottom:8px;}
.referral-section p{font-size:0.85rem;color:var(--muted);margin-bottom:16px;}
.referral-code-wrap{display:flex;gap:10px;}
.referral-code{flex:1;padding:12px 20px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:100px;font-family:var(--font-m);font-size:0.85rem;color:var(--text);outline:none;}
.copy-btn{padding:12px 20px;border-radius:100px;background:rgba(0,229,255,0.08);border:1px solid rgba(0,229,255,0.2);color:var(--accent);font-family:var(--font-m);font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.copy-btn:hover{background:rgba(0,229,255,0.12);}
.discount-card{max-width:640px;padding:48px;text-align:center;position:relative;overflow:hidden;}
.discount-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,229,255,0.03),rgba(59,111,255,0.03));pointer-events:none;}
.discount-code-chip{display:inline-flex;align-items:center;gap:12px;padding:16px 28px;background:rgba(0,229,255,0.08);border:2px dashed rgba(0,229,255,0.3);border-radius:16px;font-family:var(--font-m);font-size:1.4rem;letter-spacing:0.2em;color:var(--accent);margin:28px 0;cursor:pointer;transition:all 0.2s;position:relative;z-index:1;}
.discount-code-chip:hover{background:rgba(0,229,255,0.12);border-color:var(--accent);}
.discount-perks{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:28px;text-align:left;position:relative;z-index:1;}
.perk{padding:16px;background:var(--glass);border:1px solid var(--border);border-radius:14px;}
.perk-title{font-size:0.85rem;font-weight:800;color:var(--text);margin-bottom:4px;}
.perk-desc{font-size:0.78rem;color:var(--muted);}
.services-grid{display:flex;flex-direction:column;gap:10px;margin-top:24px;text-align:left;position:relative;z-index:1;}
.service-row{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:var(--glass);border:1px solid var(--border);border-radius:14px;text-decoration:none;transition:all 0.2s;}
.service-row:hover{border-color:var(--accent);transform:translateX(4px);}
.service-row-left strong{display:block;font-size:0.88rem;color:var(--text);}
.service-row-left span{font-family:var(--font-m);font-size:0.68rem;color:var(--muted);}
.service-price{font-family:var(--font-d);font-size:1.4rem;color:var(--accent);}
.final-cta{text-align:center;margin-top:80px;padding:60px 40px;background:linear-gradient(135deg,rgba(0,229,255,0.04),rgba(59,111,255,0.04));border:1px solid rgba(0,229,255,0.1);border-radius:40px;position:relative;z-index:1;}
.fade-up{opacity:0;transform:translateY(40px);transition:opacity 0.7s ease,transform 0.7s ease;}
.fade-up.visible{opacity:1;transform:translateY(0);}
.d2{transition-delay:0.2s;}
@media(max-width:768px){nav{padding:16px 20px;}.progress-nav{padding:10px 20px;}.section{padding:100px 0 60px;}.hero-title{font-size:clamp(4rem,18vw,7rem);}.inside-grid{grid-template-columns:1fr;}.discount-perks{grid-template-columns:1fr;}.card{padding:28px;}.magnet-card{padding:28px;}.discount-card{padding:28px;}}
</style>
</head>
<body>
<div class="stars" id="stars"></div>
<div class="orb orb1"></div>
<div class="orb orb2"></div>

<nav>
  <a href="/" class="nav-brand">GALAXY<span>BUILT</span>.dev</a>
  <div class="nav-pill"><span class="dot"></span>Remote Hustler Protocol</div>
  <a href="/" class="nav-back">← Back</a>
</nav>

<div class="progress-nav">
  <div class="prog-step"><div class="prog-dot active" id="pd1" onclick="scrollToStep(1)">1</div><span class="prog-label active" id="pl1">Who You Are</span></div>
  <div class="prog-line"></div>
  <div class="prog-step"><div class="prog-dot" id="pd2" onclick="scrollToStep(2)">2</div><span class="prog-label" id="pl2">Join the List</span></div>
  <div class="prog-line"></div>
  <div class="prog-step"><div class="prog-dot" id="pd3" onclick="scrollToStep(3)">3</div><span class="prog-label" id="pl3">Quick Profile</span></div>
  <div class="prog-line"></div>
  <div class="prog-step"><div class="prog-dot" id="pd4" onclick="scrollToStep(4)">4</div><span class="prog-label" id="pl4">Your Gift</span></div>
  <div class="prog-line"></div>
  <div class="prog-step"><div class="prog-dot" id="pd5" onclick="scrollToStep(5)">5</div><span class="prog-label" id="pl5">Your Discount</span></div>
</div>

<!-- STEP 1 -->
<section class="section" id="step1">
  <div class="wrap">
    <div class="fade-up">
      <div class="hero-tag"><span style="font-size:1rem;">💻</span>Remote Hustler Protocol — Step 1 of 5</div>
      <h1 class="hero-title">REMOTE<br/><span class="text-cyan">HUSTLER.</span></h1>
      <p class="hero-sub">You're already remote or close to it. You need income stacks, AI tools, and systems that multiply your output without multiplying your hours. This protocol is engineered for you.</p>
      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <button class="btn btn-cyan" onclick="scrollToStep(2)">This Is Me — I'm Ready <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></button>
        <a href="/" class="btn btn-ghost">I'm a different persona</a>
      </div>
      <div class="stats-row">
        <div class="stat-item"><div class="stat-num">5</div><div class="stat-label">Curated jobs weekly</div></div>
        <div class="stat-item"><div class="stat-num">3X</div><div class="stat-label">Output with AI</div></div>
        <div class="stat-item"><div class="stat-num">$0</div><div class="stat-label">To start</div></div>
        <div class="stat-item"><div class="stat-num">7</div><div class="stat-label">Days to first client</div></div>
      </div>
    </div>
  </div>
</section>

<div class="step-connector"></div>

<!-- STEP 2 -->
<section class="section" id="step2">
  <div class="wrap">
    <div class="step-num">2</div>
    <div style="max-width:640px;" class="fade-up">
      <div class="step-badge"><div class="step-badge-num">2</div><span class="step-badge-label">Join the Remote Hustler List</span></div>
      <h2 class="display" style="font-size:clamp(3rem,7vw,5.5rem);margin-bottom:16px;">YOUR INCOME<br/><span class="text-cyan">STACK</span><br/>STARTS HERE.</h2>
      <p style="color:var(--muted);font-size:0.95rem;line-height:1.8;max-width:480px;margin-bottom:8px;">Join the Remote Hustler segment — you'll get content filtered specifically for stacking income streams, landing remote roles faster, and building AI-assisted workflows that scale.</p>
      <div class="get-list">
        <div class="get-item"><span class="get-icon">💼</span><div class="get-text"><strong>Remote Jobs Starter Pack</strong><span>20 platforms ranked by quality — including 6 most hustlers never find</span></div></div>
        <div class="get-item"><span class="get-icon">🤖</span><div class="get-text"><strong>Weekly AI Prompt Toolkit</strong><span>Copy-paste prompts for cover letters, LinkedIn, cold outreach, and freelance offers</span></div></div>
        <div class="get-item"><span class="get-icon">⚡</span><div class="get-text"><strong>Income Stack Breakdowns</strong><span>Real case studies on building multiple income streams simultaneously</span></div></div>
        <div class="get-item"><span class="get-icon">🎯</span><div class="get-text"><strong>ATS-Beating Application System</strong><span>The exact workflow to land remote interviews faster than everyone else</span></div></div>
      </div>
      <form id="email-form" onsubmit="handleSubmit(event)">
        <div class="form-row">
          <input type="email" class="form-input" placeholder="your@email.com" id="email-input" required/>
          <button type="submit" class="btn btn-cyan" id="submit-btn">Join Free <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></button>
        </div>
        <p class="form-note">✓ Remote Hustler segment &nbsp;·&nbsp; ✓ Free forever &nbsp;·&nbsp; ✓ Unsubscribe anytime</p>
        <p id="form-status" style="font-family:var(--font-m);font-size:0.75rem;margin-top:8px;display:none;"></p>
      </form>
    </div>
  </div>
</section>

<div class="step-connector"></div>

<!-- STEP 3 -->
<section class="section" id="step3">
  <div class="wrap">
    <div class="step-num">3</div>
    <div style="max-width:680px;" class="fade-up">
      <div class="step-badge"><div class="step-badge-num">3</div><span class="step-badge-label">Quick Profile — 3 Questions</span></div>
      <h2 class="display" style="font-size:clamp(2.5rem,6vw,4.5rem);margin-bottom:8px;">WHAT'S YOUR<br/><span class="text-cyan">SITUATION?</span></h2>
      <p style="color:var(--muted);font-size:0.9rem;margin-bottom:40px;">3 questions to show you exactly where to focus your energy first.</p>
      <div class="quiz-q">
        <div class="quiz-q-label">Question 1 of 3</div>
        <div class="quiz-q-text">What's your current remote work status?</div>
        <div class="quiz-options" id="q1">
          <div class="quiz-opt" onclick="selectOpt('q1',this,'none')"><div class="quiz-opt-radio"></div>Not remote yet — still in office or job searching</div>
          <div class="quiz-opt" onclick="selectOpt('q1',this,'partial')"><div class="quiz-opt-radio"></div>Partially remote — hybrid or contract work</div>
          <div class="quiz-opt" onclick="selectOpt('q1',this,'full')"><div class="quiz-opt-radio"></div>Fully remote — one income source</div>
          <div class="quiz-opt" onclick="selectOpt('q1',this,'stack')"><div class="quiz-opt-radio"></div>Fully remote — building multiple income streams</div>
        </div>
      </div>
      <div class="quiz-q">
        <div class="quiz-q-label">Question 2 of 3</div>
