<script>
(function(){const c=document.getElementById('stars');for(let i=0;i<80;i++){const s=document.createElement('div');s.className='star';const sz=Math.random()*2+0.5;s.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--op:${Math.random()*0.4+0.1};--d:${Math.random()*4+2}s;--delay:-${Math.random()*4}s;`;c.appendChild(s);}})();
const steps=[document.getElementById('step1'),document.getElementById('step2'),document.getElementById('step3'),document.getElementById('step4'),document.getElementById('step5')];
function updateProgress(){const scrollY=window.scrollY+window.innerHeight/2;let current=0;steps.forEach((s,i)=>{if(s&&scrollY>s.offsetTop)current=i;});for(let i=0;i<5;i++){const dot=document.getElementById(`pd${i+1}`);const label=document.getElementById(`pl${i+1}`);dot.classList.remove('active','done');label.classList.remove('active');if(i<current){dot.classList.add('done');}else if(i===current){dot.classList.add('active');label.classList.add('active');}}}
window.addEventListener('scroll',updateProgress);
function scrollToStep(n){const el=document.getElementById(`step${n}`);if(el)el.scrollIntoView({behavior:'smooth',block:'start'});}
const observer=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.1});
document.querySelectorAll('.fade-up').forEach(el=>observer.observe(el));
async function handleSubmit(e){e.preventDefault();const email=document.getElementById('email-input').value;const btn=document.getElementById('submit-btn');const status=document.getElementById('form-status');btn.textContent='Joining...';btn.disabled=true;try{const res=await fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,source:'web',magnet:'remote-jobs-pack',tags:['remote_hustler']})});const data=await res.json();if(data.success){document.getElementById('email-form').innerHTML='<p style="color:#00e9a3;font-weight:800;font-size:0.95rem;">✓ You\'re in — your remote income stack is on the way.</p>';localStorage.setItem('gb_email',email);localStorage.setItem('gb_persona','remote-hustler');localStorage.setItem('gb_subscribed','1');unlockDownloads();if(typeof fbq!=='undefined'){fbq('track','Lead');fbq('trackCustom','PersonaSubscribed',{persona:'remote-hustler'});}if(typeof gtag!=='undefined'){gtag('event','persona_subscribed',{persona:'remote-hustler'});}setTimeout(()=>scrollToStep(3),1500);}else{throw new Error(data.error);}}catch{btn.textContent='Join Free';btn.disabled=false;status.textContent='Something went wrong — try again.';status.style.color='#ff6b35';status.style.display='block';}}
function unlockDownloads(){const d1=document.getElementById('main-download');const d2=document.getElementById('bonus-download');if(d1){d1.style.opacity='1';d1.style.pointerEvents='auto';}if(d2){d2.style.opacity='1';d2.style.pointerEvents='auto';}}
if(localStorage.getItem('gb_subscribed')==='1'){unlockDownloads();}
const savedAnswers=JSON.parse(localStorage.getItem('gb_quiz_hustler')||'{}');
const answers=Object.assign({},savedAnswers);
Object.entries(answers).forEach(([qId,val])=>{document.querySelectorAll(`#${qId} .quiz-opt`).forEach(o=>{if(o.getAttribute('onclick')&&o.getAttribute('onclick').includes(`'${val}'`))o.classList.add('selected');});});
if(Object.keys(answers).length>=3){const btn=document.getElementById('result-btn');if(btn){btn.style.opacity='1';btn.style.pointerEvents='auto';}}
function selectOpt(qId,el,val){document.querySelectorAll(`#${qId} .quiz-opt`).forEach(o=>o.classList.remove('selected'));el.classList.add('selected');answers[qId]=val;localStorage.setItem('gb_quiz_hustler',JSON.stringify(answers));if(Object.keys(answers).length>=3){const btn=document.getElementById('result-btn');btn.style.opacity='1';btn.style.pointerEvents='auto';}}
function generateResult(){localStorage.setItem('gb_quiz_hustler',JSON.stringify(answers));if(typeof fbq!=='undefined'){fbq('trackCustom','PersonaQuizCompleted',{persona:'remote-hustler'});}if(typeof gtag!=='undefined'){gtag('event','persona_quiz_completed',{persona:'remote-hustler'});}const results={none:{title:'Start with the jobs pack — then build from there',desc:'Your first move is landing a remote role. Once income is stable you can stack from there.',links:[{text:'Top Remote Job Boards in 2026',url:'/blog'},{text:'How to Beat ATS Filters Every Time',url:'/blog'},{text:'Download the Remote Jobs Starter Pack',url:'/downloads/remote-jobs-pack?ref=quiz'}]},stack:{title:'You\'re ready to automate — here\'s how',desc:'You have the income. Now it\'s about systemizing and stacking without burning out.',links:[{text:'5 AI Workflows That Replace Manual Tasks',url:'/blog'},{text:'Building a Second Income Stream in 30 Days',url:'/blog'},{text:'The Prompt Vault — Automation Edition',url:'/downloads/prompt-vault?ref=quiz'}]},full:{title:'One income is good — a stack is better',desc:'You\'re fully remote with one source. Diversifying protects you and grows your ceiling.',links:[{text:'How to Stack Remote Income Streams',url:'/blog'},{text:'Freelancing While Employed — The Safe Way',url:'/blog'},{text:'The Prompt Vault',url:'/downloads/prompt-vault?ref=quiz'}]},partial:{title:'Close the gap to full remote first',desc:'Partial remote is the stepping stone. Here\'s how to make the full jump.',links:[{text:'Negotiating Full Remote With Your Current Company',url:'/blog'},{text:'Finding Full Remote Roles in Your Field',url:'/blog'},{text:'The Remote Jobs Starter Pack',url:'/downloads/remote-jobs-pack?ref=quiz'}]}};
const r=results[answers.q1]||results.none;document.getElementById('result-title').textContent=r.title;document.getElementById('result-desc').textContent=r.desc;document.getElementById('result-links').innerHTML=r.links.map(l=>`<a class="result-link" href="${l.url}">${l.text}</a>`).join('');document.getElementById('result-card').classList.add('show');setTimeout(()=>scrollToStep(4),800);}

function copyCode(){navigator.clipboard.writeText('HUSTLER20').then(()=>{document.getElementById('copy-confirm').style.display='block';document.getElementById('discount-chip').style.borderColor='#00e9a3';if(typeof fbq!=='undefined'){fbq('trackCustom','PersonaDiscountCopied',{persona:'remote-hustler'});}if(typeof gtag!=='undefined'){gtag('event','persona_discount_copied',{persona:'remote-hustler'});}setTimeout(()=>{document.getElementById('copy-confirm').style.display='none';document.getElementById('discount-chip').style.borderColor='';},2500);});}
function fireDownloadPixel(){if(typeof fbq!=='undefined'){fbq('trackCustom','PersonaDownload',{persona:'remote-hustler',magnet:'remote-jobs-pack'});}if(typeof gtag!=='undefined'){gtag('event','persona_download',{persona:'remote-hustler',magnet:'remote-jobs-pack'});}}
</script>
