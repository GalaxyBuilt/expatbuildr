---
import Layout from '../layouts/Layout.astro';
import Pixels from '../components/Pixels.astro';

const title = "Remote Income — Earn $150k+ Remotely | ExpatBuildr";
const description = "Systems, negotiation, and micro‑SaaS strategies to build a sovereign remote income. Jobs, productized services, and passive yield.";
---

<Layout title={title} description={description} minimal={true}>
  <Fragment slot="head">
    <Pixels page="money-remote-income" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
  </Fragment>

  <main class="container" style="padding:40px 24px; max-width:900px;">
    <a href="/blog" class="back-link">← Back to Blog</a>
    <h1 style="margin-top:18px;">Remote Income: The Sovereign Salary</h1>
    <p style="color:var(--text-secondary); max-width:70%;">Practical systems to stop trading time for dollars: market sniping, productized offers, and micro‑SaaS yield that compounds. This landing page pulls together our best playbooks and a single conversion path — join the newsletter or request a growth call.</p>

    <div style="margin-top:28px; margin-bottom:32px;">
      <img src="/images/remote work.jpg" alt="Remote Work Setup" style="width:100%; max-width:100%; height:auto; border-radius:12px; object-fit:cover;" />
    </div>

    <section style="margin-top:28px;">
      <h2>What you'll get</h2>
      <ul>
        <li>Job Sniping — frameworks to find and win $100k+ remote roles before they're public.</li>
        <li>Productized Service Playbook — position technical skills as higher‑margin offerings.</li>
        <li>Micro‑SaaS & Arb — how to route surplus capital into automated yield engines.</li>
      </ul>
    </section>

    <section style="margin-top:20px;">
      <div class="section-label">Supporting Articles</div>
      <ul>
        <li><a href="/blog/remote-income/how-to-find-fully-remote-jobs-that-never-rto">How to Find Fully Remote Jobs That Never RTO</a></li>
        <li><a href="/blog/remote-income/how-to-negotiate-remote-arrangement-current-job">How to Negotiate a Remote Arrangement</a></li>
        <li><a href="/blog/remote-income/how-to-start-remote-micro-saas">How to Start a Remote Micro‑SaaS</a></li>
      </ul>
    </section>

    <section style="margin-top:22px;">
      <h2>Products & Funnels</h2>
      <p style="color:var(--text-secondary); max-width:80%;">Every pillar converts through the same funnel architecture: Blog -> Lead Magnet -> Tripwire -> Core Offer -> Ascension. Below is the Remote Income funnel and the digital products that power it.</p>
      <ol>
        <li><strong>Top (Awareness)</strong>: Blog posts (job sniping guides) driving organic traffic and SEO authority.</li>
        <li><strong>Lead Magnet</strong>: Remote Income Pack (checklists, job list, negotiation templates) — exchanges email for instant value.</li>
        <li><strong>Tripwire</strong>: Micro‑SaaS Quickstart (low‑priced course or checklist) that solves the first friction point.</li>
        <li><strong>Core Offer</strong>: 1:1 coaching or an advanced Micro‑SaaS launch course.</li>
        <li><strong>Ascension</strong>: Done‑for‑you hiring/poaching service, ongoing advisory, or access to paid tools (arbitrage bots).</li>
      </ol>
      <p style="margin-top:8px;">Conversion hooks we use: scarcity (limited beta), value stacking (4 resources), and immediate wins (checklists that produce results in <7 days). KPI focus: email conversion rate, tripwire conversion, and LTV/CAC.</p>
    </section>

    <section style="margin-top:28px;">
      <div class="subscribe-box">
        <div class="progress-header">
          <span class="progress-label">Free Resource</span>
          <strong class="progress-count">Remote Income Pack</strong>
        </div>
        <form id="subscribe-remote" class="sub-form">
          <input type="email" id="email-remote" name="email" placeholder="Your best email" required class="fake-input" />
          <button type="submit" id="submit-remote" class="btn-primary">Get The Pack →</button>
        </form>
        <p id="msg-remote" class="form-msg hidden"></p>
      </div>
      <p style="margin-top:8px; font-size:0.9rem; color:var(--text-secondary)">Or <a href="/contact">request a consulting call</a> — paid engagements available.</p>
    </section>

  </main>

  <script is:inline>
    async function submitRemote(e){
      e.preventDefault();
      const email = document.getElementById('email-remote').value.trim();
      const msg = document.getElementById('msg-remote');
      const btn = document.getElementById('submit-remote');
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if(!re.test(email)){ msg.innerText='Please enter a valid email.'; msg.classList.remove('hidden'); return; }
      btn.disabled=true; btn.innerText='Submitting...';
      try{
        const res = await fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,source:'money-remote-income',magnet:'remote-income-pack',tags:['remote_hustler']})});
        const data = await res.json();
        if(data.success){ window.location.href=data.redirect_url || '/download?magnet=remote-income-pack'; }
        else { btn.disabled=false; btn.innerText='Get The Pack →'; msg.innerText=data.error||'Error'; msg.classList.remove('hidden'); }
      }catch(err){ btn.disabled=false; btn.innerText='Get The Pack →'; msg.innerText='Network error'; msg.classList.remove('hidden'); }
    }
    document.getElementById('subscribe-remote')?.addEventListener('submit', submitRemote);
  </script>
</Layout>
