<Layout 
	title="Portfolio | Expat Buildr"
	description="A selection of systems, funnels, and products shipped for clients and internal brands by Expat Buildr."
	noindex={true}
>

	<!-- Page Header -->
	<section class="max-w-7xl mx-auto text-center space-y-8 py-12 md:py-20 relative px-4">
		<div class="absolute -top-20 md:-top-40 left-1/2 -translate-x-1/2 w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-accent-blue/20 rounded-full blur-[80px] md:blur-[120px] -z-10 animate-pulse"></div>
		<h1 class="text-5xl md:text-7xl font-black font-display tracking-tight leading-[1] md:leading-[0.9]">
			BUILT BY<br/>
			<span class="text-gradient">GALAXY.</span>
		</h1>
		<p class="max-w-2xl mx-auto text-institutional-secondary text-lg leading-relaxed">
			A selection of systems, funnels, and products shipped for clients and internal brands.
		</p>
	</section>

	<!-- Projects Sections -->
	<div id="projects" class="max-w-7xl mx-auto space-y-32 py-20">
		
		<!-- Galaxy Leads Featured Hero -->
		<section id="galaxyleads-featured" class="relative overflow-hidden rounded-[3rem] glass-card border-[1px] border-accent-cyan/30 reveal-on-scroll">
			<div class="absolute inset-0 bg-gradient-to-br from-accent-blue/10 via-transparent to-accent-purple/10 pointer-events-none"></div>
			
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 p-8 md:p-16 relative z-10">
				<div class="space-y-8 flex flex-col justify-center">
					<div class="inline-flex gap-2 flex-wrap">
						<span class="px-3 py-1 text-xs font-bold tracking-wider rounded-full bg-accent-blue/10 text-accent-cyan border border-accent-cyan/20">V2 CLIENT MODE</span>
						<span class="px-3 py-1 text-xs font-bold tracking-wider rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">TRUE ROI ENGINE</span>
						<span class="px-3 py-1 text-xs font-bold tracking-wider rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20">5 SCRAPER ENGINES</span>
					</div>
					
					<h2 class="text-5xl md:text-6xl font-black font-display tracking-tight text-slate-900 dark:text-white leading-[1.1]">
						Galaxy Leads.<br/>
						<span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-accent-cyan">The Autonomous Outreach Machine.</span>
					</h2>
					
					<p class="text-lg text-slate-400 leading-relaxed max-w-xl">
						A local desktop application that runs entirely on your computer. No monthly SaaS fees. No backend. No subscriptions. It autonomously scrapes leads, detects automation opportunities, scores them via true ROI logic, and sequences personalized outreach on your behalf.
					</p>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
						<div class="glass-card p-4 rounded-xl border border-white/5 space-y-2">
							<div class="text-accent-cyan"><Cpu size={24} /></div>
							<div class="font-bold text-slate-900 dark:text-white">5-Engine Scraper</div>
							<div class="text-sm text-slate-500">Indeed, ZipRecruiter, Yelp, Google, and Reddit signals running in parallel.</div>
						</div>
						<div class="glass-card p-4 rounded-xl border border-white/5 space-y-2">
							<div class="text-accent-purple"><LineChart size={24} /></div>
							<div class="text-slate-900 dark:text-white font-bold">ROI & AI Scoring</div>
							<div class="text-sm text-slate-500">Scores true cost, calculates payback period, and extracts exact ad phrases.</div>
						</div>
						<div class="glass-card p-4 rounded-xl border border-white/5 space-y-2">
