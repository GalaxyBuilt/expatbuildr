---
import Layout from '../layouts/Layout.astro';
import Pixels from '../components/Pixels.astro';

const title = "ExpatBuildr — Tony Long";
const description = "American founder building from Cebu, Philippines. Publishing the arbitrage playbook weekly.";
---

<Layout title={title} description={description} ogImage="/expatog.jpg">
  <Fragment slot="head">
    <Pixels page="newsletter-landing" source="homepage" />
    <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;700;900&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </Fragment>

  <div class="expat-home">
    <!-- HERO -->
    <section class="hero">
      <div class="eyebrow">American · Cebu, Philippines · Building in public</div>
      <h1>
        Lost everything.<br>
        <span class="strike">stayed broke.</span><br>
        Did the math.<br>
        <span class="signal">Left.</span>
      </h1>
      <p class="hero-sub">
        I'm Tony Long. I lost $300K in crypto, moved to Cebu, and started earning in USD while spending in pesos. Now I build online businesses from Southeast Asia and document everything in public.
      </p>
      <div class="form-wrap">
        <label class="form-label">Get the weekly arbitrage playbook — free</label>
        <form id="subscribe-form-hero" class="sub-form">
          <input type="email" id="email-hero" name="email" placeholder="Enter your best email" required class="email-input" />
          <button type="submit" id="submit-btn-hero" class="btn-primary">GET INSTANT ACCESS →</button>
        </form>
        <p id="form-message-hero" class="form-msg hidden"></p>
        <div class="form-trust">
          <span>Free forever</span>
          <span>4 resources instantly</span>
          <span>No spam. Ever.</span>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- STORY -->
    <section class="story-section" id="story">
      <div class="section-label">The story</div>
      <h2>I didn't leave because things went well.</h2>
      <p>
        I lost $300K in crypto. Not in one trade — in a series of increasingly confident bets on things I couldn't control. I had skill. My position was wrong. <strong>Skill in a bad position still loses.</strong>
      </p>
      <p>
        That loss forced me to look at everything differently. Not just how I earn money — but where I earn it, where I spend it, and what systems I build in between.
      </p>
      <p>
        I moved to Cebu, Philippines. Started earning in USD. Spending in pesos. The gap between those two currencies became my weapon. <strong>That's arbitrage.</strong> It works in 15 countries. I'm running it from one of them — and building it all in public.
      </p>
    </section>

    <!-- STATS -->
    <div class="stats-bar">
      <div class="stats-inner">
        <div class="stat-block">
          <div class="stat-number"><span class="signal">$300K</span></div>
          <div class="stat-label">Lost in crypto.<br>The lesson that changed everything.</div>
        </div>
        <div class="stat-block">
          <div class="stat-number">15</div>
          <div class="stat-label">Arbitrage Diamond<br>countries in the playbook.</div>
        </div>
        <div class="stat-block">
          <div class="stat-number" id="sub-count">566</div>
          <div class="stat-label">Freedom Seekers<br>reading every Tuesday.</div>
        </div>
      </div>
    </div>

    <!-- PROPERTIES -->
    <section class="properties-section" id="work">
      <div class="properties-inner">
        <div class="section-label">What I'm building</div>
        <h2>Four properties.<br>One mission.</h2>
        <div class="props-grid">
          <a href="https://galaxyarbitrage.com" target="_blank" rel="noopener" class="prop-card">
            <div>
              <span class="prop-tag">Newsletter</span>
              <div class="prop-name">Galaxy Arbitrage Weekly</div>
              <p class="prop-desc">The weekly playbook for Americans living abroad. Geographic arbitrage, currency gaps, labor plays, AI leverage, and health arbitrage. Every Tuesday. Free forever.</p>
            </div>
            <div class="prop-arrow">→</div>
          </a>
          <a href="https://galaxybuilt.dev" target="_blank" rel="noopener" class="prop-card">
            <div>
              <span class="prop-tag">Studio</span>
              <div class="prop-name">GalaxyBuilt</div>
              <p class="prop-desc">Done-for-you landing pages and conversion funnels for expat founders and remote business owners. If your website is leaking customers — I fix that.</p>
            </div>
            <div class="prop-arrow">→</div>
          </a>
          <a href="https://youtube.com/@GalaxyArb" target="_blank" rel="noopener" class="prop-card">
            <div>
              <span class="prop-tag">YouTube</span>
              <div class="prop-name">@GalaxyArb</div>
              <p class="prop-desc">Deeper dives on the arbitrage plays covered in the newsletter. Real numbers, real locations, real math — filmed from Cebu.</p>
            </div>
            <div class="prop-arrow">→</div>
          </a>
          <a href="https://youtube.com/@expatbuildr" target="_blank" rel="noopener" class="prop-card">
            <div>
              <span class="prop-tag">YouTube</span>
              <div class="prop-name">@ExpatBuildr</div>
              <p class="prop-desc">The unfiltered, behind-the-scenes look into my life as an expat.</p>
            </div>
            <div class="prop-arrow">→</div>
          </a>
        </div>
      </div>
    </section>

    <!-- NEWSLETTER -->
    <section class="newsletter-section" id="newsletter">
      <div class="section-label">Every Tuesday · Free forever</div>
      <h2>The arbitrage playbook.<br>Weekly.</h2>
      <p>
        Real strategies for Americans living abroad. Geographic arbitrage, currency gaps, remote income plays, health savings, and AI leverage — written by someone running the model in real time from Cebu.
      </p>
      <div class="form-wrap">
        <label class="form-label">Join 566 Freedom Seekers</label>
        <form id="subscribe-form-bottom" class="sub-form">
          <input type="email" id="email-bottom" name="email" placeholder="Enter your best email" required class="email-input" />
          <button type="submit" id="submit-btn-bottom" class="btn-primary">Join Free →</button>
        </form>
        <p id="form-message-bottom" class="form-msg hidden"></p>
        <div class="form-trust">
          <span>Free forever</span>
          <span>4 resources delivered instantly</span>
          <span>Unsubscribe anytime</span>
        </div>
      </div>
    </section>
  </div>

  <style>
    .expat-home {
      --white: #ffffff;
      --off: #f7f7f5;
      --black: #0a0a0a;
      --gray: #6b6b6b;
      --border: #e2e2de;
      --signal: #ff4d00;
      --signal-hover: #e63d00;
      font-family: 'Epilogue', sans-serif;
      color: var(--black);
    }

    .expat-home .hero {
      max-width: 860px;
      margin: 0 auto;
      padding: 40px 20px 60px;
    }

    .expat-home .eyebrow {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 13px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--signal);
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .expat-home .eyebrow::before {
      content: '';
      width: 24px;
      height: 2px;
      background: var(--signal);
      display: inline-block;
      flex-shrink: 0;
    }

    .expat-home .hero h1 {
      font-size: clamp(44px, 8vw, 80px);
      font-weight: 900;
      line-height: 1.03;
      letter-spacing: -0.03em;
      color: var(--black);
      margin: 0 0 28px;
    }
    .expat-home .hero h1 .strike { text-decoration: line-through; color: #bbb; font-weight: 400; }
    .expat-home .hero h1 .signal { color: var(--signal); }

    .expat-home .hero-sub {
      font-size: 20px;
      color: #444;
      line-height: 1.65;
      margin-bottom: 40px;
      max-width: 620px;
    }

    .expat-home .form-wrap {
      background: var(--off);
      border: 1px solid var(--border);
      padding: 32px;
      margin-bottom: 16px;
    }

    .expat-home .form-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gray);
      margin-bottom: 14px;
      display: block;
    }

    .expat-home .sub-form { display: flex; gap: 0; flex-wrap: wrap; }

    .expat-home .email-input {
      flex: 1;
      min-width: 200px;
      padding: 16px 20px;
      font-size: 16px;
      font-family: 'Epilogue', sans-serif;
      border: 2px solid var(--black);
      border-right: none;
      outline: none;
      background: var(--white);
      color: var(--black);
    }
    .expat-home .email-input:focus { border-color: var(--signal); }

    .expat-home .btn-primary {
      padding: 16px 28px;
      background: var(--signal);
      color: var(--white);
      font-family: 'Epilogue', sans-serif;
      font-size: 14px;
      font-weight: 700;
      border: 2px solid var(--signal);
      cursor: pointer;
      white-space: nowrap;
      letter-spacing: 0.02em;
    }
    .expat-home .btn-primary:hover { background: var(--signal-hover); border-color: var(--signal-hover); }
    .expat-home .btn-primary:disabled { opacity: 0.6; cursor: default; }

    .expat-home .form-msg {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      margin-top: 12px;
      color: var(--gray);
    }
    .expat-home .form-msg.hidden { display: none; }

    .expat-home .form-trust {
      font-size: 12px;
      color: var(--gray);
      margin-top: 14px;
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      font-family: 'IBM Plex Mono', monospace;
    }
    .expat-home .form-trust span::before { content: '✓ '; color: var(--signal); }

    .expat-home .section-divider { border: none; border-top: 1px solid var(--border); max-width: 860px; margin: 0 auto; }

    .expat-home .story-section {
      padding: 60px 20px;
      max-width: 860px;
      margin: 0 auto;
    }
    .expat-home .section-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--signal);
      margin-bottom: 20px;
    }
    .expat-home .story-section h2,
    .expat-home .properties-inner h2,
    .expat-home .newsletter-section h2 {
      font-size: clamp(32px, 4.5vw, 48px);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.08;
      color: var(--black);
      margin: 0 0 28px;
    }
    .expat-home .story-section p {
      font-size: 18px;
      color: #444;
      line-height: 1.75;
      margin-bottom: 20px;
    }
    .expat-home .story-section p strong { color: var(--black); }

    .expat-home .stats-bar { background: var(--black); padding: 50px 20px; }
    .expat-home .stats-inner {
      max-width: 860px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .expat-home .stat-block { padding: 32px 24px; background: #111; }
    .expat-home .stat-number {
      font-size: clamp(34px, 5vw, 52px);
      font-weight: 900;
      color: var(--white);
      letter-spacing: -0.03em;
      line-height: 1;
      margin-bottom: 8px;
    }
    .expat-home .stat-number .signal { color: var(--signal); }
    .expat-home .stat-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: #666;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 1.5;
    }

    .expat-home .properties-section { padding: 60px 20px; background: var(--off); }
    .expat-home .properties-inner { max-width: 860px; margin: 0 auto; }
    .expat-home .props-grid { display: flex; flex-direction: column; gap: 3px; }
    .expat-home .prop-card {
      background: var(--white);
      padding: 28px 24px;
      text-decoration: none;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      border-left: 3px solid transparent;
      transition: border-color 0.2s;
    }
    .expat-home .prop-card:hover { border-color: var(--signal); }
    .expat-home .prop-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--signal);
      margin-bottom: 10px;
      display: block;
    }
    .expat-home .prop-name { font-size: 22px; font-weight: 700; color: var(--black); margin-bottom: 8px; }
    .expat-home .prop-desc { font-size: 14px; color: var(--gray); line-height: 1.6; max-width: 480px; }
    .expat-home .prop-arrow { font-size: 22px; color: var(--signal); flex-shrink: 0; }

    .expat-home .newsletter-section { padding: 60px 20px 80px; max-width: 860px; margin: 0 auto; }
    .expat-home .newsletter-section p { font-size: 18px; color: #444; line-height: 1.65; margin-bottom: 32px; max-width: 560px; }

    @media (max-width: 640px) {
      .expat-home .sub-form { flex-direction: column; }
      .expat-home .email-input { border-right: 2px solid var(--black); border-bottom: none; }
      .expat-home .btn-primary { justify-content: center; }
      .expat-home .stats-inner { grid-template-columns: 1fr; }
      .expat-home .prop-card { flex-direction: column; gap: 12px; }
    }
  </style>

  <script is:inline>
    async function handleHomeSubmit(emailVal, btnEl, msgEl) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(emailVal)) {
        msgEl.innerText = '❌ Please enter a valid email address.';
        msgEl.classList.remove('hidden');
        return;
      }
      btnEl.disabled = true;
      btnEl.innerText = 'Joining...';
      msgEl.innerText = '';
      msgEl.classList.add('hidden');
      try {
        const response = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: emailVal, source: 'web', magnet: 'remote-jobs-pack', tags: ['expatbuildr-homepage'] })
        });
        const data = await response.json();
        if (data.success) {
          if (window.fireLeadEvent) window.fireLeadEvent();
          btnEl.innerText = 'Redirecting...';
          window.location.href = data.redirect_url || '/newsletter/thank-you';
        } else {
          btnEl.disabled = false;
          btnEl.innerText = 'Join Free →';
          msgEl.innerText = '❌ ' + (data.error || 'Error, try again.');
          msgEl.classList.remove('hidden');
        }
      } catch (err) {
        btnEl.disabled = false;
        btnEl.innerText = 'Join Free →';
        msgEl.innerText = '❌ Network error.';
        msgEl.classList.remove('hidden');
      }
    }

    document.getElementById('subscribe-form-hero')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      await handleHomeSubmit(
        document.getElementById('email-hero').value.trim(),
        document.getElementById('submit-btn-hero'),
        document.getElementById('form-message-hero')
      );
    });

    document.getElementById('subscribe-form-bottom')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      await handleHomeSubmit(
        document.getElementById('email-bottom').value.trim(),
        document.getElementById('submit-btn-bottom'),
        document.getElementById('form-message-bottom')
      );
    });

    fetch('/get-counter')
      .then(r => r.json())
      .then(d => {
        const el = document.getElementById('sub-count');
        if (el) el.textContent = d.count.toLocaleString();
      })
      .catch(() => {});
  </script>
</Layout>
