---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
	title="GALAXY BUILT // Autonomous Intelligence // Sovereign Infrastructure"
	description="Institutional-grade SaaS platforms, autonomous AI workflows, and proprietary trading systems. Engineered for evergreen authority and industrial scale."
>
	<!-- Sovereign Gravity Well Hero Overlay -->
	<section class="relative w-full h-[90vh] md:h-screen overflow-hidden flex items-center justify-center">
		<!-- Invisible Interaction Layer -->
		<div class="relative z-50 w-full max-w-7xl h-full flex items-center justify-center">
			
			<!-- Node: Galaxy Leads -->
			<a href="/leads" class="absolute top-[45%] right-[20%] md:right-[25%] w-32 h-32 md:w-48 md:h-48 group flex flex-col items-center justify-center transition-transform hover:scale-110">
				<div class="w-full h-full border border-cyan-500/0 group-hover:border-cyan-500/40 rounded-full transition-all duration-700 bg-cyan-500/0 group-hover:bg-cyan-500/5 backdrop-blur-[2px]">
					<div class="absolute inset-x-0 -top-8 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
						<span class="font-mono text-[9px] md:text-[10px] text-cyan-400 uppercase tracking-tighter">Access: Galaxy_Leads</span>
					</div>
				</div>
			</a>

			<!-- Node: Genesis Portfolio -->
			<a href="/automation" class="absolute top-[35%] left-[20%] w-32 h-32 md:w-40 md:h-40 group flex flex-col items-center justify-center transition-transform hover:scale-110">
				<div class="w-full h-full border border-amber-500/0 group-hover:border-amber-500/40 rounded-full transition-all duration-700 bg-amber-500/0 group-hover:bg-amber-500/5 backdrop-blur-[2px]">
					<div class="absolute inset-x-0 -top-8 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
						<span class="font-mono text-[9px] md:text-[10px] text-amber-500 uppercase tracking-tighter">Access: Genesis_Portfolio</span>
					</div>
				</div>
			</a>

			<!-- Node: SaaS Core -->
			<a href="/blog" class="absolute bottom-[25%] right-[35%] w-24 h-24 md:w-32 md:h-32 group flex flex-col items-center justify-center transition-transform hover:scale-110">
				<div class="w-full h-full border border-purple-500/0 group-hover:border-purple-500/40 rounded-full transition-all duration-700 bg-purple-500/0 group-hover:bg-purple-500/5 backdrop-blur-[1px]">
					<div class="absolute inset-x-0 -top-6 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
						<span class="font-mono text-[9px] text-purple-400 uppercase tracking-tighter">Access: Software_Network</span>
					</div>
				</div>
			</a>
		</div>

		<!-- Identity Layer (Centered) -->
		<div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none z-20 px-4 text-center">
			<h1 class="text-6xl md:text-9xl font-black font-display tracking-tighter leading-none text-white drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">
				GALAXY<br/><span class="text-gradient">BUILT.</span>
			</h1>
			<p class="mt-6 max-w-xl text-institutional-secondary text-xs md:text-sm font-mono uppercase tracking-[0.3em] opacity-60">
				Institutional Grade // Autonomous Execution // Sovereign Infrastructure
			</p>
		</div>

		<!-- Global Status Bar -->
		<div class="absolute bottom-10 left-10 z-30 font-mono text-[9px] md:text-[10px] text-cyan-500/40 uppercase tracking-[0.2em] animate-pulse">
			Node: PH_Station_01 // Status: Sovereign // Latency: 12ms // Agent Zero Linked
		</div>
	</section>
</Layout>
