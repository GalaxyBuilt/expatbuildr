<script>
(function(){
  const container = document.getElementById('stars');
  for(let i=0;i<80;i++){
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random()*2+0.5;
    s.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--op:${Math.random()*0.4+0.1};--d:${Math.random()*4+2}s;--delay:-${Math.random()*4}s;`;
    container.appendChild(s);
  }
})();

const steps = [document.getElementById('step1'),document.getElementById('step2'),document.getElementById('step3'),document.getElementById('step4'),document.getElementById('step5')];

function updateProgress(){
  const scrollY = window.scrollY + window.innerHeight/2;
  let current = 0;
  steps.forEach((s,i)=>{ if(s && scrollY > s.offsetTop) current = i; });
  for(let i=0;i<5;i++){
    const dot = document.getElementById(`pd${i+1}`);
    const label = document.getElementById(`pl${i+1}`);
    dot.classList.remove('active','done');
    label.classList.remove('active');
    if(i < current){ dot.classList.add('done'); }
    else if(i === current){ dot.classList.add('active'); label.classList.add('active'); }
  }
}
window.addEventListener('scroll', updateProgress);

function scrollToStep(n){
  const el = document.getElementById(`step${n}`);
  if(el) el.scrollIntoView({behavior:'smooth',block:'start'});
}

const observer = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('visible'); });
},{threshold:0.1});
document.querySelectorAll('.fade-up').forEach(el=>observer.observe(el));

async function handleSubmit(e){
  e.preventDefault();
  const email = document.getElementById('email-input').value;
  const btn = document.getElementById('submit-btn');
  const status = document.getElementById('form-status');
  btn.textContent = 'Joining...';
  btn.disabled = true;
  try {
    const res = await fetch('/api/subscribe',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({email, source:'web', magnet:'geo-arbitrage-starter-kit', tags:['freedom_seeker']})
    });
    const data = await res.json();
    if(data.success){
      document.getElementById('email-form').innerHTML = '<p style="color:#00e9a3;font-weight:800;font-size:0.95rem;">✓ You\'re in — check your inbox for the playbook.</p>';
      localStorage.setItem('gb_email', email);
      localStorage.setItem('gb_persona', 'freedom-seeker');
      localStorage.setItem('gb_subscribed', '1');
      unlockDownloads();
      if(typeof fbq !== 'undefined'){ fbq('track','Lead'); fbq('trackCustom','PersonaSubscribed',{persona:'freedom-seeker'}); }
      if(typeof gtag !== 'undefined'){ gtag('event','persona_subscribed',{persona:'freedom-seeker'}); }
      setTimeout(()=>scrollToStep(3), 1500);
    } else { throw new Error(data.error); }
  } catch {
    btn.textContent = 'Join Free';
    btn.disabled = false;
    status.textContent = 'Something went wrong — try again.';
    status.style.color = '#ff6b35';
    status.style.display = 'block';
  }
}

function unlockDownloads(){
  const d1 = document.getElementById('main-download');
  const d2 = document.getElementById('bonus-download');
  if(d1){ d1.style.opacity='1'; d1.style.pointerEvents='auto'; }
  if(d2){ d2.style.opacity='1'; d2.style.pointerEvents='auto'; }
}

// Unlock downloads if already subscribed in this session
if(localStorage.getItem('gb_subscribed') === '1'){ unlockDownloads(); }

const savedAnswers = JSON.parse(localStorage.getItem('gb_quiz_freedom') || '{}');
const answers = Object.assign({}, savedAnswers);

// Restore any previously selected quiz options
Object.entries(answers).forEach(([qId, val]) => {
  const opts = document.querySelectorAll(`#${qId} .quiz-opt`);
  opts.forEach(o => { if(o.getAttribute('onclick') && o.getAttribute('onclick').includes(`'${val}'`)) o.classList.add('selected'); });
});
if(Object.keys(answers).length >= 3){
  const btn = document.getElementById('result-btn');
  if(btn){ btn.style.opacity='1'; btn.style.pointerEvents='auto'; }
}

function selectOpt(qId, el, val){
  document.querySelectorAll(`#${qId} .quiz-opt`).forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
  answers[qId] = val;
  localStorage.setItem('gb_quiz_freedom', JSON.stringify(answers));
  if(Object.keys(answers).length >= 3){
    const btn = document.getElementById('result-btn');
    btn.style.opacity = '1';
    btn.style.pointerEvents = 'auto';
  }
}

function generateResult(){
  localStorage.setItem('gb_quiz_freedom', JSON.stringify(answers));
  if(typeof fbq !== 'undefined'){ fbq('trackCustom','PersonaQuizCompleted',{persona:'freedom-seeker',answers:JSON.stringify(answers)}); }
  if(typeof gtag !== 'undefined'){ gtag('event','persona_quiz_completed',{persona:'freedom-seeker'}); }
  const results = {
    dreaming:{title:'Start here — the math will convince you',desc:'You need to see the real numbers before anything else. The arbitrage calculator will show you exactly what\'s possible with your current income.',links:[{text:'How Geographic Arbitrage Actually Works',url:'/blog'},{text:'The $6K Salary in the Philippines Story',url:'/blog'},{text:'Download the Arbitrage Calculator',url:'/downloads/arbitrage-calculator?ref=quiz'}]},
    planning:{title:'You\'re closer than you think — here\'s your next step',desc:'You have the intention. The gap is usually logistics and income certainty. These resources close that gap.',links:[{text:'Best Countries for First-Time Geo-Arbitrage',url:'/blog'},{text:'How to Lock In Remote Income Before You Move',url:'/blog'},{text:'The Remote Jobs Starter Pack',url:'/downloads/remote-jobs-pack?ref=quiz'}]},
    ready:{title:'Income is the last piece — let\'s solve that',desc:'You\'re ready to move but need remote income locked in first. Here\'s exactly how others solved this.',links:[{text:'5 Remote Income Streams You Can Start This Week',url:'/blog'},{text:'How to Use AI to Land Remote Work Faster',url:'/blog'},{text:'The Prompt Vault — Remote Job Edition',url:'/downloads/prompt-vault?ref=quiz'}]},
    living:{title:'Already abroad — time to optimize',desc:'You\'re living the life. Now it\'s about squeezing more savings, finding better banking, and building income that compounds.',links:[{text:'Currency Strategy for Long-Term Expats',url:'/blog'},{text:'Banking and Tax Optimization Abroad',url:'/blog'},{text:'Building Income Systems While Traveling',url:'/blog'}]}
  };
  const r = results[answers.q1] || results.dreaming;
  document.getElementById('result-title').textContent = r.title;
  document.getElementById('result-desc').textContent = r.desc;
  document.getElementById('result-links').innerHTML = r.links.map(l=>`<a class="result-link" href="${l.url}">${l.text}</a>`).join('');
  document.getElementById('result-card').classList.add('show');
  setTimeout(()=>scrollToStep(4), 800);
}


function copyCode(){
  navigator.clipboard.writeText('FREEDOM20').then(()=>{
    document.getElementById('copy-confirm').style.display = 'block';
    document.getElementById('discount-chip').style.borderColor = '#00e9a3';
    if(typeof fbq !== 'undefined'){ fbq('trackCustom','PersonaDiscountCopied',{persona:'freedom-seeker'}); }
    if(typeof gtag !== 'undefined'){ gtag('event','persona_discount_copied',{persona:'freedom-seeker'}); }
    setTimeout(()=>{
      document.getElementById('copy-confirm').style.display = 'none';
      document.getElementById('discount-chip').style.borderColor = '';
    }, 2500);
  });
}

function fireDownloadPixel(){
  if(typeof fbq !== 'undefined'){ fbq('trackCustom','PersonaDownload',{persona:'freedom-seeker',magnet:'geo-arbitrage-starter-kit'}); }
  if(typeof gtag !== 'undefined'){ gtag('event','persona_download',{persona:'freedom-seeker',magnet:'geo-arbitrage-starter-kit'}); }
}
</script>
