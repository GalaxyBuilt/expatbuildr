---
import Layout from '../../layouts/Layout.astro';
import Pixels from '../../components/Pixels.astro';

const title = "You're In — One Quick Step | Galaxy Arbitrage";
const description = "Your free download is one step away.";

const TWITTER_HANDLE = import.meta.env.TWITTER_HANDLE || 'expatbuildr';
const YOUTUBE_HANDLE = import.meta.env.YOUTUBE_HANDLE || 'expatbuildr';
---

<Layout title={title} description={description} minimal={true} noindex={true}>
  <Pixels slot="head" page="thank-you-friction" />

  <div class="friction-root">
    <!-- Grid & Orbs -->
    <div class="grid-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <main class="content-wrap">
      <div class="friction-card glass-card reveal-on-scroll">
        <!-- Brand -->
        <div class="brand">Expat<span>Buildr</span></div>

        <!-- Success Check -->
        <div class="check-wrap">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>

        <h1 class="card-title">YOUR<br/>DOWNLOAD IS<br/><span>ALMOST READY.</span></h1>

        <p class="subtitle">
          One quick step before you grab your free resource — follow Galaxy on the two channels where all the best content drops first.
        </p>

        <!-- Progress Tracker -->
        <div class="progress-track">
          <div class="progress-dot active" id="dot1"></div>
          <div class="progress-line"></div>
          <div class="progress-dot" id="dot2"></div>
          <div class="progress-line"></div>
          <div class="progress-dot" id="dot3"></div>
          <span class="progress-label" id="progress-label">0 of 2 done</span>
        </div>

        <div class="step-divider"><span>Step 1 of 2 — Follow on X</span></div>

        <!-- Social Buttons Stack -->
        <div class="social-stack">
          <!-- Twitter -->
          <a class="social-btn twitter" id="twitter-btn" href={`https://x.com/${TWITTER_HANDLE}`} target="_blank">
            <div class="social-left">
              <div class="social-icon">𝕏</div>
              <div class="social-text">
                <strong>Follow on X (Twitter)</strong>
                <span>@{TWITTER_HANDLE} · Daily arbitrage threads</span>
              </div>
            </div>
            <div class="social-action">
              <button class="action-btn">Follow</button>
              <div class="done-badge">✓ Done</div>
            </div>
          </a>

          <!-- YouTube -->
          <a class="social-btn youtube" id="youtube-btn" href={`https://youtube.com/@${YOUTUBE_HANDLE}`} target="_blank">
            <div class="social-left">
              <div class="social-icon">▶</div>
              <div class="social-text">
                <strong>Subscribe on YouTube</strong>
                <span>@{YOUTUBE_HANDLE} · Arbitrage stories & interviews</span>
              </div>
            </div>
            <div class="social-action">
              <button class="action-btn">Subscribe</button>
              <div class="done-badge">✓ Done</div>
            </div>
          </a>
        </div>

        <!-- Unlock Button -->
        <a class="download-btn" id="unlock-btn" href="#">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Unlock My Free Download
        </a>
        <p class="lock-note" id="lock-note">🔒 Follow both channels to unlock your download</p>

        <!-- Skip Link -->
        <div class="skip-link">
          Already following? <a id="skip-trigger">Skip this step →</a>
        </div>
      </div>

      <footer class="page-footer">
        Galaxy Arbitrage by ExpatBuildr · Philippines 🇵🇭 · <a href="/newsletter" class="text-accent-gold">Join the Newsletter</a>
      </footer>
    </main>
  </div>
</Layout>

<style>
  :root {
    --bg-primary: #060810;
    --accent-gold: #f5c842;
    --accent-orange: #ff6b35;
    --accent-cyan: #00e5ff;
    --accent-emerald: #00e9a3;
    --text-primary: #f0f4ff;
    --text-secondary: #8892b0;
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.07);
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'Syne', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  .friction-root {
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    position: relative;
    overflow-x: hidden;
  }

  .grid-bg {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .orb { position: absolute; border-radius: 50%; filter: blur(120px); pointer-events: none; z-index: 0; opacity: 0.6; }
  .orb-1 { width: 500px; height: 500px; background: rgba(245,200,66,0.07); top: -100px; right: -100px; }
  .orb-2 { width: 400px; height: 400px; background: rgba(0,229,255,0.05); bottom: -100px; left: -100px; }

  .content-wrap { position: relative; z-index: 1; width: 100%; max-width: 560px; }

  .friction-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 32px;
    padding: 52px 44px;
    text-align: center;
    backdrop-filter: blur(16px);
  }

  .brand { font-family: var(--font-display); font-size: 1rem; letter-spacing: 0.15em; color: var(--text-primary); margin-bottom: 32px; }
  .brand span { background: linear-gradient(135deg, var(--accent-gold), var(--accent-orange)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .check-wrap {
    width: 72px; height: 72px; border-radius: 50%;
    background: rgba(0,233,163,0.08); border: 1px solid rgba(0,233,163,0.2);
    display: flex; align-items: center; justify-content: center; margin: 0 auto 28px;
    color: #00e9a3;
  }

  .card-title { font-family: var(--font-display); font-size: clamp(2.4rem, 6vw, 3.6rem); line-height: 0.95; letter-spacing: 0.03em; margin-bottom: 16px; }
  .card-title span { background: linear-gradient(135deg, var(--accent-gold), var(--accent-orange)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .subtitle { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 40px; max-width: 400px; margin-left: auto; margin-right: auto; }

  /* Progress Tracker */
  .progress-track { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 32px; }
  .progress-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--glass-border); transition: all 0.3s ease; }
  .progress-dot.active { background: var(--accent-gold); box-shadow: 0 0 10px var(--accent-gold); }
  .progress-dot.done-dot { background: #00e9a3; }
  .progress-line { width: 32px; height: 1px; background: var(--glass-border); }
  .progress-label { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.12em; color: var(--text-secondary); text-transform: uppercase; margin-left: 8px; }

  .step-divider { display: flex; align-items: center; gap: 12px; margin-bottom: 32px; }
  .step-divider::before, .step-divider::after { content: ''; flex: 1; height: 1px; background: var(--glass-border); }
  .step-divider span { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-secondary); white-space: nowrap; }

  /* Social Buttons */
  .social-stack { display: flex; flex-direction: column; gap: 14px; margin-bottom: 36px; }
  .social-btn {
    display: flex; align-items: center; justify-content: space-between; padding: 18px 24px;
    border-radius: 16px; border: 1px solid var(--glass-border); background: var(--glass-bg);
    cursor: pointer; text-decoration: none; transition: all 0.3s ease; position: relative; overflow: hidden;
  }
  .social-btn:hover { transform: translateX(4px); }
  .social-btn.twitter:hover { border-color: #1d9bf0; }
  .social-btn.youtube:hover { border-color: #ff0000; }

  .social-btn.done { border-color: rgba(0,233,163,0.3); background: rgba(0,233,163,0.04); pointer-events: none; }

  .social-left { display: flex; align-items: center; gap: 14px; z-index: 1; }
  .social-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
  .twitter .social-icon { background: rgba(29,155,240,0.12); color: #1d9bf0; }
  .youtube .social-icon { background: rgba(255,0,0,0.12); color: #ff0000; }

  .social-text { text-align: left; }
  .social-text strong { display: block; font-size: 0.9rem; font-weight: 800; color: var(--text-primary); margin-bottom: 2px; }
  .social-text span { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-secondary); letter-spacing: 0.06em; }

  .action-btn { padding: 8px 18px; border-radius: 100px; font-family: var(--font-body); font-weight: 800; font-size: 0.75rem; text-transform: uppercase; border: none; cursor: pointer; color: white; }
  .twitter .action-btn { background: #1d9bf0; }
  .youtube .action-btn { background: #ff0000; }

  .done-badge { padding: 8px 18px; border-radius: 100px; font-family: var(--font-mono); font-size: 0.7rem; color: #00e9a3; border: 1px solid rgba(0,233,163,0.3); display: none; }
  .social-btn.done .done-badge { display: block; }
  .social-btn.done .action-btn { display: none; }

  /* Download Button */
  .download-btn {
    display: flex; align-items: center; justify-content: center; gap: 12px; width: 100%;
    padding: 18px 32px; border-radius: 100px; background: linear-gradient(135deg, var(--accent-gold), var(--accent-orange));
    color: #000; font-family: var(--font-body); font-weight: 800; font-size: 1rem; text-transform: uppercase;
    text-decoration: none; transition: all 0.3s ease; opacity: 0.35; pointer-events: none;
    box-shadow: 0 0 40px rgba(245,200,66,0.2);
  }
  .download-btn.unlocked { opacity: 1; pointer-events: all; animation: glow-pulse 2s infinite; }
  .download-btn.unlocked:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 0 60px rgba(245,200,66,0.4); }

  @keyframes glow-pulse { 0%,100% { box-shadow: 0 0 40px rgba(245,200,66,0.2); } 50% { box-shadow: 0 0 60px rgba(245,200,66,0.4); } }

  .lock-note { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-secondary); margin-top: 12px; }
  .lock-note.unlocked-note { color: #00e9a3; }

  .skip-link { margin-top: 28px; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-secondary); }
  .skip-link a { text-decoration: underline; cursor: pointer; }
  .skip-link a:hover { color: var(--accent-cyan); }

  .page-footer { margin-top: 32px; font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-secondary); text-align: center; }

  @media (max-width: 500px) { .friction-card { padding: 36px 24px; } }

  .reveal-on-scroll { opacity: 0; transform: translateY(20px); transition: all 0.6s ease-out; }
  .reveal-on-scroll.active { opacity: 1; transform: translateY(0); }
</style>

<script is:inline>
  const params = new URLSearchParams(window.location.search);
  const magnet = params.get('magnet') || 'remote-jobs-pack';
  const downloadUrl = `/downloads/${magnet}?ref=newsletter`;

  let twitterDone = false;
  let youtubeDone = false;

  const twitterBtn = document.getElementById('twitter-btn');
  const youtubeBtn = document.getElementById('youtube-btn');
  const unlockBtn = document.getElementById('unlock-btn');
  const skipTrigger = document.getElementById('skip-trigger');

  function markDone(platform) {
    if (platform === 'twitter') {
      twitterDone = true;
      twitterBtn.classList.add('done');
      document.getElementById('dot1').classList.remove('active');
      document.getElementById('dot1').classList.add('done-dot');
      document.getElementById('dot2').classList.add('active');
      document.querySelector('.step-divider span').textContent = 'Step 2 of 2 — Subscribe on YouTube';
      if (window.firePixelEvent) window.firePixelEvent('TwitterFollowClick');
    }
    if (platform === 'youtube') {
      youtubeDone = true;
      youtubeBtn.classList.add('done');
      document.getElementById('dot2').classList.remove('active');
      document.getElementById('dot2').classList.add('done-dot');
      document.getElementById('dot3').classList.add('active');
      if (window.firePixelEvent) window.firePixelEvent('YouTubeSubscribeClick');
    }
    checkUnlock();
  }

  function openAndMark(e, url, platform) {
    e.preventDefault();
    // window.open escapes Twitter/YouTube WebViews on iOS/Android better than target="_blank"
    window.open(url, '_blank', 'noopener,noreferrer');
    // Mark done when they switch back to this tab (visibilitychange), with a 3s fallback
    // so the download unlocks regardless of whether the WebView let them return
    var marked = false;
    function doMark() {
      if (!marked) { marked = true; markDone(platform); }
    }
    document.addEventListener('visibilitychange', function onVisible() {
      if (document.visibilityState === 'visible') {
        document.removeEventListener('visibilitychange', onVisible);
        doMark();
      }
    });
    setTimeout(doMark, 3000);
  }

  twitterBtn.addEventListener('click', function(e) { openAndMark(e, twitterBtn.href, 'twitter'); });
  youtubeBtn.addEventListener('click', function(e) { openAndMark(e, youtubeBtn.href, 'youtube'); });

  function checkUnlock() {
    const count = (twitterDone ? 1 : 0) + (youtubeDone ? 1 : 0);
    document.getElementById('progress-label').textContent = `${count} of 2 done`;

    if (twitterDone && youtubeDone) {
      document.getElementById('dot3').classList.remove('active');
      document.getElementById('dot3').classList.add('done-dot');
      document.getElementById('progress-label').textContent = '✓ All done!';

      unlockBtn.classList.add('unlocked');
      unlockBtn.href = downloadUrl;

      const note = document.getElementById('lock-note');
      note.textContent = '✓ Download unlocked — you\'re all set!';
      note.classList.add('unlocked-note');

      if (window.firePixelEvent) window.firePixelEvent('DownloadUnlocked', { magnet });
    }
  }

  unlockBtn.addEventListener('click', (e) => {
    if (!unlockBtn.classList.contains('unlocked')) {
      e.preventDefault();
      return;
    }
    if (window.firePixelEvent) window.firePixelEvent('DownloadStarted', { magnet });
  });

  skipTrigger.addEventListener('click', () => {
    twitterDone = true;
    youtubeDone = true;
    twitterBtn.classList.add('done');
    youtubeBtn.classList.add('done');
    checkUnlock();
  });

  // Reveal logic
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
</script>
