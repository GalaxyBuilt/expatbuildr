---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';

// AI Business Master Prompt Vault - Landing Page
---

<Layout 
  title="AI Business Master Prompt Vault" 
  description="45 Claude prompts to build autonomous SaaS systems, validate ideas in hours, and 10x your output."
  ogImage="/images/codesnap_ai.png"
  minimal={true}
>
  <style is:inline>
    /* Funnel Specific Variables & Reset */
    :root {
      --funnel-bg: #080b10;
      --funnel-surface: #0e1319;
      --funnel-accent: #00e5a0;
      --funnel-accent-dim: rgba(0, 229, 160, 0.12);
      --funnel-text: #e8edf2;
      --funnel-text-muted: #6b7f91;
    }

    .vault-wrapper {
      background: var(--funnel-bg);
      color: var(--funnel-text);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      position: relative;
    }

    /* GRID TEXTURE */
    .vault-wrapper::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,229,160,0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,229,160,0.015) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      z-index: 0;
    }

    .container {
      max-width: 760px;
      margin: 0 auto;
      padding: 0 24px;
      position: relative;
      z-index: 1;
    }

    .container-wide {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 24px;
      position: relative;
      z-index: 1;
    }

    /* ── TOPBAR ── */
    .topbar {
      border-bottom: 1px solid #1e2730;
      padding: 14px 0;
      position: sticky;
      top: 0;
      background: rgba(8, 11, 16, 0.92);
      backdrop-filter: blur(12px);
      z-index: 100;
    }

    .topbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .brand {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 17px;
      color: var(--funnel-accent);
      text-decoration: none;
      letter-spacing: -0.3px;
    }

    .brand span { color: var(--funnel-text-muted); font-weight: 400; }

    .topbar-cta {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--funnel-text-muted);
    }

    .topbar-cta strong { color: var(--funnel-accent); }

    /* ── ANNOUNCEMENT STRIP ── */
    .strip {
      background: var(--funnel-accent-dim);
      border-bottom: 1px solid rgba(0,229,160,0.15);
      padding: 10px 0;
      text-align: center;
    }

    .strip p {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--funnel-accent);
      letter-spacing: 0.5px;
    }

    /* ── HERO ── */
    .hero {
      padding: 80px 0 64px;
      text-align: center;
    }

    .hero-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--funnel-accent-dim);
      border: 1px solid rgba(0,229,160,0.2);
      border-radius: 100px;
      padding: 6px 16px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--funnel-accent);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 32px;
    }

    .hero-label::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--funnel-accent);
      box-shadow: 0 0 8px var(--funnel-accent);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .hero h1 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(32px, 5.5vw, 52px);
      line-height: 1.1;
      letter-spacing: -1.5px;
      color: var(--funnel-text);
      margin-bottom: 12px;
    }

    .hero h1 .num { color: var(--funnel-accent); }

    .hero h1 .dash {
      display: block;
      font-size: clamp(22px, 3.5vw, 34px);
      color: var(--funnel-text-muted);
      font-weight: 600;
      margin-top: 8px;
      letter-spacing: -0.5px;
    }

    .hero-sub {
      font-size: 18px;
      color: var(--funnel-text-muted);
      max-width: 580px;
      margin: 20px auto 0;
      line-height: 1.65;
    }

    .hero-sub strong { color: var(--funnel-text); }

    .proof-bar {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      margin-top: 40px;
      flex-wrap: wrap;
    }

    .proof-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--funnel-text-muted);
    }

    .proof-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: #3d5060;
    }

    .proof-item.gold { color: #f5b944; }

    .cta-block {
      margin-top: 48px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }

    .optin-form {
      display: flex;
      gap: 0;
      width: 100%;
      max-width: 480px;
      border: 1px solid #2a3545;
      border-radius: 10px;
      overflow: hidden;
      background: var(--funnel-surface);
      transition: border-color 0.2s;
    }

    .optin-form:focus-within {
      border-color: var(--funnel-accent);
      box-shadow: 0 0 0 3px var(--funnel-accent-dim);
    }

    .optin-form input[type="email"] {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      padding: 14px 18px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      color: var(--funnel-text);
      min-width: 0;
    }

    .optin-form button {
      background: var(--funnel-accent);
      color: #040a07;
      border: none;
      padding: 14px 24px;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      white-space: nowrap;
      transition: opacity 0.15s;
    }

    .bullets {
      list-style: none;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    @media (max-width: 580px) {
      .bullets { grid-template-columns: 1fr; }
    }

    .bullets li {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      background: var(--funnel-surface);
      border: 1px solid #1e2730;
      border-radius: 10px;
      padding: 16px;
    }

    .bullet-icon {
      width: 22px;
      height: 22px;
      border-radius: 5px;
      background: var(--funnel-accent-dim);
      border: 1px solid rgba(0,229,160,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .bullet-icon svg { width: 12px; height: 12px; stroke: var(--funnel-accent); fill: none; stroke-width: 2.5; }

    .bullet-text strong { display: block; font-size: 14px; color: var(--funnel-text); }
    .bullet-text span { font-size: 13px; color: var(--funnel-text-muted); }

    .categories-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 36px;
    }

    @media (max-width: 580px) {
      .categories-grid { grid-template-columns: 1fr; }
    }

    .cat-card {
      background: var(--funnel-surface);
      border: 1px solid #1e2730;
      border-radius: 10px;
      padding: 16px 18px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .divider { border: none; border-top: 1px solid #1e2730; margin: 0; }

    .sample-prompt {
      background: #141a22;
      border: 1px solid #2a3545;
      border-left: 3px solid var(--funnel-accent);
      border-radius: 10px;
      padding: 24px;
      margin: 36px 0;
    }

    footer.funnel-footer {
      border-top: 1px solid #1e2730;
      padding: 28px 0;
      text-align: center;
    }
  </style>

  <div class="vault-wrapper">
    <!-- TOPBAR -->
    <nav class="topbar">
      <div class="container-wide">
        <div class="topbar-inner">
          <a href="/" class="brand">Galaxy<span>Built</span></a>
          <span class="topbar-cta">Free Download · <strong>45 AI Prompts</strong></span>
        </div>
      </div>
    </nav>

    <!-- ANNOUNCEMENT STRIP -->
    <div class="strip">
      <div class="container">
        <p>⚡ FREE RESOURCE — Used by 1,200+ founders & AI builders. No fluff.</p>
      </div>
    </div>

    <!-- HERO -->
    <section class="hero">
      <div class="container">
        <div class="hero-label">AI Business Master Prompt Vault</div>
        <h1>
          <span class="num">45</span> Claude Prompts to Become
          <span class="dash">an AI Business Master</span>
        </h1>
        <p class="hero-sub">
          Build <strong>autonomous SaaS systems</strong>, validate ideas in hours, and 10x your output. 
          Copy-paste ready prompts organized into 8 categories.
        </p>

        <div class="cta-block">
          <form class="optin-form" id="hero-form">
            <input type="hidden" name="source" value="prompt-vault-hero-astro">
            <input type="email" name="email" placeholder="Enter your best email" required autocomplete="email">
            <button type="submit">Get Free Access →</button>
          </form>
          <p style="font-size: 11px; color: #3d5060;">No spam. Unsubscribe any time. Delivered instantly.</p>
        </div>
      </div>
    </section>

    <hr class="divider">

    <!-- PREVIEW -->
    <section style="padding: 48px 0 64px;">
      <div class="container">
        <h2 style="font-family: Syne, sans-serif; font-size: 34px; margin-bottom: 24px;">Everything a Serious AI Founder Needs</h2>
        <ul class="bullets">
          <li>
            <div class="bullet-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <div class="bullet-text"><strong>6 Idea Validation Prompts</strong><span>Kill bad ideas fast. Find the $1M pain hiding in your market.</span></div>
          </li>
          <li>
            <div class="bullet-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <div class="bullet-text"><strong>6 AI Agent Architecture Prompts</strong><span>Design multi-agent systems and autonomous workflows.</span></div>
          </li>
          <li>
            <div class="bullet-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <div class="bullet-text"><strong>6 MVP Development Prompts</strong><span>Ship faster. Define the right features and onboarding.</span></div>
          </li>
          <li>
            <div class="bullet-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <div class="bullet-text"><strong>6 Market Research Prompts</strong><span>Build ICPs and teardown competitors with ease.</span></div>
          </li>
        </ul>
      </div>
    </section>

    <hr class="divider">

    <!-- BOTTOM CTA -->
    <section style="padding: 80px 0; text-align: center;">
      <div class="container">
        <h2 style="font-family: Syne, sans-serif; font-size: 40px; margin-bottom: 16px;">Get the Vault. <span style="color: var(--funnel-accent);">Free.</span></h2>
        <div style="display: flex; justify-content: center; margin-top: 32px;">
          <form class="optin-form" id="bottom-form">
            <input type="hidden" name="source" value="prompt-vault-bottom-astro">
            <input type="email" name="email" placeholder="Your email address" required autocomplete="email">
            <button type="submit">Send Me the Vault →</button>
          </form>
        </div>
      </div>
    </section>

    <footer class="funnel-footer">
      <div class="container">
        <p style="font-size: 12px; color: #3d5060;">© 2025 <a href="/" style="color: var(--funnel-accent); text-decoration: none;">ExpatBuildr</a> · Built for founders who build real leverage</p>
      </div>
    </footer>
  </div>

  <script is:inline src="/beehiiv-v2.js"></script>
  <script is:inline>
    const handleFormSubmit = async (e) => {
      e.preventDefault();
      const form = e.target;
      const button = form.querySelector('button');
      const emailInput = form.querySelector('input[type="email"]');
      const email = emailInput.value.trim();
      
      if (!isValidEmail(email)) {
        emailInput.style.borderColor = 'red';
        return;
      }

      button.innerText = 'Syncing...';
      button.disabled = true;

      try {
        const success = await subscribeToBeehiiv({
          email,
          tags: ["founders", "claude_vault_lead"],
          utm_medium: "ai_business_funnel",
          utm_campaign: "claude_prompts_freebie"
        });
        if (success) {
          window.location.href = '/ai-business/thank-you';
        } else {
          button.innerText = 'Try Again';
          button.disabled = false;
          emailInput.style.borderColor = 'red';
          alert('Subscription failed. Please check your email or try again.');
        }
      } catch (err) {
        console.error("Signup error:", err);
        button.innerText = 'Try Again';
        button.disabled = false;
        alert('System error. Please try again.');
      }
    };

    document.getElementById('hero-form')?.addEventListener('submit', handleFormSubmit);
    document.getElementById('bottom-form')?.addEventListener('submit', handleFormSubmit);
  </script>
</Layout>
