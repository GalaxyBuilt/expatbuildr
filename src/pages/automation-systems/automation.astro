  <script is:inline src="/beehiiv-v2.js"></script>
  <script is:inline>
  // Form AJAX submit
  const form = document.getElementById('build-form');
  const success = document.getElementById('form-success');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('[type=submit]');
      const originalText = btn.innerHTML;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      const formData = new FormData(form);
      const email = formData.get('email');

      // Use the shared utility
      await subscribeToBeehiiv({
        email,
        tags: ["automation_buyer", "done_for_you", "high_ticket"],
        utm_medium: "automation_page",
        utm_campaign: "automation_service"
      });
      
      // Always show success to advance user
      form.style.display = 'none';
      success.style.display = 'block';
    });
  }

  // Scroll-triggered fade-in for below-fold sections
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.case-card, .step, .plan, .problem-item').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    observer.observe(el);
  });

  // Theme Toggle Logic
  const themeBtn = document.getElementById('systemsThemeToggle');
  if (themeBtn) {
    themeBtn.addEventListener('click', () => {
      const element = document.documentElement;
      element.classList.toggle("dark");
      const isDark = element.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }
</script>
