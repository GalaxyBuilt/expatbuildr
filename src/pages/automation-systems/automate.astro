---
export const prerender = true;
---
<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ExpatBuildr — Free Automation Audit</title>
<meta name="description" content="Map exactly where AI automation can replace manual work in your business. Get your free personalized automation audit and save 10+ hours per week." />

<!-- Open Graph / SEO -->
<meta property="og:title" content="ExpatBuildr — Free Automation Audit" />
<meta property="og:description" content="Map exactly where AI automation can replace manual work in your business. Get your free personalized automation audit." />
<meta property="og:image" content="https://expatbuildr.com/images/og-systems.png" />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://expatbuildr.com/automate" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="ExpatBuildr — Free Automation Audit" />
<meta name="twitter:description" content="Map exactly where AI automation can replace manual work in your business. Get your free personalized automation audit." />
<meta name="twitter:image" content="https://expatbuildr.com/images/og-systems.png" />
<link rel="canonical" href="https://expatbuildr.com/automate" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Mono:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:       #04040a;
    --bg-card:  #09090f;
    --border:   rgba(255,255,255,0.07);
    --border-hi:rgba(255,255,255,0.13);
    --text:     #eeeaff;
    --muted:    #7c7a9a;
    --dim:      #3d3b55;

--purple:   #9945FF;
--teal:     #14F195;
--pink:     #FF6FD8;
--cyan:     #00C2FF;

--grad:      linear-gradient(135deg, #9945FF 0%, #FF6FD8 45%, #14F195 100%);
--grad-btn:  linear-gradient(135deg, #9945FF 0%, #c84bff 35%, #FF6FD8 65%, #14F195 100%);
--glow-p:    rgba(153,69,255,0.18);
--glow-t:    rgba(20,241,149,0.12);

--serif: 'DM Serif Display', Georgia, serif;
--mono:  'IBM Plex Mono', monospace;
--sans:  'DM Sans', system-ui, sans-serif;

}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }

body {
background: var(--bg);
color: var(--text);
font-family: var(--sans);
min-height: 100vh;
display: flex;
flex-direction: column;
-webkit-font-smoothing: antialiased;
overflow-x: hidden;
}

/* ── AMBIENT LIGHTS ── */
.ambient {
position: fixed;
inset: 0;
pointer-events: none;
z-index: 0;
overflow: hidden;
}
.ambient-1 {
position: absolute;
top: -25%;
right: -15%;
width: 70vw; height: 70vw;
background: radial-gradient(ellipse, rgba(153,69,255,0.12) 0%, transparent 65%);
}
.ambient-2 {
position: absolute;
bottom: -20%;
left: -10%;
width: 55vw; height: 55vw;
background: radial-gradient(ellipse, rgba(20,241,149,0.07) 0%, transparent 65%);
}
.ambient-3 {
position: absolute;
top: 40%;
left: 30%;
width: 40vw; height: 40vw;
background: radial-gradient(ellipse, rgba(255,111,216,0.05) 0%, transparent 65%);
}

/* ── GRID ── */
body::before {
content:'';
position: fixed;
inset: 0;
background-image:
repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(153,69,255,0.03) 59px, rgba(153,69,255,0.03) 60px),
repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(20,241,149,0.02) 59px, rgba(20,241,149,0.02) 60px);
pointer-events: none;
z-index: 0;
}

/* ── TOPBAR ── */
.topbar {
position: relative;
z-index: 10;
background: linear-gradient(90deg, rgba(153,69,255,0.15), rgba(255,111,216,0.1), rgba(20,241,149,0.12));
border-bottom: 1px solid rgba(153,69,255,0.2);
text-align: center;
padding: 9px 20px;
font-family: var(--mono);
font-size: 10px;
letter-spacing: 2px;
color: var(--muted);
text-transform: uppercase;
}
.topbar span {
background: var(--grad);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
font-weight: 600;
}

/* ── NAV ── */
nav {
position: relative;
z-index: 10;
display: flex;
align-items: center;
justify-content: space-between;
padding: 20px 40px;
border-bottom: 1px solid var(--border);
}
  .nav-logo-container {
    display: flex; align-items: center; gap: 12px; text-decoration: none;
  }
  .nav-img-logo {
    width: 40px; height: 40px; border-radius: 12px; object-fit: cover;
    box-shadow: 0 0 0 2px rgba(255,255,255,0.06);
    transition: box-shadow 0.2s;
  }
  .nav-logo-container:hover .nav-img-logo {
    box-shadow: 0 0 0 2px rgba(153,69,255,0.4);
  }
  .nav-text-logo {
    font-family: var(--sans); font-weight: 900; font-size: 24px;
    color: var(--text); letter-spacing: -0.02em;
  }
  .nav-text-logo span {
    font-weight: 300; color: var(--purple);
    background: var(--grad);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
.nav-right {
font-family: var(--mono);
font-size: 9px;
color: var(--dim);
letter-spacing: 2px;
text-transform: uppercase;
}

/* ── MAIN ── */
main {
position: relative;
z-index: 1;
flex: 1;
display: flex;
align-items: center;
justify-content: center;
padding: 60px 24px 80px;
}

.squeeze {
width: 100%;
max-width: 560px;
}

/* ── EYEBROW ── */
.eyebrow {
display: inline-flex;
align-items: center;
gap: 8px;
margin-bottom: 28px;
font-family: var(--mono);
font-size: 9px;
letter-spacing: 2.5px;
text-transform: uppercase;
color: var(--muted);
}
.eyebrow-pip {
width: 6px; height: 6px;
border-radius: 50%;
background: var(--grad);
flex-shrink: 0;
animation: pip 2.5s ease infinite;
}
.eyebrow-line {
width: 28px; height: 1px;
background: var(--grad);
opacity: 0.5;
}
@keyframes pip {
0%,100% { opacity:1; box-shadow: 0 0 0 0 rgba(153,69,255,0); }
50%      { opacity:0.7; box-shadow: 0 0 0 5px rgba(153,69,255,0); }
}

/* ── HEADLINE ── */
h1 {
font-family: var(--serif);
font-size: clamp(36px, 6vw, 58px);
line-height: 1.05;
letter-spacing: -0.02em;
color: var(--text);
margin-bottom: 20px;
}
h1 em {
font-style: italic;
background: var(--grad);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
}

/* ── SUB ── */
.sub {
font-size: 16px;
color: var(--muted);
line-height: 1.75;
font-weight: 300;
margin-bottom: 36px;
max-width: 46ch;
}
.sub strong { color: var(--text); font-weight: 500; }

/* ── PROOF PILLS ── */
.proof-row {
display: flex;
flex-wrap: wrap;
gap: 8px;
margin-bottom: 40px;
}
.proof-pill {
display: flex;
align-items: center;
gap: 6px;
padding: 5px 12px;
background: rgba(255,255,255,0.03);
border: 1px solid var(--border-hi);
border-radius: 100px;
font-family: var(--mono);
font-size: 10px;
color: var(--muted);
letter-spacing: 0.5px;
}
.proof-pill .check {
width: 14px; height: 14px;
border-radius: 50%;
background: var(--grad);
display: flex; align-items: center; justify-content: center;
font-size: 8px;
color: #000;
font-weight: 700;
flex-shrink: 0;
}

/* ── CARD ── */
.card {
background: var(--bg-card);
border: 1px solid var(--border-hi);
border-radius: 16px;
padding: 36px 32px 28px;
position: relative;
overflow: hidden;
}
.card::before {
content: '';
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
background: var(--grad);
}
/* inner glow */
.card::after {
content: '';
position: absolute;
top: -40px; right: -40px;
width: 200px; height: 200px;
background: radial-gradient(ellipse, rgba(153,69,255,0.08) 0%, transparent 70%);
pointer-events: none;
}

.card-label {
font-family: var(--mono);
font-size: 9px;
color: var(--purple);
letter-spacing: 2.5px;
text-transform: uppercase;
margin-bottom: 14px;
opacity: 0.8;
}

.card h2 {
font-family: var(--serif);
font-size: 22px;
color: var(--text);
margin-bottom: 6px;
line-height: 1.2;
}

.card-sub {
font-size: 13px;
color: var(--muted);
margin-bottom: 24px;
line-height: 1.6;
}

/* ── WHAT YOU GET ── */
.gets {
background: rgba(153,69,255,0.04);
border: 1px solid rgba(153,69,255,0.12);
border-radius: 10px;
padding: 16px 18px;
margin-bottom: 24px;
}
.gets-label {
font-family: var(--mono);
font-size: 8px;
color: var(--dim);
letter-spacing: 2px;
text-transform: uppercase;
margin-bottom: 12px;
}
.get-item {
display: flex;
align-items: flex-start;
gap: 10px;
margin-bottom: 9px;
font-size: 13px;
color: var(--text);
line-height: 1.4;
}
.get-item:last-child { margin-bottom: 0; }
.get-icon {
font-size: 13px;
flex-shrink: 0;
margin-top: 1px;
}
.get-item span { color: var(--muted); }
.get-item strong { color: var(--text); }

/* ── FORM ── */
.form-field {
margin-bottom: 12px;
}
.form-field label {
display: block;
font-family: var(--mono);
font-size: 9px;
letter-spacing: 1.5px;
text-transform: uppercase;
color: var(--dim);
margin-bottom: 6px;
}
.form-field input {
width: 100%;
padding: 13px 16px;
background: rgba(255,255,255,0.03);
border: 1px solid var(--border-hi);
border-radius: 8px;
color: var(--text);
font-family: var(--sans);
font-size: 15px;
outline: none;
transition: border-color 0.2s, box-shadow 0.2s;
}
.form-field input::placeholder { color: var(--dim); }
.form-field input:focus {
border-color: var(--purple);
box-shadow: 0 0 0 3px rgba(153,69,255,0.12);
}

/* ── CTA BUTTON ── */
.cta {
width: 100%;
padding: 15px 24px;
background: var(--grad-btn);
background-size: 200% 200%;
animation: gradshift 4s ease infinite;
color: #000;
border: none;
border-radius: 8px;
font-family: var(--sans);
font-size: 15px;
font-weight: 600;
cursor: pointer;
letter-spacing: 0.2px;
margin-top: 4px;
display: flex;
align-items: center;
justify-content: center;
gap: 8px;
transition: transform 0.15s, filter 0.15s;
}
.cta:hover { transform: translateY(-2px); filter: brightness(1.08); }
.cta:active { transform: translateY(0); }
.cta-arrow { transition: transform 0.2s; font-size: 17px; }
.cta:hover .cta-arrow { transform: translateX(4px); }

@keyframes gradshift {
0%   { background-position: 0% 50%; }
50%  { background-position: 100% 50%; }
100% { background-position: 0% 50%; }
}

/* ── TRUST LINE ── */
.trust {
display: flex;
align-items: center;
justify-content: center;
gap: 16px;
margin-top: 14px;
flex-wrap: wrap;
}
.trust-item {
display: flex;
align-items: center;
gap: 5px;
font-family: var(--mono);
font-size: 9px;
color: var(--dim);
letter-spacing: 1px;
text-transform: uppercase;
}
.trust-dot { color: var(--teal); font-size: 8px; }

/* ── DIVIDER ── */
.card-divider {
border: none;
border-top: 1px solid var(--border);
margin: 22px 0;
}

/* ── SOCIAL COUNT ── */
.social-count {
display: flex;
align-items: center;
gap: 14px;
}
.avatars {
display: flex;
}
.av {
width: 26px; height: 26px;
border-radius: 50%;
border: 2px solid var(--bg-card);
margin-right: -7px;
font-size: 10px;
display: flex; align-items: center; justify-content: center;
font-weight: 700;
color: #000;
flex-shrink: 0;
}
.social-text {
font-size: 12px;
color: var(--muted);
line-height: 1.4;
}
.social-text strong { color: var(--text); font-size: 13px; }

/* ── BELOW CARD — LOGOS / SOCIAL PROOF ── */
.below-card {
margin-top: 32px;
text-align: center;
}
.below-label {
font-family: var(--mono);
font-size: 9px;
color: var(--dim);
letter-spacing: 2px;
text-transform: uppercase;
margin-bottom: 16px;
}
.tools-row {
display: flex;
align-items: center;
justify-content: center;
flex-wrap: wrap;
gap: 8px;
}
.tool-tag {
font-family: var(--mono);
font-size: 10px;
color: var(--muted);
background: rgba(255,255,255,0.03);
border: 1px solid var(--border);
border-radius: 4px;
padding: 4px 10px;
letter-spacing: 1px;
transition: border-color 0.2s, color 0.2s;
}
.tool-tag:hover {
border-color: rgba(153,69,255,0.3);
color: var(--text);
}

/* ── FOOTER ── */
footer {
position: relative;
z-index: 1;
border-top: 1px solid var(--border);
padding: 20px 40px;
display: flex;
align-items: center;
justify-content: space-between;
flex-wrap: wrap;
gap: 12px;
}
.footer-brand {
font-family: var(--mono);
font-size: 9px;
color: var(--dim);
letter-spacing: 1.5px;
text-transform: uppercase;
}
.footer-brand span {
background: var(--grad);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
}
.footer-links {
display: flex;
gap: 20px;
list-style: none;
}
.footer-links a {
font-family: var(--mono);
font-size: 9px;
color: var(--dim);
text-decoration: none;
letter-spacing: 1px;
text-transform: uppercase;
transition: color 0.2s;
}
.footer-links a:hover { color: var(--purple); }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
from { opacity:0; transform:translateY(20px); }
to   { opacity:1; transform:translateY(0); }
}
.squeeze > * {
animation: fadeUp 0.6s ease both;
}
.squeeze > *:nth-child(1) { animation-delay: 0.05s; }
.squeeze > *:nth-child(2) { animation-delay: 0.12s; }
.squeeze > *:nth-child(3) { animation-delay: 0.18s; }
.squeeze > *:nth-child(4) { animation-delay: 0.24s; }
.squeeze > *:nth-child(5) { animation-delay: 0.30s; }
.squeeze > *:nth-child(6) { animation-delay: 0.36s; }

/* ── MOBILE ── */
@media (max-width: 600px) {
nav { padding: 16px 20px; }
main { padding: 40px 16px 60px; }
.card { padding: 28px 20px 22px; }
footer { padding: 16px 20px; }
h1 { font-size: 34px; }
}
</style>

</head>
<body>

<div class="ambient">
  <div class="ambient-1"></div>
  <div class="ambient-2"></div>
  <div class="ambient-3"></div>
</div>

<!-- TOPBAR -->

<div class="topbar">
  <span>Free for a limited time</span> — Automation Audit · Normally $500 · Yours free today
</div>

<!-- NAV -->

<nav>
  <a href="https://expatbuildr.com" class="nav-logo-container">
    <img src="/logo.jpg" alt="ExpatBuildr Logo" class="nav-img-logo" />
    <div class="nav-text-logo">Expat<span>Buildr</span></div>
  </a>
  <div class="nav-right">Automation Systems · Built in PH 🇵🇭</div>
</nav>

<!-- SQUEEZE -->

<main>
  <div class="squeeze">

<div class="eyebrow">
  <div class="eyebrow-pip"></div>
  <div class="eyebrow-line"></div>
  Free Automation Audit
</div>

<h1>Your business is leaking<br /><em>time and money.</em><br />Let's find it.</h1>

<p class="sub">
  We'll map exactly <strong>where AI automation can replace manual work</strong> in your business — 
  and show you the hours and dollars you recover. Free. No pitch. No obligation.
</p>

<div class="proof-row">
  <div class="proof-pill">
    <div class="check">✔</div>
    40+ systems delivered
  </div>
  <div class="proof-pill">
    <div class="check">✔</div>
    12,000+ hours automated
  </div>
  <div class="proof-pill">
    <div class="check">✔</div>
    3–7 day build time
  </div>
</div>

<!-- FORM CARD -->
<div class="card">
  <div class="card-label">// Get your free audit</div>
  <h2>See exactly what to automate first.</h2>
  <p class="card-sub">Enter your email. We'll send your personalized workflow audit — the top 3 tasks eating your time that AI can handle today.</p>

  <div class="gets">
    <div class="gets-label">What lands in your inbox</div>
    <div class="get-item">
      <div class="get-icon">⚡</div>
      <span><strong>Top 3 automation wins</strong> specific to your business type</span>
    </div>
    <div class="get-item">
      <div class="get-icon">📊</div>
      <span><strong>Time + cost savings estimate</strong> — real hours, real dollars</span>
    </div>
    <div class="get-item">
      <div class="get-icon">🛠</div>
      <span><strong>Recommended tool stack</strong> — no bloat, no subscriptions you don't need</span>
    </div>
    <div class="get-item">
      <div class="get-icon">🔒</div>
      <span><strong>Weekly systems intel</strong> — AI workflows, automation case studies, no fluff</span>
    </div>
  </div>

  <div class="form-field">
    <label for="name">First Name</label>
    <input type="text" id="name" placeholder="Your name" autocomplete="given-name" />
  </div>
  <div class="form-field">
    <label for="email">Work Email</label>
    <input type="email" id="email" placeholder="you@company.com" autocomplete="email" />
  </div>

  <button class="cta" onclick="handleSubmit()">
    Send Me The Free Audit
    <span class="cta-arrow">→</span>
  </button>

  <div class="trust">
    <div class="trust-item"><span class="trust-dot">●</span> No spam</div>
    <div class="trust-item"><span class="trust-dot">●</span> No sales calls</div>
    <div class="trust-item"><span class="trust-dot">●</span> Unsubscribe anytime</div>
  </div>

  <hr class="card-divider">

  <div class="social-count">
    <div class="avatars">
      <div class="av" style="background:linear-gradient(135deg,#9945FF,#FF6FD8);">M</div>
      <div class="av" style="background:linear-gradient(135deg,#FF6FD8,#00C2FF);">J</div>
      <div class="av" style="background:linear-gradient(135deg,#00C2FF,#14F195);">A</div>
      <div class="av" style="background:linear-gradient(135deg,#14F195,#9945FF);">R</div>
      <div class="av" style="background:linear-gradient(135deg,#9945FF,#00C2FF);">K</div>
    </div>
    <div class="social-text">
      <strong>40+ founders and operators</strong><br>
      already running automated systems
    </div>
  </div>
</div>

<!-- TOOLS ROW -->
<div class="below-card">
  <div class="below-label">Systems built with</div>
  <div class="tools-row">
    <span class="tool-tag">Make</span>
    <span class="tool-tag">n8n</span>
    <span class="tool-tag">Zapier</span>
    <span class="tool-tag">OpenAI</span>
    <span class="tool-tag">Claude</span>
    <span class="tool-tag">Airtable</span>
    <span class="tool-tag">Notion</span>
    <span class="tool-tag">Supabase</span>
    <span class="tool-tag">Railway</span>
    <span class="tool-tag">Slack</span>
  </div>
</div>

  </div>
</main>

<!-- FOOTER -->

<footer>
  <div class="footer-brand">Expat<span>Buildr</span> · Custom Automation Systems</div>
  <ul class="footer-links">
    <li><a href="https://expatbuildr.com/privacy">Privacy</a></li>
    <li><a href="https://expatbuildr.com/automation">Services</a></li>
    <li><a href="https://x.com/expatbuildr">X / Twitter</a></li>
    <li><a href="https://t.me/galaxyleads">Telegram</a></li>
  </ul>
</footer>

<script is:inline src="/beehiiv-v2.js"></script>
<script is:inline>
  async function handleSubmit() {
    const email = document.getElementById('email').value.trim();
    const name  = document.getElementById('name').value.trim();

    if (!isValidEmail(email)) {
      const el = document.getElementById('email');
      el.style.borderColor = '#FF6FD8';
      el.focus();
      setTimeout(() => el.style.borderColor = '', 2200);
      return;
    }

    const btn = document.querySelector('.cta');
    btn.textContent = 'Processing...';
    btn.disabled = true;

    // Call API
    await subscribeToBeehiiv({
        email,
        tags: ["automation_buyer", "done_for_you", "high_ticket"],
        utm_medium: "automation_page",
        utm_campaign: "automation_service"
    });

    // Redirect to the 2-step social unlock page
    window.location.href = '/automation-systems/unlock';
  }

  document.getElementById('email').addEventListener('keydown', e => {
    if (e.key === 'Enter') handleSubmit();
  });
  document.getElementById('name').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('email').focus();
  });
</script>

</body>
</html>
