        const successDiv = document.getElementById('shop-modal-success');
        const formDiv = document.getElementById('shop-form');

        if (!isValidEmail(email)) {
          emailInput.style.borderColor = 'red';
          return;
        }

        shopBtn.textContent = 'Applying...';
        shopBtn.disabled = true;

        await subscribeToBeehiiv({
          email,
          tags: ["shop_visitor", "discount_code", "warm_lead"],
          utm_medium: "shop_page",
          utm_campaign: "shop_discount_exit"
        });

        formDiv.style.display = 'none';
        successDiv.style.display = 'block';
      });
    }
  </script>
</body>
</html>
