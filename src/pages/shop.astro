<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Mono:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">

<style>
  :root {
    --nav-bg:   rgba(255,255,255,0.88);
    --bg:       #fcfcfc;
    --bg-card:  #ffffff;
    --bg-3:     #f5f5f9;
    --border:   rgba(0,0,0,0.08);
    --border-hi:rgba(0,0,0,0.16);
    --text:     #1a1a24;
    --muted:    #505068;
    --dim:      #8c8c9e;

    --purple:   #8a2be2;
    --teal:     #059669;
    --pink:     #db2777;
    --cyan:     #0284c7;

    --grad:      linear-gradient(135deg, #8a2be2 0%, #db2777 45%, #059669 100%);
    --grad-btn:  linear-gradient(135deg, #8a2be2 0%, #a43ff8 35%, #db2777 65%, #059669 100%);
    --grad-text: linear-gradient(90deg, #8a2be2, #db2777, #059669);
    --glow-p:    rgba(138,43,226,0.15);
    --glow-t:    rgba(5,150,105,0.08);

    --serif: 'DM Serif Display', Georgia, serif;
    --mono:  'IBM Plex Mono', monospace;
    --sans:  'DM Sans', system-ui, sans-serif;
  }

  html.dark {
    --nav-bg:   rgba(4,4,10,0.88);
    --bg:       #04040a;
    --bg-card:  #07070f;
    --bg-3:     #0c0c18;
    --border:   rgba(255,255,255,0.06);
    --border-hi:rgba(255,255,255,0.11);
    --text:     #eeeaff;
    --muted:    #7c7a9a;
    --dim:      #3d3b55;

    --purple:   #9945FF;
    --teal:     #14F195;
    --pink:     #FF6FD8;
    --cyan:     #00C2FF;

    --grad:      linear-gradient(135deg, #9945FF 0%, #FF6FD8 45%, #14F195 100%);
    --grad-btn:  linear-gradient(135deg, #9945FF 0%, #c84bff 35%, #FF6FD8 65%, #14F195 100%);
    --grad-text: linear-gradient(90deg, #9945FF, #FF6FD8, #14F195);
    --glow-p:    rgba(153,69,255,0.15);
    --glow-t:    rgba(20,241,149,0.08);
  }

  .icon-sun { display: none; }
  .icon-moon { display: block; }
  html.dark .icon-sun { display: block; }
  html.dark .icon-moon { display: none; }

  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* GRID BG */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(153,69,255,0.025) 59px, rgba(153,69,255,0.025) 60px),
      repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(20,241,149,0.015) 59px, rgba(20,241,149,0.015) 60px);
    pointer-events: none;
    z-index: 0;
  }
  
  html.dark body::after {
    content: '';
    position: fixed; inset: 0;
    background-image: url('/shop_galaxy_bg.png');
    background-size: cover;
    background-position: center top;
    opacity: 0.15;
    pointer-events: none;
    z-index: -1;
  }

  /* AMBIENT */
  .ambient { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden; }
  .amb-1 { position:absolute; top:-20%; right:-10%; width:60vw; height:60vw; background:radial-gradient(ellipse, rgba(153,69,255,0.09) 0%, transparent 65%); }
  .amb-2 { position:absolute; bottom:-20%; left:-10%; width:50vw; height:50vw; background:radial-gradient(ellipse, rgba(20,241,149,0.05) 0%, transparent 65%); }
  .amb-3 { position:absolute; top:50%; left:40%; width:35vw; height:35vw; background:radial-gradient(ellipse, rgba(255,111,216,0.04) 0%, transparent 65%); }

  /* GRAD TOP LINE */
  .top-line { position:fixed; top:0; left:0; right:0; height:2px; background:var(--grad); z-index:200; }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid var(--border);
    background: var(--nav-bg);
    backdrop-filter: blur(16px);
  }
  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 0 40px;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav-logo-container {
    display: flex; align-items: center; gap: 12px; text-decoration: none;
  }
  .nav-img-logo {
    width: 40px; height: 40px; border-radius: 12px; object-fit: cover;
    box-shadow: 0 0 0 2px rgba(255,255,255,0.1);
    transition: box-shadow 0.2s;
  }
  .nav-logo-container:hover .nav-img-logo {
    box-shadow: 0 0 0 2px rgba(153,69,255,0.5); /* using var(--purple) approx */
  }
  .nav-text-logo {
    font-family: var(--sans); font-weight: 900; font-size: 24px;
    color: var(--text); letter-spacing: -0.02em; text-transform: uppercase;
  }
  .nav-text-logo span {
    font-weight: 300; color: var(--purple);
    background: var(--grad);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .nav-links { display:flex; align-items:center; gap:32px; list-style:none; }
  .nav-links a {
    font-family: var(--mono); font-size: 9px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--muted); text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-links a.active { color: var(--purple); }
  .nav-cta {
    font-family: var(--mono); font-size: 9px; letter-spacing: 1.5px;
    text-transform: uppercase; padding: 8px 16px;
    background: var(--grad-btn); color: #000 !important;
    border-radius: 6px; text-decoration: none; font-weight: 600;
    transition: filter 0.2s;
  }
  .nav-cta:hover { filter: brightness(1.1); }

  /* ── WRAP ── */
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 40px; position: relative; z-index: 1; }

  /* ── PAGE HEADER ── */
  .page-header {
    padding: 80px 0 64px;
    border-bottom: 1px solid var(--border);
  }
  .page-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--mono); font-size: 9px; letter-spacing: 3px;
    text-transform: uppercase; color: var(--muted); margin-bottom: 24px;
  }
  .eyebrow-pip {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--grad); flex-shrink: 0;
    animation: pip 2.5s ease infinite;
  }
  @keyframes pip {
    0%,100% { opacity:1; } 50% { opacity:0.4; }
  }
  .page-header h1 {
    font-family: var(--serif);
    font-size: clamp(38px, 5vw, 64px);
    line-height: 1.05; letter-spacing: -0.02em;
    color: var(--text); margin-bottom: 16px;
  }
  .page-header h1 em {
    font-style: italic;
    background: var(--grad-text);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .page-header-sub {
    font-size: 16px; color: var(--muted); font-weight: 300;
    line-height: 1.75; max-width: 52ch; margin-bottom: 32px;
  }
  .header-meta {
    display: flex; align-items: center; gap: 24px; flex-wrap: wrap;
  }
  .meta-tag {
    font-family: var(--mono); font-size: 9px; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--dim);
    display: flex; align-items: center; gap: 6px;
  }
  .meta-tag-dot { color: var(--teal); font-size: 10px; }

  /* ── PILLAR TABS ── */
  .pillars {
    display: flex; gap: 0;
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .pillars::-webkit-scrollbar { display:none; }
  .pillar-tab {
    font-family: var(--sans); font-size: 14px; font-weight: 600; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--muted);
    padding: 20px 32px; border: none; background: none;
    cursor: pointer; border-bottom: 3px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .pillar-tab:hover { color: var(--text); }
  .pillar-tab.active {
    color: var(--text); border-bottom-color: var(--purple);
  }

  /* ── SHOP GRID ── */
  .shop-section { padding: 56px 0 80px; }
  .section-label {
    font-family: var(--mono); font-size: 9px; letter-spacing: 3px;
    text-transform: uppercase; color: var(--dim);
    margin-bottom: 32px;
    display: flex; align-items: center; gap: 12px;
  }
  .section-label::after {
    content: ''; display: block; height: 1px; flex: 1;
    background: var(--border);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  /* ── PRODUCT CARD ── */
  .product-card {
    background: var(--bg-card);
    display: flex; flex-direction: column;
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
  }
  .product-card:hover { background: var(--bg-3); }
  .product-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 1px;
    background: var(--grad);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .product-card:hover::before { opacity: 1; }

  /* MOCKUP */
  .card-mockup {
    width: 100%; aspect-ratio: 16/9;
    background: var(--bg-3);
    border-bottom: 1px solid var(--border);
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  /* Placeholder mockup — replace with real screenshots */
  .mockup-inner {
    width: 85%; height: 78%;
    border-radius: 6px;
    border: 1px solid var(--border-hi);
    background: var(--bg);
    position: relative; overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
  }
  .mockup-topbar {
    height: 24px; background: rgba(255,255,255,0.04);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 5px; padding: 0 10px;
  }
  .mockup-dot { width:7px; height:7px; border-radius:50%; }
  .mockup-dot:nth-child(1) { background:#e05858; }
  .mockup-dot:nth-child(2) { background:#e0a020; }
  .mockup-dot:nth-child(3) { background:#40a858; }
  .mockup-body { padding: 12px; display:flex; flex-direction:column; gap:6px; }
  .mockup-row {
    height: 8px; border-radius: 2px;
    background: rgba(255,255,255,0.04);
  }
  .mockup-row.accent { background: linear-gradient(90deg, rgba(153,69,255,0.3), rgba(20,241,149,0.2)); }
  .mockup-row.sm { width: 60%; }
  .mockup-row.xs { width: 40%; }
  .mockup-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; margin-top:6px; }
  .mockup-cell {
    height: 24px; border-radius: 2px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
  }
  .mockup-cell.hi { background: rgba(153,69,255,0.1); border-color: rgba(153,69,255,0.2); }
  .mockup-cell.teal { background: rgba(20,241,149,0.08); border-color: rgba(20,241,149,0.15); }

  /* CARD BADGE */
  .card-badge {
    position: absolute; top: 12px; right: 12px;
    font-family: var(--mono); font-size: 8px; letter-spacing: 1.5px;
    text-transform: uppercase; padding: 3px 9px;
    border-radius: 3px; background: rgba(4,4,10,0.85);
    border: 1px solid var(--border-hi);
    backdrop-filter: blur(8px);
  }
  .badge-new { color: var(--teal); border-color: rgba(20,241,149,0.25); }
  .badge-hot { color: var(--pink); border-color: rgba(255,111,216,0.25); }

  /* CARD BODY */
  .card-body { padding: 24px; flex: 1; display: flex; flex-direction: column; gap: 0; }
  .card-pillar {
    font-family: var(--mono); font-size: 8px; letter-spacing: 2.5px;
    text-transform: uppercase; margin-bottom: 10px;
    background: var(--grad-text);
