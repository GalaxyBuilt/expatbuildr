<!-- ══════════════════════════════════════════════
     PROCESSING OVERLAY
     2-second branded delay before Etsy redirect
     Maintains brand authority / feels intentional
════════════════════════════════════════════════ -->
<div class="processing-overlay" id="processing-overlay">
  <div class="processing-logo">Galaxy<span>Built</span></div>
  <div class="processing-spinner"></div>
  <div class="processing-text">Preparing your download</div>
  <div class="processing-sub">Redirecting to secure checkout...</div>
</div>


<script is:inline>
  // ── STATE ──
  let currentEtsyUrl  = null;
  let currentProduct  = null;
  let currentPrice    = null;

  // ── PILLAR FILTER ──
  function filterPillar(pillar, btn) {
    document.querySelectorAll('.pillar-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.product-card').forEach(card => {
      if (pillar === 'all' || card.dataset.pillar === pillar) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }

  // ── OPEN EMAIL GATE ──
  function openGate(productName, etsyUrl, price) {
    currentProduct  = productName;
    currentEtsyUrl  = etsyUrl;
    currentPrice    = price;

    document.getElementById('modal-product-ref').textContent = '// ' + productName;
    document.getElementById('modal-title').textContent =
      etsyUrl ? 'One step to instant access.' : 'Get notified first.';
    document.getElementById('modal-sub').textContent = etsyUrl
      ? 'Enter your email — we\'ll add you to Galaxy Arbitrage (free weekly remote jobs + income intel), then take you straight to checkout.'
      : 'Drop your email and we\'ll notify you the moment ' + productName + ' drops.';
    document.getElementById('modal-btn-text').textContent =
      etsyUrl ? 'Proceed to Checkout →' : 'Notify Me When Live →';

    document.getElementById('modal-overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
    setTimeout(() => document.getElementById('gate-email').focus(), 300);
  }

  // ── CLOSE GATE ──
  function closeGate() {
    document.getElementById('modal-overlay').classList.remove('open');
    document.body.style.overflow = '';
    // reset btn
    document.getElementById('modal-btn-text').textContent = 'Proceed to Checkout →';
    document.getElementById('modal-btn').disabled = false;
  }

  function handleOverlayClick(e) {
    if (e.target === document.getElementById('modal-overlay')) closeGate();
  }

  // ── GATE SUBMIT ──
  // Flow: validate → subscribe Beehiiv → show processing overlay → open Etsy in new tab
  async function handleGateSubmit() {
    const email = document.getElementById('gate-email').value.trim();
    const name  = document.getElementById('gate-name').value.trim();

    if (!email || !email.includes('@')) {
      const el = document.getElementById('gate-email');
      el.style.borderColor = '#FF6FD8';
      el.focus();
      setTimeout(() => el.style.borderColor = '', 2000);
      return;
    }

    // Update button state
    const btn = document.getElementById('modal-btn');
    btn.disabled = true;
    document.getElementById('modal-btn-text').textContent = 'Saving your spot...';

    // ── BEEHIIV SUBSCRIBE ──
    const beehiivUrl = `https://expatbuildr.beehiiv.com/subscribe?email=${encodeURIComponent(email)}&utm_source=shop_gate&utm_medium=product_click&utm_campaign=${encodeURIComponent(currentProduct)}`;

    localStorage.setItem('gb_email', email);
    localStorage.setItem('gb_name', name);
    localStorage.setItem('gb_product', currentProduct);

    // Close modal
    document.getElementById('modal-overlay').classList.remove('open');
    document.body.style.overflow = '';

    // ── SHOW PROCESSING OVERLAY (2 seconds) ──
    const proc = document.getElementById('processing-overlay');
    proc.classList.add('active');

    await new Promise(r => setTimeout(r, 2000));

    // ── REDIRECT TO CHECKOUT (Same window to bypass blockers) ──
    if (currentEtsyUrl) {
      window.location.href = currentEtsyUrl;
      return; // Stop here as we are navigating away
    }

    proc.classList.remove('active');

    // Show a subtle confirmation instead
    showConfirmation(name || 'there');
  }

  // ── SOFT CONFIRMATION ──
  function showConfirmation(name) {
    const div = document.createElement('div');
    div.style.cssText = `
      position:fixed; bottom:24px; right:24px; z-index:700;
      background:var(--bg-card); border:1px solid rgba(20,241,149,0.3);
      border-radius:10px; padding:16px 20px; max-width:280px;
      font-family:var(--mono); font-size:10px; color:var(--teal);
      letter-spacing:1px; line-height:1.6;
      animation: slideIn 0.3s ease both;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    `;
    div.innerHTML = `
      <div style="font-size:11px;font-weight:600;margin-bottom:4px;">✓ You're in, ${name}.</div>
      <div style="color:var(--muted);">Checkout opened in new tab.<br>Check your inbox for the newsletter.</div>
    `;
    document.body.appendChild(div);
    setTimeout(() => {
      div.style.opacity = '0'; div.style.transform = 'translateY(10px)';
      div.style.transition = 'all 0.3s';
      setTimeout(() => div.remove(), 300);
    }, 4000);
  }

  // ── ESC TO CLOSE ──
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeGate();
  });

  // ── SCROLL REVEAL ──
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.product-card, .trust-item').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(14px)';
    el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    observer.observe(el);
  });

  // ── THEME TOGGLE ──
  const toggleTheme = () => {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  };

  document.getElementById('shopThemeToggle')?.addEventListener('click', toggleTheme);
  document.getElementById('shopThemeToggleMobile')?.addEventListener('click', toggleTheme);

  // ── MOBILE MENU TOGGLE ──
  const mobToggle = document.getElementById('shopMobileToggle');
  const mobMenu = document.getElementById('shopMobileMenu');
  const icMenu = mobToggle?.querySelector('.icon-menu');
  const icClose = mobToggle?.querySelector('.icon-close');

  mobToggle?.addEventListener('click', () => {
    mobMenu.classList.toggle('open');
    if (mobMenu.classList.contains('open')) {
      if(icMenu) icMenu.style.display = 'none';
      if(icClose) icClose.style.display = 'block';
    } else {
      if(icMenu) icMenu.style.display = 'block';
      if(icClose) icClose.style.display = 'none';
    }
  });

</script>

