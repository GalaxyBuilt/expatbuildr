---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Target, Cpu, Send, CheckCircle2 } from 'lucide-astro';

const systems = [
  "Autonomous lead scoring via multi-vector intent signals.",
  "AI-powered deep enrichment and prospect graph mapping.",
  "Scalable cold outreach sequences with 20%+ reply rates.",
  "Closed-loop attribution and pipeline tracking native to your stack."
];
---

<Layout
  title="Lead Generation Systems: The Autonomous Outreach Protocol"
  description="How to architect high-intent client acquisition engines and decouple growth from manual labor."
  ogImage="/images/lead gen.jpg"
  noindex={true}
>
  <div class="relative min-h-screen flex flex-col items-center pt-32 px-4 pb-20 overflow-hidden">
    <!-- Cinematic Background -->
    <div class="absolute inset-0 -z-10 bg-white dark:bg-slate-950">
        <img
            src="/images/lead gen.jpg"
            alt="Lead Generation"
            class="w-full h-full object-cover opacity-10 dark:opacity-20 grayscale"
        />
        <div class="absolute inset-0 bg-radial-at-t from-emerald-500/5 dark:from-emerald-500/10 via-white/80 dark:via-slate-950/80 to-white dark:to-slate-950"></div>
    </div>

    <!-- Header Content -->
    <div class="max-w-4xl text-center space-y-8 reveal-on-scroll">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] uppercase tracking-[0.2em] font-mono">
        Active Protocol: Lead Systems v2.0
      </div>
      
      <h1 class="text-6xl md:text-8xl font-black font-display tracking-tight text-slate-900 dark:text-white leading-none uppercase">
        ARCHITECT YOUR <span class="text-gradient">OUTREACH</span> ENGINE.
      </h1>

      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-inter">
        Volume is a legacy metric. Intent is the only signal that matters. Learn how we build the autonomous acquisition systems used by the world's most aggressive technical operators.
      </p>

      <div class="pt-8">
        <form id="hero-subscribe-form" class="flex flex-col sm:flex-row items-center gap-4 justify-center w-full max-w-lg mx-auto">
            <input type="email" id="hero-email" placeholder="Enter your best email" required class="w-full px-6 py-4 rounded-xl bg-white dark:bg-slate-900 border border-emerald-500/30 text-slate-900 dark:text-white focus:outline-none focus:border-emerald-500 font-sans" />
            <button type="submit" id="hero-submit-btn" class="btn-primary flex items-center gap-3 px-8 py-4 text-lg bg-emerald-500 hover:bg-emerald-600 w-full sm:w-auto justify-center rounded-xl whitespace-nowrap pixel-border">
                ACTIVATE SYSTEMS <ArrowRight size={20} />
            </button>
        </form>
        <p id="hero-form-message" class="text-sm text-red-400 mt-2 hidden text-center font-mono"></p>
      </div>
    </div>

    <!-- The Framework -->
    <div class="max-w-6xl w-full grid grid-cols-1 md:grid-cols-2 gap-12 mt-40 reveal-on-scroll">
        <div class="space-y-8">
            <h2 class="text-4xl font-black font-display text-slate-900 dark:text-white uppercase tracking-tighter">
                The <span class="text-emerald-500">Acquisition</span> Protocol
            </h2>
            <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed">
                We've moved beyond the "List." We architect lead engines that identify inflection points—technographic shifts, semantic hiring, and financial velocity—to hit targets exactly when they are ready to buy.
            </p>
            <div class="space-y-4">
                {systems.map(system => (
                    <div class="flex items-start gap-4 p-4 rounded-2xl glass-card border border-slate-200 dark:border-white/5 group hover:border-emerald-500/30 transition-all">
                        <div class="mt-1 text-emerald-500"><CheckCircle2 size={24} /></div>
                        <p class="text-slate-900 dark:text-white font-inter">{system}</p>
                    </div>
                ))}
            </div>
        </div>

        <div class="relative group">
            <div class="absolute inset-0 bg-emerald-500/10 blur-[100px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative glass-card p-1 rounded-[3rem] border border-slate-200 dark:border-white/10 overflow-hidden shadow-2xl">
                <img src="/images/lead gen.jpg" alt="Dashboard" class="w-full h-full object-cover rounded-[2.8rem]" />
            </div>
        </div>
    </div>

    <!-- Newsletter CTA Section -->
    <div id="newsletter" class="max-w-5xl w-full mt-40 p-12 rounded-[3.5rem] glass-gradient border border-emerald-500/20 text-center space-y-8 reveal-on-scroll relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-linear-to-r from-emerald-500 via-accent-cyan to-accent-blue"></div>
        
        <h3 class="text-4xl md:text-5xl font-black font-display text-slate-900 dark:text-white uppercase tracking-tighter">
            JOIN <span class="text-gradient">GALAXY ARBITRAGE</span>
        </h3>
        <p class="text-slate-600 dark:text-slate-400 max-w-xl mx-auto text-lg leading-relaxed">
            Get the exact outreach blueprints and intent-scoring frameworks we use to close $10k+ deals every month.
        </p>
        
        <a href="/newsletter" class="btn-primary inline-flex items-center gap-4 px-12 py-6 text-xl mx-auto bg-emerald-500 hover:bg-emerald-600">
            ACCESS THE PROTOCOL <Send size={24} />
        </a>
    </div>
  </div>
</Layout>

<script is:inline>
  const heroForm = document.getElementById('hero-subscribe-form');
  const heroBtn = document.getElementById('hero-submit-btn');
  const heroMsg = document.getElementById('hero-form-message');

  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailVal = document.getElementById('hero-email').value.trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
      heroMsg.innerText = '❌ Please enter a valid email address.';
      heroMsg.classList.remove('hidden');
      return;
    }
    heroBtn.disabled = true;
    heroBtn.innerHTML = 'Activating...';
    heroMsg.classList.add('hidden');
    try {
      const response = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: emailVal, source: 'lead-gen-edge', magnet: 'lead-gen-systems', tags: ['lead_builder'] })
      });
      const data = await response.json();
      if (data.success) {
        if (window.fireLeadEvent) window.fireLeadEvent();
        heroBtn.innerText = 'Redirecting...';
        window.location.href = '/contact';
      } else {
        heroBtn.disabled = false;
        heroBtn.innerHTML = 'ACTIVATE SYSTEMS &nbsp;→';
        heroMsg.innerText = '❌ ' + (data.error || 'Error, try again.');
        heroMsg.classList.remove('hidden');
      }
    } catch (err) {
      heroBtn.disabled = false;
      heroBtn.innerHTML = 'ACTIVATE SYSTEMS &nbsp;→';
      heroMsg.innerText = '❌ Network error.';
      heroMsg.classList.remove('hidden');
    }
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.active {
    opacity: 1;
    transform: translateY(0);
  }
  .glass-gradient {
    background: linear-gradient(135deg, rgba(241, 245, 249, 0.9) 0%, rgba(226, 232, 240, 0.8) 100%);
    backdrop-filter: blur(20px);
  }
  html.dark .glass-gradient {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(30, 41, 59, 0.8) 100%);
  }
</style>
