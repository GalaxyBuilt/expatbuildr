---
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Zap, Target, Rocket, CheckCircle2 } from 'lucide-astro';

const benefits = [
  "Identify high-yield remote roles before they hit public boards.",
  "Automate your application and follow-up sequences.",
  "Productize your technical skills into high-ticket service offers.",
  "Deploy micro-SaaS and data arbitrage bots for residual income."
];
---

<Layout 
  title="Remote Income: Start Here — The Sovereign Salary Protocol"
  description="How to secure $150k+ remote roles, automate your income, and transition to a sovereign digital lifestyle."
  ogImage="/images/remote work.jpg"
>
  <div class="relative min-h-screen flex flex-col items-center pt-32 px-4 pb-20 overflow-hidden">
    <!-- Cinematic Background -->
    <div class="absolute inset-0 -z-10 bg-slate-950">
        <img 
            src="/images/remote work.jpg" 
            alt="Remote Income" 
            class="w-full h-full object-cover opacity-20 grayscale"
        />
        <div class="absolute inset-0 bg-radial-at-t from-accent-blue/20 via-slate-950/80 to-slate-950"></div>
    </div>

    <!-- Header Content -->
    <div class="max-w-4xl text-center space-y-8 reveal-on-scroll">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-accent-blue text-[10px] uppercase tracking-[0.2em] font-mono">
        Active Protocol: Remote Income v2.0
      </div>
      
      <h1 class="text-6xl md:text-8xl font-black font-display tracking-tight text-white leading-none uppercase">
        SECURE YOUR <span class="text-gradient">SOVEREIGN</span> SALARY.
      </h1>

      <p class="text-xl text-slate-400 max-w-2xl mx-auto font-inter">
        Most technical professionals trade time for money at a 1:1 ratio. We trade systems for scale. This is the definitive manual for the high-velocity remote operator.
      </p>

      <div class="pt-8">
        <form id="hero-subscribe-form" class="flex flex-col sm:flex-row items-center gap-4 justify-center w-full max-w-lg mx-auto">
            <input type="email" id="hero-email" placeholder="Enter your best email" required class="w-full px-6 py-4 rounded-xl bg-slate-900 border border-accent-blue/30 text-white focus:outline-none focus:border-accent-blue font-sans" />
            <button type="submit" id="hero-submit-btn" class="btn-primary flex items-center gap-3 px-8 py-4 text-lg w-full sm:w-auto justify-center rounded-xl whitespace-nowrap pixel-border">
                JOIN THE ARBITRAGE <ArrowRight size={20} />
            </button>
        </form>
        <p id="hero-form-message" class="text-sm text-red-400 mt-2 hidden text-center font-mono"></p>
      </div>
    </div>

    <!-- The Framework -->
    <div class="max-w-6xl w-full grid grid-cols-1 md:grid-cols-2 gap-12 mt-40 reveal-on-scroll">
        <div class="space-y-8">
            <h2 class="text-4xl font-black font-display text-white uppercase tracking-tighter">
                The <span class="text-accent-blue">Sniper</span> Framework
            </h2>
            <p class="text-slate-400 text-lg leading-relaxed">
                We've spent the last 5 years perfecting the technical architecture required to dominate remote markets. We don't "wait" for raises; we engineer them.
            </p>
            <div class="space-y-4">
                {benefits.map(benefit => (
                    <div class="flex items-start gap-4 p-4 rounded-2xl glass-card border border-white/5 group hover:border-accent-blue/30 transition-all">
                        <div class="mt-1 text-emerald-500"><CheckCircle2 size={24} /></div>
                        <p class="text-white font-inter">{benefit}</p>
                    </div>
                ))}
            </div>
        </div>

        <div class="relative group">
            <div class="absolute inset-0 bg-accent-blue/20 blur-[100px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative glass-card p-1 rounded-[3rem] border border-white/10 overflow-hidden shadow-2xl">
                <img src="/images/remote work.jpg" alt="Dashboard" class="w-full h-full object-cover rounded-[2.8rem]" />
            </div>
        </div>
    </div>

    <!-- Newsletter CTA Section -->
    <div id="newsletter" class="max-w-5xl w-full mt-40 p-12 rounded-[3.5rem] glass-gradient border border-accent-blue/20 text-center space-y-8 reveal-on-scroll relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-linear-to-r from-accent-blue via-accent-purple to-accent-cyan"></div>
        
        <h3 class="text-4xl md:text-5xl font-black font-display text-white uppercase tracking-tighter">
            JOIN <span class="text-gradient">GALAXY ARBITRAGE</span>
        </h3>
        <p class="text-slate-400 max-w-xl mx-auto text-lg leading-relaxed">
            Get weekly strategic briefings on remote income hacks, job sniping protocols, and autonomous wealth engines.
        </p>
        
        <!-- Redirect to /newsletter -->
        <a href="/newsletter" class="btn-primary inline-flex items-center gap-4 px-12 py-6 text-xl mx-auto">
            ACCESS THE PROTOCOL <Zap size={24} />
        </a>
        
        <p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest pt-8">
            No Spam. No Noise. Just Industrial-Grade Intelligence.
        </p>
    </div>
  </div>
</Layout>

<script is:inline>
  const heroForm = document.getElementById('hero-subscribe-form');
  const heroBtn = document.getElementById('hero-submit-btn');
  const heroMsg = document.getElementById('hero-form-message');

  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailVal = document.getElementById('hero-email').value.trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
      heroMsg.innerText = '❌ Please enter a valid email address.';
      heroMsg.classList.remove('hidden');
      return;
    }
    heroBtn.disabled = true;
    heroBtn.innerHTML = 'Activating...';
    heroMsg.classList.add('hidden');
    try {
      const response = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: emailVal, source: 'remote-income-sniper', magnet: 'geo-arbitrage-starter-kit', tags: ['remote_hustler'] })
      });
      const data = await response.json();
      if (data.success) {
        if (window.fireLeadEvent) window.fireLeadEvent();
        heroBtn.innerText = 'Redirecting...';
        window.location.href = '/job';
      } else {
        heroBtn.disabled = false;
        heroBtn.innerHTML = 'JOIN THE ARBITRAGE &nbsp;→';
        heroMsg.innerText = '❌ ' + (data.error || 'Error, try again.');
        heroMsg.classList.remove('hidden');
      }
    } catch (err) {
      heroBtn.disabled = false;
      heroBtn.innerHTML = 'JOIN THE ARBITRAGE &nbsp;→';
      heroMsg.innerText = '❌ Network error.';
      heroMsg.classList.remove('hidden');
    }
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-on-scroll.active {
    opacity: 1;
    transform: translateY(0);
  }
  .glass-gradient {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(30, 41, 59, 0.8) 100%);
    backdrop-filter: blur(20px);
  }
</style>
