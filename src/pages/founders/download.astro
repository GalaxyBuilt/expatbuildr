---
import Layout from '../../layouts/Layout.astro';
import '../../styles/funnel.css';
---

<Layout minimal={true} noAnimations={true} title="Starting Your Download — ExpatBuildr" noindex={true}>
  <script is:inline>
    (()=>{ document.documentElement.classList.add('dark'); document.documentElement.classList.remove('light'); })();
  </script>

  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/logo.jpg" alt="ExpatBuildr Logo" class="nav-logo-img" />
        <div class="logo-text">Expat<span class="built">Buildr</span><span class="slug">/download</span></div>
      </a>
    </div>
  </nav>

  <main>
    <div class="download-container">
      <div class="loading-circle">
        <div class="circle-inner"></div>
        <div class="check-icon">✓</div>
      </div>

      <h1 class="f1">Your download is <em>starting.</em></h1>
      <p class="f2">The 12-Point Founder Launch Checklist is being prepared.</p>

      <div class="progress-bar f2">
        <div class="progress-fill"></div>
      </div>

      <div class="manual-download f3">
        <p>Didn't start? <a href="/downloads/checklist.pdf" download id="manual-link">Click here to download manually</a></p>
      </div>

      <div class="next-step f4">
        <div class="ns-label">// While you wait</div>
        <h3>Ready to build your launch <em>for real?</em></h3>
        <p>I build conversion-optimized funnels like this one for founders in 7 days.</p>
        <a href="/founders/offer" class="btn-primary">View the Launch Offer →</a>
      </div>
    </div>
  </main>

  <script is:inline>
    // Auto-trigger download
    setTimeout(() => {
      const link = document.getElementById('manual-link');
      link.click();
    }, 1500);

    // Auto-redirect to offer page after delay
    setTimeout(() => {
      window.location.href = '/founders/offer';
    }, 8000);
  </script>
</Layout>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(5,5,5,0.9);
    backdrop-filter: blur(12px);
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem clamp(1.25rem,5vw,2.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  .nav-logo-img {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    object-fit: cover;
  }
  .logo-text {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 1.4rem;
    letter-spacing: -0.04em;
    color: var(--text);
  }
  .logo-text .built { background: linear-gradient(135deg, var(--accent-1), var(--accent-2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 400; }
  .logo-text .slug { font-family: var(--mono); font-size: 0.8rem; color: var(--text-dim); margin-left: 0.3rem; font-weight: 400; letter-spacing: 0.05em; }

  main {
    position: relative;
    z-index: 5;
    max-width: 600px;
    margin: 0 auto;
    padding: clamp(4rem,10vw,8rem) clamp(1.25rem,5vw,2.5rem);
    text-align: center;
  }

  .download-container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .loading-circle {
    position: relative;
    width: 80px;
    height: 80px;
    margin-bottom: 2rem;
  }
  .circle-inner {
    position: absolute;
    inset: 0;
    border: 3px solid var(--border);
    border-top-color: var(--accent-1);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  .check-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--accent-1);
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  h1 {
    font-family: var(--serif);
    font-size: clamp(2rem,6vw,3.5rem);
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  h1 em { font-style: italic; color: var(--accent-1); }

  p { color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; }

  .progress-bar {
    width: 100%;
    max-width: 300px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .progress-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--accent-1), var(--accent-2));
    animation: fillProgress 1.5s ease forwards;
  }
  @keyframes fillProgress { to { width: 100%; } }

  .manual-download {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 4rem;
  }
  .manual-download a { color: var(--accent-1); text-decoration: underline; }

  .next-step {
    background: var(--bg-2);
    border: 1px solid var(--border-hi);
    padding: 2.5rem 2rem;
    text-align: left;
    width: 100%;
  }
  .ns-label { font-family: var(--mono); font-size: 0.6rem; color: var(--text-dim); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.1em; }
  .next-step h3 { font-family: var(--serif); font-size: 1.5rem; margin-bottom: 0.75rem; }
  .next-step h3 em { font-style: italic; color: var(--accent-1); }
  .next-step p { font-size: 0.9rem; margin-bottom: 1.5rem; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1em 1.5em;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    color: #000;
    transition: all 0.15s;
  }
  .btn-primary:hover { filter: brightness(1.1); transform: translateY(-1px); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .f1 { animation: fadeUp .6s ease both; }
  .f2 { animation: fadeUp .6s .1s ease both; }
  .f3 { animation: fadeUp .6s .2s ease both; }
  .f4 { animation: fadeUp .6s .3s ease both; }
</style>
