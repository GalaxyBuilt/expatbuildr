---
import Layout from '../../layouts/Layout.astro';
import '../../styles/funnel.css';
---

<Layout minimal={true} noAnimations={true} title="Payment Received — ExpatBuildr">
  <Fragment slot="head">
    <script is:inline>
      // Tracking Purchase Event
      fbq('track', 'Purchase', { currency: 'USD', value: 650.00 });
      ttq.track('CompletePayment', { content_type: 'product', value: 650.00, currency: 'USD' });
      rdt('track', 'Purchase', { currency: 'USD', value: 650.00 });
    </script>
  </Fragment>

  <canvas id="confetti-canvas"></canvas>
  <script is:inline>
    (()=>{ document.documentElement.classList.add('dark'); document.documentElement.classList.remove('light'); })();
  </script>

  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/logo.jpg" alt="ExpatBuildr Logo" class="nav-logo-img" />
        <div class="logo-text">Expat<span class="built">Buildr</span><span class="slug">/receipt</span></div>
      </a>
      <div class="nav-tag">✓ Payment Received</div>
    </div>
  </nav>

  <main>
    <div class="receipt-badge f1"><span class="badge-dot"></span>Payment confirmed</div>

    <h1 class="f2">We're building<br /><em>your launch.</em></h1>

    <p class="sub f3">
      Payment received and logged. You'll hear from me within 24 hours with your intake form.
      Here's exactly what happens next.
    </p>

    <!-- ORDER SUMMARY -->
    <div class="order-card f3">
      <div class="order-row">
        <span class="order-label">Status</span>
        <span class="order-status">✓ Confirmed</span>
      </div>
      <div class="order-row">
        <span class="order-label">Response time</span>
        <span class="order-value amber">Within 24 hours</span>
      </div>
      <div class="order-row">
        <span class="order-label">Build delivery</span>
        <span class="order-value">3–7 business days</span>
      </div>
      <div class="order-row">
        <span class="order-label">Revisions included</span>
        <span class="order-value green">2 rounds — no extra charge</span>
      </div>
      <div class="order-row">
        <span class="order-label">Code ownership</span>
        <span class="order-value green">100% yours on delivery</span>
      </div>
    </div>

    <!-- TIMELINE -->
    <div class="tl-label f4">// What happens now</div>
    <div class="timeline f4">
      <div class="tl-item done">
        <div class="tl-dot">✓</div>
        <div class="tl-body">
          <h4>Payment received</h4>
          <p>Your order is confirmed. Stripe receipt sent to your email.</p>
          <div class="tl-time">Done — just now</div>
        </div>
      </div>
      <div class="tl-item active">
        <div class="tl-dot">⚡</div>
        <div class="tl-body">
          <h4>I send you the intake form</h4>
          <p>Within 24 hours I reach out with a short brief — your product, target audience, goal, and any brand assets. Takes 5 minutes.</p>
          <div class="tl-time">Within 24 hours</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-dot">02</div>
        <div class="tl-body">
          <h4>Build starts</h4>
          <p>Once your intake is submitted I start immediately — copy, page build, pixel setup, email sequence. You don't touch a line of code.</p>
          <div class="tl-time">After intake submitted</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-dot">03</div>
        <div class="tl-body">
          <h4>First draft delivered</h4>
          <p>You receive the full build with a handover doc. Review, request revisions — we iterate until it's exactly right.</p>
          <div class="tl-time">3–7 business days</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-dot">04</div>
        <div class="tl-body">
          <h4>You launch</h4>
          <p>Everything live, tested, fully yours. Send traffic. Watch your list grow.</p>
          <div class="tl-time">After final approval</div>
        </div>
      </div>
    </div>

    <!-- INTAKE PROMPT -->
    <div class="intake-box f4">
      <div class="ib-label">// Optional — speed up your start</div>
      <h3>Want to move <em>faster?</em></h3>
      <p>DM me on X right now with your product name and target audience. I can start scoping before the intake form arrives.</p>
      <a href="https://twitter.com/messages/compose?recipient_id=expatbuildr&text=Hey%20Tony%2C%20just%20paid%20for%20a%20ExpatBuildr%20package.%20My%20product%20is%3A%20" target="_blank" rel="noopener" class="btn-intake">
        DM @expatbuildr on X →
      </a>
    </div>

    <a href="/" class="back-link f6">← Back to ExpatBuildr home</a>

  </main>

  <footer>
    ExpatBuildr · Built in the Philippines 🇵🇭 ·
    <a href="/privacy">Privacy</a> ·
    <a href="/terms">Terms</a>
  </footer>

  <script is:inline>
    // CONFETTI
    (function(){
      const canvas = document.getElementById('confetti-canvas');
      const ctx = canvas.getContext('2d');
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      const colors = ['#a855f7','#22d3ee','#e8a020','#40a858','#f8fafc','#a855f7'];
      const pieces = Array.from({length:90}, () => ({
        x: Math.random() * canvas.width,
        y: -20 - Math.random() * 250,
        w: 6 + Math.random() * 8,
        h: 3 + Math.random() * 5,
        r: Math.random() * Math.PI * 2,
        dr: (Math.random() - 0.5) * 0.14,
        vx: (Math.random() - 0.5) * 2.8,
        vy: 2.5 + Math.random() * 3.5,
        color: colors[Math.floor(Math.random() * colors.length)],
        alpha: 1
      }));
      const startTime = performance.now();
      function draw(now){
        ctx.clearRect(0,0,canvas.width,canvas.height);
        let alive = 0;
        const elapsed = now - startTime;
        for(const p of pieces){
          p.x += p.vx; p.y += p.vy; p.r += p.dr;
          if(elapsed > 2200) p.alpha = Math.max(0, p.alpha - 0.007);
          if(p.y < canvas.height + 20 && p.alpha > 0) alive++;
          ctx.save();
          ctx.globalAlpha = p.alpha;
          ctx.translate(p.x, p.y);
          ctx.rotate(p.r);
          ctx.fillStyle = p.color;
          ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
          ctx.restore();
        }
        if(alive > 0) requestAnimationFrame(draw);
        else canvas.style.display = 'none';
      }
      requestAnimationFrame(draw);
      window.addEventListener('resize', () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; });
    })();

    // SCROLL FADE
    const obs = new IntersectionObserver(e => e.forEach(x => {
      if(x.isIntersecting){x.target.style.opacity='1';x.target.style.transform='translateY(0)'}
    }), {threshold:.08});
    document.querySelectorAll('.tl-item,.order-card,.intake-box').forEach(el => {
      el.style.opacity='0'; el.style.transform='translateY(12px)'; el.style.transition='opacity .5s ease,transform .5s ease';
      obs.observe(el);
    });
  </script>
</Layout>

<style>
  #confetti-canvas { position: fixed; top: 0; left: 0; pointer-events: none; z-index: 99; }
  nav { position: sticky; top: 0; z-index: 100; border-bottom: 1px solid var(--border); background: rgba(5,5,5,0.9); backdrop-filter: blur(12px); }
  .nav-inner { max-width: 1100px; margin: 0 auto; padding: 1rem clamp(1.25rem,5vw,2.5rem); display: flex; align-items: center; justify-content: space-between; }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  .nav-logo-img {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    object-fit: cover;
  }
  .logo-text { font-family: var(--sans); font-weight: 900; font-size: 1.4rem; letter-spacing: -0.04em; color: var(--text); }
  .logo-text .built { background: linear-gradient(135deg, var(--accent-1), var(--accent-2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 400; }
  .logo-text .slug { font-family: var(--mono); font-size: 0.8rem; color: var(--text-dim); margin-left: 0.3rem; font-weight: 400; letter-spacing: 0.05em; }
  .nav-tag { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-1); border: 1px solid var(--accent-1); background: var(--accent-glow); padding: 0.3em 0.75em; }

  main { position: relative; z-index: 5; max-width: 600px; margin: 0 auto; padding: clamp(3rem,8vw,6rem) clamp(1.25rem,5vw,2.5rem); }
  .receipt-badge { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #40a858; background: rgba(64,168,88,0.1); border: 1px solid rgba(64,168,88,0.2); padding: 0.4em 0.8em; margin-bottom: 1.5rem; }
  .badge-dot { width: 6px; height: 6px; background: #40a858; border-radius: 50%; display: inline-block; animation: pulse 2s infinite; }
  @keyframes pulse { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); } }

  h1 { font-family: var(--serif); font-size: clamp(2.5rem,7vw,4.5rem); line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 1.25rem; color: var(--text); }
  h1 em { font-style: italic; color: var(--accent-1); }
  .sub { font-size: 1.05rem; color: var(--text-muted); line-height: 1.75; margin-bottom: 3rem; font-weight: 300; }

  .order-card { background: var(--bg-2); border: 1px solid var(--border-hi); padding: 1.5rem; margin-bottom: 3rem; }
  .order-row { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--border); }
  .order-row:last-child { border-bottom: none; }
  .order-label { font-family: var(--mono); font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05em; }
  .order-status { font-family: var(--mono); font-size: 0.75rem; color: #40a858; font-weight: 600; }
  .order-value { font-family: var(--mono); font-size: 0.75rem; color: var(--text-muted); font-weight: 500; }
  .order-value.amber { color: var(--amber); }
  .order-value.green { color: #40a858; }

  .tl-label { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 1.5rem; }
  .timeline { display: flex; flex-direction: column; gap: 0; margin-bottom: 4rem; }
  .tl-item { display: flex; gap: 1.5rem; padding-bottom: 2.5rem; position: relative; }
  .tl-item::after { content: ''; position: absolute; left: 11px; top: 24px; bottom: 0; width: 1px; background: var(--border); }
  .tl-item:last-child::after { display: none; }
  .tl-dot { width: 24px; height: 24px; border-radius: 50%; background: var(--bg-3); border: 1px solid var(--border-hi); display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 0.6rem; color: var(--text-dim); flex-shrink: 0; z-index: 2; position: relative; }
  .tl-item.done .tl-dot { background: #40a858; border-color: #40a858; color: #000; }
  .tl-item.active .tl-dot { background: var(--accent-1); border-color: var(--accent-1); color: #000; animation: activeDot 2s infinite; }
  @keyframes activeDot { 0%, 100% { box-shadow: 0 0 0 0 rgba(168,85,247,0.4); } 50% { box-shadow: 0 0 0 8px rgba(168,85,247,0); } }
  .tl-body h4 { font-family: var(--mono); font-size: 0.85rem; font-weight: 600; color: var(--text); margin-bottom: 0.3rem; }
  .tl-item.done h4 { color: var(--text-dim); }
  .tl-body p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; }
  .tl-time { font-family: var(--mono); font-size: 0.6rem; color: var(--text-dim); margin-top: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em; }

  .intake-box { background: var(--accent-glow); border: 1px solid var(--accent-1); padding: 2rem; margin-bottom: 3rem; position: relative; overflow: hidden; }
  .ib-label { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em; color: var(--accent-1); margin-bottom: 0.75rem; }
  .intake-box h3 { font-family: var(--serif); font-size: 1.5rem; margin-bottom: 0.5rem; }
  .intake-box h3 em { font-style: italic; color: var(--accent-1); }
  .intake-box p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem; max-width: 45ch; }
  .btn-intake { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--mono); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; text-decoration: none; padding: 0.8em 1.5em; background: #000; color: #fff; border: 1px solid var(--accent-1); transition: all 0.15s; }
  .btn-intake:hover { background: var(--accent-1); color: #000; }

  .back-link { font-family: var(--mono); font-size: 0.7rem; color: var(--text-dim); text-decoration: none; display: block; text-align: center; margin-top: 2rem; }
  .back-link:hover { color: var(--text-muted); }

  footer { padding: 2rem; text-align: center; font-family: var(--mono); font-size: 0.65rem; color: var(--text-dim); border-top: 1px solid var(--border); margin-top: 4rem; }
  footer a { color: inherit; text-decoration: none; margin: 0 0.5rem; }
  footer a:hover { color: var(--accent-1); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .f1 { animation: fadeUp .6s ease both; }
  .f2 { animation: fadeUp .6s .1s ease both; }
  .f3 { animation: fadeUp .6s .2s ease both; }
  .f4 { animation: fadeUp .6s .3s ease both; }
  .f6 { animation: fadeUp .6s .5s ease both; }
</style>
