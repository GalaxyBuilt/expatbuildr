---
// welcome.astro - Newsletter Welcome & Lead Magnet Unlock
import ExitIntentPopup from '../../components/ExitIntentPopup.astro';

// --- PRODUCTION CONFIGURATION ---
const TIKTOK_PIXEL_ID = 'D7EJNB3C77U1RGO04F1G';
const LINKEDIN_INSIGHT_ID = 'NNNNNNN';
const META_PIXEL_ID = '1480646753745240';
const GOOGLE_ANALYTICS_ID = 'G-SD1015FGKZ';
// --------------------------------
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow" />
  <title>Welcome to Galaxy Arbitrage — Unlock Your Job List</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Mono:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">

  <!-- ─── TikTok Pixel ─────────────────────────────────────────── -->
  <script is:inline define:vars={{ TIKTOK_PIXEL_ID }}>
    !function (w, d, t) {
      w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];
      ttq.methods=["page","track","identify","instances","debug","on","off","once",
      "ready","alias","group","enableCookie","disableCookie","holdConsent",
      "revokeConsent","grantConsent"],ttq.setAndDefer=function(t,e){t[e]=function(){
      t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};
      for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);
      ttq.instance=function(t){for(var e=ttq._i[t]||[],n=0;n<ttq.methods.length;n++)
      ttq.setAndDefer(e,ttq.methods[n]);return e},ttq.load=function(e,n){
      var r="https://analytics.tiktok.com/i18n/pixel/events.js",o=n&&n.partner;
      ttq._i=ttq._i||{},ttq._i[e]=[],ttq._i[e]._u=r,ttq._t=ttq._t||{},
      ttq._t[e]=+new Date,ttq._o=ttq._o||{},ttq._o[e]=n||{};n=document.createElement("script");
      n.type="text/javascript",n.async=!0,n.src=r+"?sdkid="+e+"&lib="+t;
      e=document.getElementsByTagName("script")[0];e.parentNode.insertBefore(n,e)};
      ttq.load(TIKTOK_PIXEL_ID); 
      ttq.page();
    }(window, document, 'ttq');
  </script>

  <!-- ─── Meta (Facebook/Instagram) Pixel ──────────────────────── -->
  <script is:inline define:vars={{ META_PIXEL_ID }}>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', META_PIXEL_ID); 
    fbq('track', 'PageView');
  </script>

  <!-- ─── LinkedIn Insight Tag ─────────────────────────────────── -->
  <script is:inline define:vars={{ LINKEDIN_INSIGHT_ID }}>
    _linkedin_partner_id = LINKEDIN_INSIGHT_ID; 
    window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
    window._linkedin_data_partner_ids.push(_linkedin_partner_id);
  </script>
  <script is:inline>
    (function(l) {
      if (!l){window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
      window.lintrk.q=[]}
      var s = document.getElementsByTagName("script")[0];
      var b = document.createElement("script");
      b.type = "text/javascript";b.async = true;
      b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
      s.parentNode.insertBefore(b, s);})(window.lintrk);
  </script>

  <!-- ─── Google Analytics (GA4) ────────────────────────────────── -->
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GOOGLE_ANALYTICS_ID}`}></script>
  <script is:inline define:vars={{ GOOGLE_ANALYTICS_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GOOGLE_ANALYTICS_ID);
    gtag('event', 'generate_lead', { event_category: 'newsletter', event_label: 'Welcome Page View' });
  </script>

  <!-- ─── Galaxy Lead Event Engine ──────────────────────────────── -->
  <script is:inline>
    window.trackLead = function(data={}) {
      if(window.gtag) gtag('event','generate_lead',{event_category:'engagement',event_label:data.label||'Lead',value:data.value||0});
      if(window.fbq) fbq('track','Lead',{value:data.value||0,currency:'USD'});
      if(window.ttq) ttq.track('CompletePayment',{value:data.value||0,currency:'USD'});
      if(window.lintrk) window.lintrk('track',{conversion_id:data.linkedin_cid||1234567});
    };
  </script>

  <style>
    :root {
      --bg:        #faf8f3;
      --bg-2:      #ffffff;
      --ink:       #0d0d0d;
      --gold:      #b8943f;
      --gold-light:#d4aa58;
      --gold-pale: #f7f0de;
      --gold-dim:  #e8d9b0;
      --green:     #0f7a3e;
      --green-bg:  #eef7f2;
      --green-dim: #c8e8d8;
      --muted:     #6b6458;
      --border:    #e4ddd0;
      --border-hi: #cfc5b0;
      --serif:     'DM Serif Display', Georgia, serif;
      --mono:      'IBM Plex Mono', monospace;
      --sans:      'DM Sans', system-ui, sans-serif;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.6;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* SUBTLE PAPER TEXTURE */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    /* GOLD GRADIENT TOP ACCENT */
    .top-accent {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
      z-index: 100;
    }

    /* NAV */
    nav {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 40px;
      border-bottom: 1px solid var(--border);
      background: rgba(250,248,243,0.9);
      backdrop-filter: blur(10px);
    }
    .nav-logo {
      font-family: var(--serif);
      font-size: 20px;
      color: var(--ink);
      text-decoration: none;
      letter-spacing: -0.02em;
    }
    .nav-logo em { color: var(--gold); font-style: italic; }
    .nav-right {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted);
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    /* MAIN */
    main {
      position: relative;
      z-index: 1;
      max-width: 680px;
      margin: 0 auto;
      padding: 72px 24px 100px;
    }

    /* WELCOME BADGE */
    .welcome-badge {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 36px;
      animation: popIn 0.5s cubic-bezier(0.175,0.885,0.32,1.275) both;
    }
    .welcome-circle {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: var(--gold-pale);
      border: 2px solid var(--gold-dim);
      display: flex; align-items: center; justify-content: center;
      font-size: 30px;
      position: relative;
    }
    .welcome-circle::after {
      content: '';
      position: absolute;
      inset: -6px;
      border-radius: 50%;
      border: 1px solid var(--gold-dim);
      opacity: 0.5;
      animation: ringPulse 2s ease infinite;
    }
    @keyframes popIn {
      from { opacity:0; transform: scale(0.6); }
      to   { opacity:1; transform: scale(1); }
    }
    @keyframes ringPulse {
      0%,100% { transform: scale(1); opacity: 0.5; }
      50%     { transform: scale(1.15); opacity: 0; }
    }

    /* HEADLINE BLOCK */
    .headline-block {
      text-align: center;
      margin-bottom: 48px;
      animation: fadeUp 0.6s ease 0.15s both;
    }
    .welcome-label {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--gold);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .welcome-label::before,
    .welcome-label::after {
      content: '';
      display: block;
      width: 32px; height: 1px;
      background: var(--gold-dim);
    }
    h1 {
      font-family: var(--serif);
      font-size: clamp(32px, 5vw, 52px);
      line-height: 1.08;
      color: var(--ink);
      margin-bottom: 16px;
      letter-spacing: -0.02em;
    }
    h1 em { font-style: italic; color: var(--gold); }
    .headline-sub {
      font-size: 16px;
      color: var(--muted);
      font-weight: 300;
      line-height: 1.7;
      max-width: 46ch;
      margin: 0 auto;
    }

    /* REWARD CARD */
    .reward-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 32px;
      animation: fadeUp 0.6s ease 0.2s both;
      box-shadow: 0 2px 20px rgba(0,0,0,0.04);
    }
    .reward-card-header {
      background: var(--gold-pale);
      border-bottom: 1px solid var(--gold-dim);
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .reward-card-title {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--gold);
      letter-spacing: 2.5px;
      text-transform: uppercase;
    }
    .reward-value {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--green);
      letter-spacing: 1px;
      background: var(--green-bg);
      padding: 4px 10px;
      border-radius: 20px;
    }
    .reward-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 24px;
      border-bottom: 1px solid var(--border);
    }
    .reward-row:last-child { border-bottom: none; }
    .reward-item-name {
      font-size: 15px;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 3px;
    }
    .reward-item-desc {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.5px;
    }
    .reward-badge {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--green);
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    /* SOCIAL CARDS */
    .social-section {
      margin-bottom: 24px;
      animation: fadeUp 0.6s ease 0.3s both;
    }
    .social-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 16px;
      transition: all 0.2s;
    }
    .social-card.completed {
      border-color: var(--green-dim);
      background: var(--green-bg);
    }
    .social-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 24px;
      gap: 16px;
      flex-wrap: wrap;
    }
    .social-info {
      flex: 1;
    }
    .social-info h3 {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 500;
      margin-bottom: 4px;
    }
    .social-info p {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.5px;
    }
    .btn-social {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      border-radius: 8px;
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
    }
    .btn-x {
      background: #000;
      color: #fff;
    }
    .btn-x:hover {
      background: #1a1a1a;
      transform: translateY(-1px);
    }
    .btn-yt {
      background: #ff0000;
      color: #fff;
    }
    .btn-yt:hover {
      background: #cc0000;
      transform: translateY(-1px);
    }
    .btn-social.done {
      background: var(--green);
      cursor: default;
      opacity: 0.8;
      transform: none;
    }
    .btn-social.done:hover {
      transform: none;
    }

    /* UNLOCK CARD */
    .unlock-card {
      background: linear-gradient(135deg, var(--ink) 0%, #1a1a1a 100%);
      border-radius: 14px;
      padding: 32px 28px;
      margin-bottom: 24px;
      position: relative;
      overflow: hidden;
      animation: fadeUp 0.6s ease 0.4s both;
      display: none;
    }
    .unlock-card.visible {
      display: block;
    }
    .unlock-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
    }
    .unlock-card::after {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 220px; height: 220px;
      background: radial-gradient(ellipse, rgba(184,148,63,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .unlock-label {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--gold);
      letter-spacing: 2.5px;
      text-transform: uppercase;
      margin-bottom: 16px;
      opacity: 0.8;
    }
    .unlock-card h2 {
      font-family: var(--serif);
      font-size: clamp(22px, 3vw, 30px);
      color: #fff;
      line-height: 1.15;
      margin-bottom: 12px;
      font-style: italic;
    }
    .unlock-card p {
      font-size: 14px;
      color: rgba(255,255,255,0.5);
      line-height: 1.65;
      margin-bottom: 24px;
      font-weight: 300;
    }
    .btn-unlock {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 28px;
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      color: #000;
      border: none;
      border-radius: 8px;
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: filter 0.2s, transform 0.15s;
      letter-spacing: 0.2px;
    }
    .btn-unlock:hover { filter: brightness(1.08); transform: translateY(-1px); }

    /* SKIP BUTTON */
    .skip-wrapper {
      text-align: center;
      margin: 8px 0 24px;
    }
    .btn-skip {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 1px;
      cursor: pointer;
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s;
      border: none;
      background: none;
    }
    .btn-skip:hover { color: var(--gold); }

    /* DOWNLOAD STEP */
    .download-step {
      display: none;
      text-align: center;
      animation: fadeUp 0.6s ease both;
    }
    .download-step h1 {
      margin-bottom: 16px;
    }
    .download-step p {
      color: var(--muted);
      margin-bottom: 32px;
    }
    .loader {
      margin: 0 auto 40px;
      width: 48px;
      height: 48px;
      border: 3px solid var(--cream, #e4ddd0);
      border-top: 3px solid var(--gold);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    .fallback-note {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      margin-top: 24px;
    }
    .fallback-note a {
      color: var(--gold);
      text-decoration: underline;
    }

    /* FOOTER */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      padding: 24px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 60px;
    }
    .footer-brand {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }
    .footer-brand em { color: var(--gold); font-style: normal; }
    .footer-links {
      display: flex;
      gap: 20px;
      list-style: none;
    }
    .footer-links a {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 1px;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--gold); }

    @keyframes fadeUp {
      from { opacity:0; transform:translateY(18px); }
      to   { opacity:1; transform:translateY(0); }
    }

    @media (max-width: 600px) {
      nav { padding: 16px 20px; }
      main { padding: 48px 16px 80px; }
      footer { padding: 20px; flex-direction: column; text-align: center; }
      .social-row { flex-direction: column; align-items: stretch; text-align: center; }
      .btn-social { justify-content: center; }
    }
  </style>
</head>
<body>

<div class="top-accent"></div>

<!-- NAV -->
  <script is:inline>
    (()=>{ document.documentElement.classList.add('dark'); document.documentElement.classList.remove('light'); })();
  </script>

  <nav>
  <a href="/" class="nav-logo">Galaxy <em>Arbitrage</em></a>
  <div class="nav-right">Welcome  ✦</div>
</nav>

<main>

  <!-- WELCOME BADGE -->
  <div class="welcome-badge">
    <div class="welcome-circle">✦</div>
  </div>

  <!-- HEADLINE -->
  <div class="headline-block">
    <div class="welcome-label">You're on the list</div>
    <h1>Welcome to <em>Galaxy Arbitrage</em></h1>
    <p class="headline-sub">
      Your weekly remote income intelligence just arrived. One last thing — unlock your free job list below.
    </p>
  </div>

  <!-- REWARD CARD -->
  <div class="reward-card">
    <div class="reward-card-header">
      <div class="reward-card-title">// Your welcome gift</div>
      <div class="reward-value">Free Download</div>
    </div>
    <div class="reward-row">
      <div>
        <div class="reward-item-name">Remote Jobs Master List (50+ roles)</div>
        <div class="reward-item-desc">USD-paying remote positions · Updated weekly · Pre-vetted</div>
      </div>
      <div class="reward-badge">$0 value</div>
    </div>
  </div>

  <!-- SOCIAL REQUIREMENT SECTION -->
  <div id="social-step">
    <div class="social-section">
      <div class="social-card" id="x-card">
        <div class="social-row">
          <div class="social-info">
            <h3>Follow on X</h3>
            <p>@expatbuildr — daily remote income workflows</p>
          </div>
          <button id="x-follow-btn" class="btn-social btn-x">
            <span>𝕏</span> Follow
          </button>
        </div>
      </div>

      <div class="social-card" id="yt-card">
        <div class="social-row">
          <div class="social-info">
            <h3>Subscribe on YouTube</h3>
            <p>Watch me build these systems live</p>
          </div>
          <button id="yt-follow-btn" class="btn-social btn-yt">
            <span>▶</span> Subscribe
          </button>
        </div>
      </div>
    </div>

    <!-- UNLOCK CARD (appears after at least one social action) -->
    <div id="unlock-card" class="unlock-card">
      <div class="unlock-label">// Ready for your reward</div>
      <h2>Your job list is <em>waiting</em></h2>
      <p>One click and the PDF will start downloading. You'll also be redirected to the full job directory.</p>
      <button id="download-unlock-btn" class="btn-unlock">Unlock & Download →</button>
    </div>

    <!-- SKIP BUTTON -->
    <div class="skip-wrapper">
      <button id="skip-follow-btn" class="btn-skip">Skip — take me to my download</button>
    </div>
  </div>

  <!-- DOWNLOAD STEP (shown after unlock is triggered) -->
  <div id="download-step" class="download-step">
    <h1>Your PDF is <em>downloading...</em></h1>
    <p>Redirecting you to the full job directory in <span id="timer">3</span> seconds.</p>
    <div class="loader"></div>
    <div class="fallback-note" id="fallback-note" style="display: none;">
      Download didn't start? <a href="/downloads/50-job-report.pdf" download="50-Job-Report-ExpatBuildr.pdf">Click here to manually download</a>
    </div>
  </div>

</main>

<ExitIntentPopup telegramMode={true} />

<footer>
  <div class="footer-brand">Galaxy<em>Arbitrage</em> · Built in the Philippines 🇵🇭</div>
  <ul class="footer-links">
    <li><a href="/">Home</a></li>
    <li><a href="https://x.com/expatbuildr">X / Twitter</a></li>
    <li><a href="https://www.youtube.com/@expatbuildr">YouTube</a></li>
  </ul>
</footer>

<script is:inline>
  // Fire lead pixel on page load
  if (window.trackLead) {
    window.trackLead({ label: 'Newsletter Welcome', value: 0 });
  }

  // DOM Elements
  const xCard = document.getElementById('x-card');
  const ytCard = document.getElementById('yt-card');
  const xBtn = document.getElementById('x-follow-btn');
  const ytBtn = document.getElementById('yt-follow-btn');
  const skipBtn = document.getElementById('skip-follow-btn');
  const unlockCard = document.getElementById('unlock-card');
  const unlockBtn = document.getElementById('download-unlock-btn');
  const socialStep = document.getElementById('social-step');
  const downloadStep = document.getElementById('download-step');
  const fallbackNote = document.getElementById('fallback-note');
  const timerDisplay = document.getElementById('timer');

  let socialCompleted = false;

  function markSocialCompleted(btn, card) {
    if (btn.classList.contains('done')) return;
    btn.classList.add('done');
    btn.innerHTML = btn.innerHTML.includes('Follow') ? '✓ Followed' : '✓ Subscribed';
    btn.disabled = true;
    card.classList.add('completed');
    
    if (!socialCompleted) {
      socialCompleted = true;
      // Show unlock card
      unlockCard.classList.add('visible');
      // Smooth scroll to unlock card
      setTimeout(() => {
        unlockCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    }
  }

  // X button click
  if (xBtn) {
    xBtn.addEventListener('click', (e) => {
      e.preventDefault();
      window.open('https://x.com/expatbuildr', '_blank');
      markSocialCompleted(xBtn, xCard);
    });
  }

  // YouTube button click
  if (ytBtn) {
    ytBtn.addEventListener('click', (e) => {
      e.preventDefault();
      window.open('https://www.youtube.com/@expatbuildr?sub_confirmation=1', '_blank');
      markSocialCompleted(ytBtn, ytCard);
    });
  }

  // Unlock button click
  if (unlockBtn) {
    unlockBtn.addEventListener('click', () => {
      startBridge();
    });
  }

  // Skip button click
  if (skipBtn) {
    skipBtn.addEventListener('click', () => {
      startBridge();
    });
  }

  function startBridge() {
    console.log('Galaxy Bridge: Handshake Initiated — Unlocking Lead Magnet');
    
    // Fire lead conversion pixel
    if (window.trackLead) {
      window.trackLead({ label: 'Lead Magnet Unlocked', value: 50 });
    }
    
    // Hide social step and show download step
    if (socialStep) socialStep.style.display = 'none';
    if (downloadStep) downloadStep.style.display = 'block';

    // Trigger PDF download after short delay
    setTimeout(() => {
      try {
        const link = document.createElement('a');
        link.href = '/downloads/50-job-report.pdf';
        link.download = '50-Job-Report-ExpatBuildr.pdf';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        console.log('✓ PDF Download Signal Sent');
        if (fallbackNote) fallbackNote.style.display = 'block';
      } catch (e) {
        console.error('❌ PDF Download Trigger Failed', e);
        if (fallbackNote) fallbackNote.style.display = 'block';
      }
    }, 500);

    // Countdown and redirect to job directory
    let seconds = 3;
    const countdown = setInterval(() => {
      seconds--;
      if (timerDisplay) timerDisplay.textContent = seconds;
      if (seconds <= 0) {
        clearInterval(countdown);
        console.log('🚀 Redirecting to job directory...');
        window.location.href = '/geo-arbitrage/job';
      }
    }, 1000);
  }
</script>

</body>
</html>
