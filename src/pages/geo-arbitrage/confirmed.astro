<!-- ─── Galaxy Event Engine + Purchase Event (HIGHEST INTENT) ── -->
<script is:inline>
  window.trackLead = function(data={}) {
    if(window.gtag) gtag('event','generate_lead',{event_category:'engagement',event_label:data.label||'Lead',value:data.value||0});
    if(window.fbq) fbq('track','Lead',{value:data.value||0,currency:'USD'});
    if(window.ttq) ttq.track('CompletePayment',{value:data.value||50,currency:'USD'});
    if(window.rdt) rdt('track','Lead');
    if(window.lintrk) window.lintrk('track',{conversion_id:data.linkedin_cid||1234567});
  };
  // Fire Purchase event — highest intent signal on the site
  window.addEventListener('load', () => {
    if(window.gtag) gtag('event','purchase',{event_category:'ecommerce',event_label:'Stripe Confirmation'});
    if(window.fbq) fbq('track','Purchase',{value:97.00,currency:'USD'});
    if(window.ttq) ttq.track('CompletePayment',{value:97.00,currency:'USD'});
    if(window.rdt) rdt('track','Purchase');
  });
</script>

<style>
  :root {
    --bg:        #faf8f3;
    --bg-2:      #ffffff;
    --ink:       #0d0d0d;
    --gold:      #b8943f;
    --gold-light:#d4aa58;
    --gold-pale: #f7f0de;
    --gold-dim:  #e8d9b0;
    --green:     #0f7a3e;
    --green-bg:  #eef7f2;
    --green-dim: #c8e8d8;
    --muted:     #6b6458;
    --border:    #e4ddd0;
    --border-hi: #cfc5b0;
    --serif:     'DM Serif Display', Georgia, serif;
    --mono:      'IBM Plex Mono', monospace;
    --sans:      'DM Sans', system-ui, sans-serif;
  }

  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* SUBTLE PAPER TEXTURE */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  /* GOLD GRADIENT TOP ACCENT */
  .top-accent {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
    z-index: 100;
  }

  /* NAV */
  nav {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 40px;
    border-bottom: 1px solid var(--border);
    background: rgba(250,248,243,0.9);
    backdrop-filter: blur(10px);
  }
  .nav-logo {
    font-family: var(--serif);
    font-size: 20px;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .nav-logo em { color: var(--gold); font-style: italic; }
  .nav-right {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* MAIN */
  main {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    padding: 72px 24px 100px;
  }

  /* CONFIRMATION BADGE */
  .confirm-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 36px;
    animation: popIn 0.5s cubic-bezier(0.175,0.885,0.32,1.275) both;
  }
  .confirm-circle {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: var(--green-bg);
    border: 2px solid var(--green-dim);
    display: flex; align-items: center; justify-content: center;
    font-size: 30px;
    position: relative;
  }
  .confirm-circle::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid var(--green-dim);
    opacity: 0.5;
    animation: ringPulse 2s ease infinite;
  }
  @keyframes popIn {
    from { opacity:0; transform: scale(0.6); }
    to   { opacity:1; transform: scale(1); }
  }
  @keyframes ringPulse {
    0%,100% { transform: scale(1); opacity: 0.5; }
    50%     { transform: scale(1.15); opacity: 0; }
  }

  /* HEADLINE BLOCK */
  .headline-block {
    text-align: center;
    margin-bottom: 48px;
    animation: fadeUp 0.6s ease 0.15s both;
  }
  .confirm-label {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--green);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .confirm-label::before,
  .confirm-label::after {
    content: '';
    display: block;
    width: 32px; height: 1px;
    background: var(--green-dim);
  }
  h1 {
    font-family: var(--serif);
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.08;
    color: var(--ink);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  h1 em { font-style: italic; color: var(--gold); }
  .headline-sub {
    font-size: 16px;
    color: var(--muted);
    font-weight: 300;
    line-height: 1.7;
    max-width: 46ch;
    margin: 0 auto;
  }

  /* ORDER CARD */
  .order-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 24px;
    animation: fadeUp 0.6s ease 0.25s both;
    box-shadow: 0 2px 20px rgba(0,0,0,0.04);
  }
  .order-card-header {
    background: var(--gold-pale);
    border-bottom: 1px solid var(--gold-dim);
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .order-card-title {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--gold);
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }
  .order-id {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 1px;
  }
  .order-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
  }
  .order-row:last-child { border-bottom: none; }
  .order-item-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 3px;
  }
  .order-item-desc {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.5px;
  }
  .order-price {
    font-family: var(--serif);
    font-size: 24px;
    color: var(--ink);
    font-style: italic;
  }
  .order-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--green);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .status-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: blink 2s ease infinite;
  }
  @keyframes blink {
    0%,100% { opacity:1; } 50% { opacity:0.4; }
  }

  /* NEXT STEPS */
  .next-steps {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 24px;
    animation: fadeUp 0.6s ease 0.35s both;
    box-shadow: 0 2px 20px rgba(0,0,0,0.04);
  }
  .next-header {
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }
  .step-row {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }
  .step-row:last-child { border-bottom: none; }
  .step-row:hover { background: var(--bg); }
  .step-num {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--gold-pale);
    border: 1px solid var(--gold-dim);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--gold);
    flex-shrink: 0;
  }
  .step-content {}
  .step-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .step-detail {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.55;
  }
  .step-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 3px;
    margin-top: 6px;
  }
  .tag-now  { background: var(--green-bg); color: var(--green); }
  .tag-soon { background: var(--gold-pale); color: var(--gold); }

  /* UPSELL CARD */
  .upsell {
    background: var(--ink);
    border-radius: 14px;
    padding: 32px 28px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
    animation: fadeUp 0.6s ease 0.45s both;
  }
  .upsell::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
  }
  .upsell::after {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    background: radial-gradient(ellipse, rgba(184,148,63,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .upsell-label {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--gold);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
    opacity: 0.8;
  }
  .upsell h2 {
    font-family: var(--serif);
    font-size: clamp(22px, 3vw, 30px);
    color: #fff;
    line-height: 1.15;
    margin-bottom: 12px;
    font-style: italic;
  }
  .upsell-sub {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.65;
    margin-bottom: 24px;
    font-weight: 300;
    max-width: 44ch;
  }
  .upsell-features {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
  }
  .upsell-feat {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,0.7);
  }
  .feat-check {
    width: 16px; height: 16px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    display: flex; align-items: center; justify-content: center;
    font-size: 8px;
    color: #000;
    font-weight: 700;
    flex-shrink: 0;
  }
  .upsell-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .btn-upsell {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 24px;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: #000;
    border: none;
    border-radius: 8px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: filter 0.2s, transform 0.15s;
    letter-spacing: 0.2px;
  }
  .btn-upsell:hover { filter: brightness(1.08); transform: translateY(-1px); }
  .upsell-skip {
    font-family: var(--mono);
    font-size: 10px;
    color: rgba(255,255,255,0.25);
    letter-spacing: 1px;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
    border: none;
    background: none;
  }
  .upsell-skip:hover { color: rgba(255,255,255,0.5); }
  .upsell-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 20px;
  }
  .price-amount {
    font-family: var(--serif);
    font-size: 36px;
    color: var(--gold-light);
    font-style: italic;
  }
  .price-was {
    font-family: var(--mono);
    font-size: 11px;
    color: rgba(255,255,255,0.25);
    text-decoration: line-through;
    letter-spacing: 1px;
  }
  .price-save {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--gold);
    letter-spacing: 1px;
    background: rgba(184,148,63,0.15);
    padding: 2px 7px;
    border-radius: 3px;
    text-transform: uppercase;
  }

  /* SHARE / COMMUNITY */
  .community {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px 24px;
    animation: fadeUp 0.6s ease 0.55s both;
    box-shadow: 0 2px 20px rgba(0,0,0,0.04);
  }
  .community-label {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .community h3 {
    font-family: var(--serif);
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 8px;
    font-style: italic;
  }
  .community p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 20px;
    max-width: 46ch;
  }
  .share-btns {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 16px;
    border: 1px solid var(--border-hi);
    border-radius: 7px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    background: transparent;
    cursor: pointer;
  }
  .share-btn:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-pale); }

  /* FOOTER */
  footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    padding: 24px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 60px;
  }
  .footer-brand {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .footer-brand em { color: var(--gold); font-style: normal; }
  .footer-links {
    display: flex;
    gap: 20px;
    list-style: none;
  }
  .footer-links a {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--gold); }

  /* ANIM */
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(18px); }
    to   { opacity:1; transform:translateY(0); }
  }

  /* MOBILE */
  @media (max-width: 600px) {
    nav { padding: 16px 20px; }
    main { padding: 48px 16px 80px; }
    footer { padding: 20px; }
    .order-card-header { flex-direction: column; gap: 4px; align-items: flex-start; }
    .upsell-actions { flex-direction: column; align-items: flex-start; }
  }
</style>

<!-- PIXEL BLOCK — fires on page load = confirmed buyer event -->
<!-- Meta / Facebook Pixel -->
