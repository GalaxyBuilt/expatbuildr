  <script is:inline>
    // Shared Signup Logic for ArbJobs
    async function handleSignup(formId, emailId, submitId, successId, errorId, tag) {
      const form = document.getElementById(formId);
      const emailInput = document.getElementById(emailId);
      const submitBtn = document.getElementById(submitId);
      const successDiv = document.getElementById(successId);
      const errorMsg = document.getElementById(errorId);

      if (!form) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = emailInput.value.trim();
        
        if (!isValidEmail(email)) {
            errorMsg.classList.remove('hidden');
            errorMsg.textContent = '[ ERROR: INVALID_EMAIL ]';
            return;
        }

        submitBtn.disabled = true;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = 'Verifying...';
        errorMsg.classList.add('hidden');

        try {
            const success = await subscribeToBeehiiv({
                email,
                tags: ["arb_jobs", "jobs_list", "remote worker", "job seeker"],
                utm_medium: 'arbjobs_page',
                utm_campaign: 'remote_jobs_list'
            });

            if (success === true) {
              form.classList.add('hidden');
              successDiv.classList.remove('hidden');
              
              // Redirect to welcome page instead of auto-download
              window.location.href = '/geo-arbitrage/welcome';
            } else if (success === "already_subscribed") {
              errorMsg.classList.remove('hidden');
              errorMsg.textContent = '[ ERROR: ALREADY_SUBSCRIBED ]';
              submitBtn.disabled = false;
              submitBtn.innerText = originalText;
            } else {
              throw new Error("Subscription failed");
            }
        } catch (err) {
            console.error('Signup error:', err);
            errorMsg.classList.remove('hidden');
            errorMsg.textContent = '[ ERROR: CONNECTION_FAILED ]';
            submitBtn.disabled = false;
            submitBtn.innerText = originalText;
        }
      });
    }

    // Initialize both forms
    handleSignup('hero-signup-form', 'hero-email', 'hero-submit-btn', 'hero-success', 'hero-error', 'arbjobs_hero');
    handleSignup('footer-signup-form', 'footer-email', 'footer-submit-btn', 'footer-success', 'footer-error', 'arbjobs_footer');
  </script>

