<script is:inline>
  const form = document.getElementById('subscribe-form');
  const btn = document.getElementById('submit-btn');
  const msg = document.getElementById('form-message');

  async function handleSubmit(emailVal, btnEl, msgEl) {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(emailVal)) {
      msgEl.innerText = '❌ Please enter a valid email address.';
      msgEl.classList.remove('hidden');
      return;
    }
    btnEl.disabled = true;
    btnEl.innerText = 'Joining...';
    msgEl.innerText = '';
    msgEl.classList.add('hidden');
    try {
      const response = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: emailVal, source: 'web', magnet: 'geo-arbitrage-starter-kit', tags: ['founder'] })
      });
      const data = await response.json();
      if (data.success) {
        if (window.fireLeadEvent) window.fireLeadEvent();
        btnEl.innerText = 'Redirecting...';
        window.location.href = data.redirect_url;
      } else {
        btnEl.disabled = false;
        btnEl.innerText = 'Join Free';
        msgEl.innerText = '❌ ' + (data.error || 'Error, try again.');
        msgEl.classList.remove('hidden');
      }
    } catch (err) {
      btnEl.disabled = false;
      btnEl.innerText = 'Join Free';
      msgEl.innerText = '❌ Network error.';
      msgEl.classList.remove('hidden');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    await handleSubmit(document.getElementById('email').value.trim(), btn, msg);
  });

  document.getElementById('subscribe-form-bottom')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    await handleSubmit(
      document.getElementById('email-bottom').value.trim(),
      document.getElementById('submit-btn-bottom'),
      document.getElementById('form-message-bottom')
    );
  });
</script>