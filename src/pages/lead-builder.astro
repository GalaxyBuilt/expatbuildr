<script>
(function(){const c=document.getElementById('stars');for(let i=0;i<80;i++){const s=document.createElement('div');s.className='star';const sz=Math.random()*2+0.5;s.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--op:${Math.random()*0.4+0.1};--d:${Math.random()*4+2}s;--delay:-${Math.random()*4}s;`;c.appendChild(s);}})();
const steps=[document.getElementById('step1'),document.getElementById('step2'),document.getElementById('step3'),document.getElementById('step4'),document.getElementById('step5')];
function updateProgress(){const scrollY=window.scrollY+window.innerHeight/2;let current=0;steps.forEach((s,i)=>{if(s&&scrollY>s.offsetTop)current=i;});for(let i=0;i<5;i++){const dot=document.getElementById(`pd${i+1}`);const label=document.getElementById(`pl${i+1}`);dot.classList.remove('active','done');label.classList.remove('active');if(i<current){dot.classList.add('done');}else if(i===current){dot.classList.add('active');label.classList.add('active');}}}
window.addEventListener('scroll',updateProgress);
function scrollToStep(n){const el=document.getElementById(`step${n}`);if(el)el.scrollIntoView({behavior:'smooth',block:'start'});}
const observer=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.1});
document.querySelectorAll('.fade-up').forEach(el=>observer.observe(el));
async function handleSubmit(e){e.preventDefault();const email=document.getElementById('email-input').value;const btn=document.getElementById('submit-btn');const status=document.getElementById('form-status');btn.textContent='Joining...';btn.disabled=true;try{const res=await fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,source:'web',magnet:'prompt-vault',tags:['lead_builder']})});const data=await res.json();if(data.success){document.getElementById('email-form').innerHTML='<p style="color:#00e9a3;font-weight:800;font-size:0.95rem;">✓ You\'re in — your Prompt Vault is on the way.</p>';localStorage.setItem('gb_email',email);localStorage.setItem('gb_persona','lead-builder');localStorage.setItem('gb_subscribed','1');unlockDownloads();if(typeof fbq!=='undefined'){fbq('track','Lead');fbq('trackCustom','PersonaSubscribed',{persona:'lead-builder'});}if(typeof gtag!=='undefined'){gtag('event','persona_subscribed',{persona:'lead-builder'});}setTimeout(()=>scrollToStep(3),1500);}else{throw new Error(data.error);}}catch{btn.textContent='Join Free';btn.disabled=false;status.textContent='Something went wrong — try again.';status.style.color='#ff6b35';status.style.display='block';}}
function calcROI(){const hours=parseFloat(document.getElementById('hours').value)||0;const rate=parseFloat(document.getElementById('rate').value)||0;if(hours&&rate){const weeklyWaste=hours*rate;const annualWaste=weeklyWaste*52;const systemCost=5000;const annualSavings=annualWaste-systemCost;const result=document.getElementById('roi-result');result.style.display='block';result.innerHTML=`You're spending <strong style="color:#fff">$${weeklyWaste.toLocaleString()}/week</strong> ($${annualWaste.toLocaleString()}/yr) on manual outreach. An automated system costs ~$5,000/yr and reclaims all of it. <strong style="color:#00e9a3">Net annual savings: $${Math.max(0,annualSavings).toLocaleString()}</strong>.`;}}
function unlockDownloads(){const d1=document.getElementById('main-download');const d2=document.getElementById('bonus-download');if(d1){d1.style.opacity='1';d1.style.pointerEvents='auto';}if(d2){d2.style.opacity='1';d2.style.pointerEvents='auto';}}
if(localStorage.getItem('gb_subscribed')==='1'){unlockDownloads();}
const savedAnswers=JSON.parse(localStorage.getItem('gb_quiz_builder')||'{}');
const answers=Object.assign({},savedAnswers);
Object.entries(answers).forEach(([qId,val])=>{document.querySelectorAll(`#${qId} .quiz-opt`).forEach(o=>{if(o.getAttribute('onclick')&&o.getAttribute('onclick').includes(`'${val}'`))o.classList.add('selected');});});
if(Object.keys(answers).length>=3){const btn=document.getElementById('result-btn');if(btn){btn.style.opacity='1';btn.style.pointerEvents='auto';}}
function selectOpt(qId,el,val){document.querySelectorAll(`#${qId} .quiz-opt`).forEach(o=>o.classList.remove('selected'));el.classList.add('selected');answers[qId]=val;localStorage.setItem('gb_quiz_builder',JSON.stringify(answers));if(Object.keys(answers).length>=3){const btn=document.getElementById('result-btn');btn.style.opacity='1';btn.style.pointerEvents='auto';}}
function generateResult(){localStorage.setItem('gb_quiz_builder',JSON.stringify(answers));if(typeof fbq!=='undefined'){fbq('trackCustom','PersonaQuizCompleted',{persona:'lead-builder'});}if(typeof gtag!=='undefined'){gtag('event','persona_quiz_completed',{persona:'lead-builder'});}const results={manual:{title:'Start with the grant cheatsheet — then build the pipeline',desc:'Manual outreach is leaving money on the table. The grants fund the automation build.',links:[{text:'How to Replace Manual Outreach With AI',url:'/blog'},{text:'The $60K Role We Replaced for $5K',url:'/blog'},{text:'Download the Prompt Vault — Free',url:'/downloads/prompt-vault?ref=quiz'}]},scaling:{title:'You have the foundation — time to scale without hiring',desc:'A working system just needs the right multipliers. Here\'s how to 10x output without headcount.',links:[{text:'Scaling Lead Gen Without Scaling Your Team',url:'/blog'},{text:'Multi-Agent Outreach Architecture',url:'/blog'},{text:'Explore GalaxyLeads',url:'/lead-gen/edge'}]},broken:{title:'Fix the foundation before you scale',desc:'A broken system that scales just breaks louder. Here\'s how to diagnose and fix the core issue.',links:[{text:'The 5 Most Common Pipeline Breakdowns',url:'/blog'},{text:'How to Audit Your Current Lead Gen System',url:'/blog'},{text:'GalaxyLeads — Full Rebuild Option',url:'/lead-gen/edge'}]},partial:{title:'Close the automation gaps — one system at a time',desc:'Partial automation still has manual bottlenecks bleeding time. Here\'s where to plug them.',links:[{text:'Which Parts of Lead Gen to Automate First',url:'/blog'},{text:'The Make.com + Claude Lead Gen Stack',url:'/blog'},{text:'Automation System — Done For You',url:'/automation-systems/automation'}]}};
const r=results[answers.q1]||results.manual;document.getElementById('result-title').textContent=r.title;document.getElementById('result-desc').textContent=r.desc;document.getElementById('result-links').innerHTML=r.links.map(l=>`<a class="result-link" href="${l.url}">${l.text}</a>`).join('');document.getElementById('result-card').classList.add('show');setTimeout(()=>scrollToStep(4),800);}

function copyCode(){navigator.clipboard.writeText('BUILDER20').then(()=>{document.getElementById('copy-confirm').style.display='block';document.getElementById('discount-chip').style.borderColor='#00e9a3';if(typeof fbq!=='undefined'){fbq('trackCustom','PersonaDiscountCopied',{persona:'lead-builder'});}if(typeof gtag!=='undefined'){gtag('event','persona_discount_copied',{persona:'lead-builder'});}setTimeout(()=>{document.getElementById('copy-confirm').style.display='none';document.getElementById('discount-chip').style.borderColor='';},2500);});}
function fireDownloadPixel(){if(typeof fbq!=='undefined'){fbq('trackCustom','PersonaDownload',{persona:'lead-builder',magnet:'prompt-vault'});}if(typeof gtag!=='undefined'){gtag('event','persona_download',{persona:'lead-builder',magnet:'prompt-vault'});}}
</script>
