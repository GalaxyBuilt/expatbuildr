---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="ExpatBuildr — YouTube Outlier Architecture" minimal={true}>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>
  <div class="min-h-screen bg-[#080808] text-[#e8e8e8] font-['DM_Sans'] overflow-x-hidden">
    <style is:inline>
      :root {
        --black: #080808;
        --surface: #111111;
        --surface2: #191919;
        --border: #242424;
        --text: #e8e8e8;
        --muted: #666;
        --dim: #444;

        --p1: #FFD166; /* Remote Income - amber */
        --p2: #06D6A0; /* Lead Gen - mint */
        --p3: #EF476F; /* Geo-Arbitrage - coral */
        --p4: #118AB2; /* Grants - blue */

        --p1-dim: rgba(255,209,102,0.08);
        --p2-dim: rgba(6,214,160,0.08);
        --p3-dim: rgba(239,71,111,0.08);
        --p4-dim: rgba(17,138,178,0.08);
      }

      /* ── HEADER ── */
      header {
        border-bottom: 1px solid var(--border);
        padding: 32px 48px 28px;
        display: flex;
        align-items: flex-end;
        gap: 32px;
        flex-wrap: wrap;
        background: linear-gradient(135deg, #0e0e0e 60%, #141212);
      }

      .logo-block h1 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 42px;
        letter-spacing: 3px;
        line-height: 1;
        background: linear-gradient(90deg, #FFD166 0%, #EF476F 50%, #118AB2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .logo-block p {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-top: 4px;
      }

      .header-meta {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-left: auto;
      }

      .meta-chip {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        padding: 6px 12px;
        border-radius: 4px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--muted);
        letter-spacing: 1.5px;
        text-transform: uppercase;
      }

      /* ── NAV TABS ── */
      .tab-bar {
        display: flex;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
        overflow-x: auto;
        scrollbar-width: none;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .tab-bar::-webkit-scrollbar { display: none; }

      .tab {
        padding: 16px 28px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        cursor: pointer;
        border: none;
        background: transparent;
        color: var(--muted);
        border-bottom: 2px solid transparent;
        white-space: nowrap;
        transition: all 0.2s;
        position: relative;
        bottom: -1px;
      }

      .tab:hover { color: var(--text); }
      .tab.active { color: var(--text); font-weight: 500; }
      .tab[data-pillar="1"].active { color: var(--p1); border-bottom-color: var(--p1); }
      .tab[data-pillar="2"].active { color: var(--p2); border-bottom-color: var(--p2); }
      .tab[data-pillar="3"].active { color: var(--p3); border-bottom-color: var(--p3); }
      .tab[data-pillar="4"].active { color: var(--p4); border-bottom-color: var(--p4); }

      /* ── PANELS ── */
      .panel { display: none; }
      .panel.active { display: block; }

      /* ── PILLAR HERO ── */
      .pillar-hero {
        padding: 40px 48px 32px;
        border-bottom: 1px solid var(--border);
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 24px;
      }

      .pillar-label {
        grid-column: 1 / -1;
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 8px;
      }

      .pillar-badge {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 28px;
        letter-spacing: 2px;
      }

      .pillar-tag {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        letter-spacing: 2px;
        padding: 4px 10px;
        border-radius: 3px;
        border: 1px solid;
        text-transform: uppercase;
      }

      .pillar-stat {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px;
      }

      .stat-num {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 36px;
        letter-spacing: 1px;
        line-height: 1;
      }

      .stat-label {
        font-size: 11px;
        color: var(--muted);
        margin-top: 4px;
        font-family: 'DM Mono', monospace;
        letter-spacing: 1px;
        text-transform: uppercase;
      }

      .stat-note {
        font-size: 12px;
        color: var(--dim);
        margin-top: 6px;
      }

      /* ── STRATEGY SECTION HEADER ── */
      .section-header {
        padding: 28px 48px 16px;
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--muted);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .section-header::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
      }

      /* ── VIDEO TABLE ── */
      .video-table-wrap {
        padding: 0 0 40px;
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }

      thead th {
        background: var(--surface2);
        padding: 14px 20px;
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
        text-align: left;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }

      tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s;
      }

      tbody tr:hover { background: var(--surface2); }

      tbody td {
        padding: 16px 20px;
        vertical-align: top;
        line-height: 1.5;
      }

      .row-num {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22px;
        color: var(--dim);
        width: 40px;
      }

      .outlier-hook {
        font-weight: 600;
        font-size: 13px;
        line-height: 1.4;
      }

      .hook-sub {
        font-size: 11px;
        color: var(--muted);
        margin-top: 4px;
        font-family: 'DM Mono', monospace;
      }

      .viral-angle {
        display: inline-block;
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        padding: 2px 8px;
        border-radius: 3px;
        border: 1px solid;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .title-combo {
        font-weight: 600;
        font-size: 13px;
      }

      .thumb-note {
        font-size: 11px;
        color: var(--muted);
        margin-top: 4px;
      }

      .edge-pill {
        font-size: 11px;
        color: var(--muted);
        background: var(--surface2);
        padding: 2px 8px;
        border-radius: 4px;
        border: 1px solid var(--border);
        display: inline-block;
        margin: 2px 2px 0 0;
      }

      .why-badge {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        padding: 3px 8px;
        border-radius: 3px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: inline-block;
        margin-bottom: 6px;
      }

      .why-utility { background: rgba(6,214,160,0.12); color: #06D6A0; }
      .why-controversy { background: rgba(239,71,111,0.12); color: #EF476F; }
      .why-speed { background: rgba(255,209,102,0.12); color: #FFD166; }
      .why-identity { background: rgba(17,138,178,0.12); color: #118AB2; }

      /* ── MASTER SCRIPT ── */
      .master-script {
        margin: 0 48px 60px;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
      }

      .script-header {
        padding: 24px 28px;
        display: flex;
        align-items: center;
        gap: 16px;
        border-bottom: 1px solid var(--border);
      }

      .script-badge {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 13px;
        letter-spacing: 3px;
        padding: 6px 14px;
        border-radius: 4px;
        text-transform: uppercase;
      }

      .script-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22px;
        letter-spacing: 1px;
        flex: 1;
      }

      .script-body {
        padding: 32px 28px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
      }

      @media (max-width: 900px) {
        .script-body { grid-template-columns: 1fr; }
        .pillar-hero { grid-template-columns: 1fr 1fr; }
        header, .pillar-hero, .section-header, .master-script { padding-left: 20px; padding-right: 20px; }
        .master-script { margin: 0 16px 40px; }
      }

      .script-section {
        background: var(--surface2);
        border-radius: 8px;
        padding: 20px;
        border: 1px solid var(--border);
      }

      .script-section-title {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .script-section-title::before {
        content: '';
        display: block;
        width: 4px;
        height: 4px;
        border-radius: 50%;
      }

      .timeline-item {
        display: grid;
        grid-template-columns: 60px 1fr;
        gap: 12px;
        margin-bottom: 16px;
      }

      .tl-time {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: var(--muted);
        padding-top: 2px;
        letter-spacing: 1px;
      }

      .tl-content strong {
        font-size: 12px;
        display: block;
        margin-bottom: 2px;
      }

      .tl-content span {
        font-size: 11px;
        color: var(--dim);
      }

      .pain-item {
        display: flex;
        gap: 10px;
        margin-bottom: 12px;
        align-items: flex-start;
      }

      .pain-q {
        font-size: 11px;
        font-style: italic;
        color: var(--muted);
        flex: 1;
        line-height: 1.5;
      }

      .pain-a {
        font-size: 11px;
        color: var(--dim);
        flex: 1.5;
        line-height: 1.5;
      }

      .screen-share-list {
        list-style: none;
      }

      .screen-share-list li {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 12px;
        margin-bottom: 8px;
        line-height: 1.4;
      }

      .screen-share-list li::before {
        content: '▶';
        font-size: 8px;
        margin-top: 4px;
        flex-shrink: 0;
        opacity: 0.5;
      }

      /* ── OVERVIEW PANEL ── */
      .overview-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border-bottom: 1px solid var(--border);
      }

      .overview-card {
        padding: 36px 32px;
        border-right: 1px solid var(--border);
        position: relative;
        overflow: hidden;
      }

      .overview-card:last-child { border-right: none; }

      .ov-accent {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
      }

      .ov-num {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 52px;
        letter-spacing: 1px;
        line-height: 1;
        margin-top: 16px;
      }

      .ov-pillar {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 16px;
        letter-spacing: 2px;
        color: var(--muted);
        margin-top: 4px;
      }

      .ov-focus {
        font-size: 11px;
        color: var(--dim);
        margin-top: 8px;
        line-height: 1.5;
        border-top: 1px solid var(--border);
        padding-top: 12px;
        margin-top: 12px;
      }

      .strategy-strip {
        padding: 48px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
      }

      .strategy-card {
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 24px;
        background: var(--surface2);
      }

      .strategy-card h3 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 18px;
        letter-spacing: 2px;
        margin-bottom: 12px;
      }

      .strategy-card ul {
        list-style: none;
      }

      .strategy-card li {
        font-size: 12px;
        color: var(--muted);
        padding: 6px 0;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: flex-start;
        gap: 8px;
      }

      .strategy-card li:last-child { border-bottom: none; }

      .strategy-card li span {
        opacity: 0.4;
        flex-shrink: 0;
        font-size: 10px;
        margin-top: 2px;
      }

      @media (max-width: 1100px) {
        .overview-grid { grid-template-columns: 1fr 1fr; }
        .overview-card:nth-child(2) { border-right: none; }
        .overview-card:nth-child(3) { border-right: 1px solid var(--border); border-top: 1px solid var(--border); }
        .overview-card:nth-child(4) { border-top: 1px solid var(--border); border-right: none; }
      }

      @media (max-width: 700px) {
        .overview-grid { grid-template-columns: 1fr; }
        .overview-card { border-right: none; border-top: 1px solid var(--border); }
        .strategy-strip { grid-template-columns: 1fr; padding: 24px; }
      }

      /* colour helpers */
      .c1 { color: var(--p1); }
      .c2 { color: var(--p2); }
      .c3 { color: var(--p3); }
      .c4 { color: var(--p4); }
      .b1 { border-color: var(--p1); }
      .b2 { border-color: var(--p2); }
      .b3 { border-color: var(--p3); }
      .b4 { border-color: var(--p4); }
      .bg1 { background: var(--p1-dim); }
      .bg2 { background: var(--p2-dim); }
      .bg3 { background: var(--p3-dim); }
      .bg4 { background: var(--p4-dim); }

      .divider {
        height: 1px;
        background: var(--border);
        margin: 0 48px;
      }

      .footnote {
        padding: 20px 48px;
        font-size: 11px;
        color: var(--dim);
        font-family: 'DM Mono', monospace;
        border-top: 1px solid var(--border);
      }
    </style>

    <header>
      <div class="logo-block">
        <h1>EXPATBUILDR</h1>
        <p>YouTube Outlier Architecture — 2026 Edition</p>
      </div>
      <div class="header-meta">
        <div class="meta-chip">4 Pillars</div>
        <div class="meta-chip">50 Video Concepts</div>
        <div class="meta-chip">4 Master Scripts</div>
        <div class="meta-chip">Target: Views/Subs &gt;5×</div>
      </div>
    </header>

    <div class="tab-bar">
      <button class="tab active" data-pillar="0" onclick="switchTab(0)">Overview</button>
      <button class="tab" data-pillar="1" onclick="switchTab(1)">🟡 Remote Income</button>
      <button class="tab" data-pillar="2" onclick="switchTab(2)">🟢 Lead Gen</button>
      <button class="tab" data-pillar="3" onclick="switchTab(3)">🔴 Geo-Arbitrage</button>
      <button class="tab" data-pillar="4" onclick="switchTab(4)">🔵 Grants</button>
    </div>

    <!-- ══════════════ OVERVIEW ══════════════ -->
    <div id="panel-0" class="panel active">
      <div class="overview-grid">
        <div class="overview-card">
          <div class="ov-accent" style="background:var(--p1)"></div>
          <div class="ov-num c1">01</div>
          <div class="ov-pillar">Remote Income</div>
          <div class="ov-focus">Focus: <strong>The System</strong> — Automated income vs gig work. Show the difference between trading time and owning a machine.</div>
        </div>
        <div class="overview-card">
          <div class="ov-accent" style="background:var(--p2)"></div>
          <div class="ov-num c2">02</div>
          <div class="ov-pillar">Lead Generation</div>
          <div class="ov-focus">Focus: <strong>Data Assets &amp; B2B Arbitrage</strong> — Turn scraped intent signals into booked calls. Own the data, own the pipeline.</div>
        </div>
        <div class="overview-card">
          <div class="ov-accent" style="background:var(--p3)"></div>
          <div class="ov-num c3">03</div>
          <div class="ov-pillar">Geo-Arbitrage</div>
          <div class="ov-focus">Focus: <strong>Compound Building + Tax-Free Residency</strong> — Family-first arbitrage with USD income in a PHP world.</div>
        </div>
        <div class="overview-card">
          <div class="ov-accent" style="background:var(--p4)"></div>
          <div class="ov-num c4">04</div>
          <div class="ov-pillar">Business Grants</div>
          <div class="ov-focus">Focus: <strong>AI-Driven Discovery + Hidden Funding</strong> — Surface $0-equity money most founders never see.</div>
        </div>
      </div>

      <div class="strategy-strip">
        <div class="strategy-card">
          <h3 style="color:var(--p1)">What Makes an Outlier?</h3>
          <ul>
            <li><span>01</span> Views/Subs ratio exceeds 5× (target 10–50×)</li>
            <li><span>02</span> Surfaces via Homepage, not Search — emotion beats keyword</li>
            <li><span>03</span> Hook answers the viewer's secret fear or forbidden desire</li>
            <li><span>04</span> Thumbnail creates a "gap of curiosity" — you need to close it</li>
            <li><span>05</span> First 30 seconds makes a promise that feels new</li>
            <li><span>06</span> Screen-share proof in the first 2 minutes kills doubt</li>
            <li><span>07</span> Comments section reveals the 3 pain points the original missed</li>
          </ul>
        </div>
        <div class="strategy-card">
          <h3 style="color:var(--p2)">ExpatBuildr 2026 Edge</h3>
          <ul>
            <li><span>◆</span> AI Lead Scoring — only pitch leads with intent signals</li>
            <li><span>◆</span> AI Routing — match lead to offer automatically via Make.com</li>
            <li><span>◆</span> Lifestyle Arbitrage Calculator — live USD→PHP salary widget</li>
            <li><span>◆</span> GrantWisdom SaaS — proprietary AI grant discovery engine</li>
            <li><span>◆</span> Remote Work Sniper — private scraper surfacing hidden jobs first</li>
            <li><span>◆</span> Galaxy Arbitrage Newsletter — proof flywheel for every video</li>
            <li><span>◆</span> 50-Agent AI Factory — content at scale without AI-slop quality</li>
          </ul>
        </div>
        <div class="strategy-card">
          <h3 style="color:var(--p3)">Remake Formula (Every Video)</h3>
          <ul>
            <li><span>01</span> Find the Outlier — Views/Subs &gt;5× in niche via vidIQ/1of10</li>
            <li><span>02</span> Mine the comments — extract the top 3 unanswered questions</li>
            <li><span>03</span> Cut runtime 30% — remove every explanation that lacks a demo</li>
            <li><span>04</span> Lead with a screen-share result in the first 90 seconds</li>
            <li><span>05</span> Inject ExpatBuildr proprietary system as the "2026 layer"</li>
            <li><span>06</span> Title: Number + Specific Outcome + Unexpected Mechanism</li>
            <li><span>07</span> Thumbnail: Dark bg, single face/result, 4-word max text</li>
          </ul>
        </div>
        <div class="strategy-card">
          <h3 style="color:var(--p4)">Channel Hybrid Model</h3>
          <ul>
            <li><span>◆</span> B-roll: cinematic city-at-night, screen dashboards, peso stacks</li>
            <li><span>◆</span> Screen-share: live software demos, Make.com flows, GrantWisdom</li>
            <li><span>◆</span> On-cam: Tony Leads personal brand, DC5 build updates as hooks</li>
            <li><span>◆</span> Voiceover: authoritative but conversational — no AI robotic tone</li>
            <li><span>◆</span> Pacing: cut to b-roll every 30–45 sec maximum</li>
            <li><span>◆</span> CTA: "Join Galaxy Arbitrage newsletter for the full system"</li>
            <li><span>◆</span> Funnel: YouTube → Beehiiv → Email list → SaaS/Services offer</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- ══════════════ PILLAR 1: REMOTE INCOME ══════════════ -->
    <div id="panel-1" class="panel">
      <div class="pillar-hero" style="background:linear-gradient(135deg,#0c0b08 60%,var(--p1-dim))">
        <div class="pillar-label">
          <span class="pillar-badge c1">PILLAR 01 — REMOTE INCOME</span>
          <span class="pillar-tag c1 b1">The System</span>
        </div>
        <div class="pillar-stat bg1" style="border-color:rgba(255,209,102,0.2)">
          <div class="stat-num c1">50×</div>
          <div class="stat-label">Target Views/Subs Ratio</div>
          <div class="stat-note">Outlier threshold begins at 5×. System videos peak at 30–80×</div>
        </div>
        <div class="pillar-stat bg1" style="border-color:rgba(255,209,102,0.2)">
          <div class="stat-num c1">$83B</div>
          <div class="stat-label">Marketing Automation Market</div>
          <div class="stat-note">Viewers are searching for the automated version — not the hustle</div>
        </div>
        <div class="pillar-stat bg1" style="border-color:rgba(255,209,102,0.2)">
          <div class="stat-num c1">22%</div>
          <div class="stat-label">US Workforce Now Remote</div>
          <div class="stat-note">32M people primed for geo-arb and system content crossover</div>
        </div>
      </div>

      <div class="section-header">OUTLIER VIDEO CONCEPTS — 13 IDEAS</div>

      <div class="video-table-wrap">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Outlier Hook (Viral Angle)</th>
              <th>Why It Wins</th>
              <th>Title / Thumbnail Combo</th>
              <th>Screen-Shares to Include</th>
              <th>ExpatBuildr 2026 Edge</th>
            </tr>
          </thead>
          <tbody>

            <tr>
              <td class="row-num">01</td>
              <td>
                <div class="viral-angle c1 b1">IDENTITY THREAT</div>
                <div class="outlier-hook">The Job Board Is a Trap — Here's the Exit</div>
                <div class="hook-sub">Reframes applying to jobs as a wealth leak, not a path</div>
              </td>
              <td>
                <span class="why-badge why-controversy">Controversy</span><br />
                Challenges the consensus belief. "Hard work = success" is the villain here.
