---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="TONY LEADS — Upwork Blitz Strategy | Internal Protocol" minimal={true}>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>
  <div class="blitz-page min-h-screen bg-[#111111] text-[#f5f0e8] overflow-x-hidden relative font-['Barlow_Condensed',sans-serif]">
    <style is:inline>
      @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=Barlow+Condensed:wght@400;600;700;900&display=swap');

      :root {
        --blood: #c0392b;
        --ember: #e67e22;
        --gold: #f1c40f;
        --bone: #f5f0e8;
        --ash: #1a1a1a;
        --soot: #111111;
        --wire: #2d2d2d;
        --dim: #888;
        --green: #27ae60;
      }

      .blitz-page::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.07'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 999;
        opacity: 0.4;
      }

      header.war-header {
        border-bottom: 3px solid var(--blood);
        padding: 28px 32px 20px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        background: #0d0d0d;
        animation: fadeDown 0.6s ease both;
      }

      .logo {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 3.2rem;
        letter-spacing: 4px;
        color: var(--bone);
        line-height: 1;
      }
      .logo span { color: var(--blood); }

      .mission-badge {
        text-align: right;
        font-family: 'DM Mono', monospace;
        font-size: 0.72rem;
        color: var(--dim);
        line-height: 1.8;
      }
      .mission-badge strong {
        color: var(--gold);
        display: block;
        font-size: 1.1rem;
        letter-spacing: 2px;
      }

      .ticker { background: var(--blood); padding: 7px 0; overflow: hidden; white-space: nowrap; }
      .ticker-inner { display: inline-block; animation: ticker 28s linear infinite; font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 2px; color: #fff; }
      @keyframes ticker { 0% { transform: translateX(100vw); } 100% { transform: translateX(-100%); } }

      .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

      .section-label { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 4px; color: var(--blood); text-transform: uppercase; margin-bottom: 6px; padding-top: 48px; }
      .section-title { font-family: 'Bebas Neue', sans-serif; font-size: 2.6rem; letter-spacing: 2px; line-height: 1; margin-bottom: 24px; border-left: 4px solid var(--ember); padding-left: 14px; }

      .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; margin: 32px 0 0; background: var(--wire); }
      .stat-card { background: #0d0d0d; padding: 22px 18px; animation: fadeUp 0.5s ease both; }
      .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 2.8rem; color: var(--gold); line-height: 1; }
      .stat-label { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--dim); letter-spacing: 2px; margin-top: 4px; }

      .search-block { background: #0d0d0d; border: 1px solid var(--wire); border-left: 3px solid var(--ember); padding: 20px 22px; margin-bottom: 12px; animation: fadeUp 0.5s ease both; }
      .search-string { font-family: 'DM Mono', monospace; font-size: 0.82rem; color: var(--gold); background: #1a1a1a; padding: 10px 14px; border-radius: 2px; margin: 10px 0; word-break: break-all; cursor: pointer; transition: background 0.2s; border: 1px solid #333; position: relative; }
      .search-string:hover { background: #252525; }
      .search-string::after { content: 'COPY'; position: absolute; right: 10px; top: 50%; transform: translateY(-50%); font-size: 0.6rem; color: var(--dim); letter-spacing: 2px; }
      .search-target { font-size: 0.82rem; color: var(--dim); font-style: italic; }
      .search-target strong { color: var(--ember); }

      .proposal-box { background: #0d0d0d; border: 1px solid var(--wire); border-top: 3px solid var(--gold); padding: 28px 30px; margin-top: 8px; position: relative; }
      .proposal-box::before { content: 'COPY & CUSTOMIZE'; position: absolute; top: -11px; right: 20px; background: var(--gold); color: var(--soot); font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 2px; padding: 2px 8px; }
      .proposal-text { font-size: 1rem; line-height: 1.75; color: #ccc; font-weight: 400; }
      .proposal-text .highlight { color: var(--gold); font-weight: 700; }
      .proposal-text .action { color: var(--ember); }
      .proposal-text .proof { color: var(--green); }

      .vs-grid { display: grid; grid-template-columns: 1fr 60px 1fr; margin-top: 8px; }
      .vs-col { background: #0d0d0d; padding: 22px 20px; border: 1px solid var(--wire); }
      .vs-col.bad { border-top: 3px solid #c0392b; }
      .vs-col.good { border-top: 3px solid var(--green); }
      .vs-center { display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; color: var(--blood); background: var(--soot); border-top: 1px solid var(--wire); border-bottom: 1px solid var(--wire); }
      .vs-col-header { font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; letter-spacing: 2px; margin-bottom: 14px; }
      .vs-item { font-size: 0.88rem; color: #aaa; padding: 6px 0; border-bottom: 1px solid #1e1e1e; line-height: 1.4; }
      .vs-item.neg::before { content: '✗  '; color: var(--blood); font-weight: 700; }
      .vs-item.pos::before { content: '✓  '; color: var(--green); font-weight: 700; }

      .pitch-box { background: linear-gradient(135deg, #1a0a00, #1a1200); border: 1px solid var(--ember); padding: 22px 26px; margin-top: 20px; }
      .pitch-box p { font-size: 1rem; color: #ddd; line-height: 1.7; }

      .roadmap-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; background: var(--wire); margin-top: 8px; }
      .day-card { background: #0d0d0d; padding: 18px 20px; border-left: 3px solid transparent; transition: border-color 0.2s; }
      .day-card:hover { border-left-color: var(--ember); }
      .day-card.critical { border-left-color: var(--blood) !important; }
      .day-card.milestone { border-left-color: var(--gold) !important; }
      .day-card.scale { border-left-color: var(--green) !important; }
      .day-num { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: var(--dim); letter-spacing: 2px; }
      .day-card.critical .day-num { color: var(--blood); }
      .day-card.milestone .day-num { color: var(--gold); }
      .day-card.scale .day-num { color: var(--green); }
      .day-earn { font-family: 'DM Mono', monospace; font-size: 0.75rem; color: var(--green); }
      .day-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.05rem; letter-spacing: 1px; color: var(--bone); margin-bottom: 8px; }
      .day-tasks { list-style: none; font-size: 0.82rem; color: #999; font-family: 'DM_Mono', monospace; line-height: 1.8; }
      .day-tasks li::before { content: '→ '; color: var(--ember); }

      .quick-cash-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: var(--wire); margin-top: 8px; }
      .cash-card { background: #0d0d0d; padding: 24px 20px; border-top: 3px solid var(--ember); }
      .cash-price { font-family: 'Bebas Neue', sans-serif; font-size: 2.4rem; color: var(--bone); line-height: 1; }
      .cash-badge { display: inline-block; background: #1a1a1a; border: 1px solid #333; color: var(--dim); font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 2px; padding: 3px 8px; }

      .mindset { background: var(--blood); padding: 20px 32px; margin-top: 48px; text-align: center; }
      .mindset p { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 4px; color: #fff; }
      .mindset span { color: var(--gold); }

      footer.war-footer { padding: 28px 32px; border-top: 1px solid var(--wire); display: flex; justify-content: space-between; align-items: center; background: #0d0d0d; }
      footer.war-footer p { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--dim); letter-spacing: 2px; }

      .tag { display: inline-block; font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 2px; padding: 3px 8px; background: #1a1a1a; border: 1px solid #333; color: var(--dim); margin-right: 6px; margin-bottom: 6px; vertical-align: middle; }
      .tag.hot { border-color: var(--blood); color: var(--blood); }
      .tag.gold { border-color: var(--gold); color: var(--gold); }

      .flash { display: none; position: fixed; bottom: 24px; right: 24px; background: var(--green); color: #000; font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 2px; padding: 10px 18px; z-index: 1000; animation: fadeUp 0.3s ease; }

      @keyframes fadeDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
      @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

      @media (max-width: 768px) {
        .stat-row { grid-template-columns: repeat(2, 1fr); }
        .roadmap-grid { grid-template-columns: 1fr; }
        .quick-cash-grid { grid-template-columns: 1fr; }
        .vs-grid { grid-template-columns: 1fr; }
        .vs-center { display: none; }
      }
    </style>

    <div id="copy-flash" class="flash">COPIED ✓</div>

    <header class="war-header">
      <div>
        <div class="logo">TONY <span>LEADS</span></div>
        <div style="font-family:'DM Mono',monospace;font-size:0.65rem;color:var(--dim);letter-spacing:3px;margin-top:4px;">AGENTIC BLITZ STRATEGY · UPWORK WAR ROOM</div>
      </div>
      <div class="mission-badge">
        <strong>$800 / 14 DAYS</strong>
        SCOTTSDALE, AZ · VERIFIED<br>
        PHILIPPINES TIME ZONE · 24/7 OUTPUT<br>
        GALAXYLEADS V4.1 RAINMAKER
      </div>
    </header>

    <div class="ticker">
      <span class="ticker-inner">
              ⚡ MISSION: $800 IN 14 DAYS  ·  SCOTTSDALE VERIFIED = US-ONLY FILTER ADVANTAGE  ·  4× AGENT AUDITS @ $200 = $800 BASE  ·  EVERY HOUR YOU'RE NOT PITCHING IS MONEY LEFT ON THE TABLE  ·  FOLLOW THE SUN: THEY SLEEP, YOU BUILD  ·  ANTI-ZAPIER EDGE = YOUR MOAT  ·  AGENTIC IS THE UPGRADE. YOU ARE THE ARCHITECT.       
      </span>
    </div>

    <div class="container">
      <div class="stat-row">
        <div class="stat-card"><div class="stat-num">$800</div><div class="stat-label">TARGET / 14 DAYS</div></div>
        <div class="stat-card"><div class="stat-num">4×</div><div class="stat-label">AGENT AUDITS @ $200</div></div>
        <div class="stat-card"><div class="stat-num">$25–45</div><div class="stat-label">HOURLY FLOOR RATE</div></div>
        <div class="stat-card"><div class="stat-num">$100+</div><div class="stat-label">AGENTIC ARCHITECT CEILING</div></div>
      </div>

      <p class="section-label">// SECTION 01 — UPWORK INTEL</p>
      <h2 class="section-title">THE AGENTIC SEARCH FILTER</h2>
      
      <div class="search-block">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;color:var(--ember);margin-bottom:6px;">STRING 01 — STARTUPS</div>
        <div class="search-string" data-copy='(agentic OR "AI agent") AND (python OR langgraph OR crewai OR autogen)'>(agentic OR "AI agent") AND (python OR langgraph OR crewai OR autogen)</div>
        <div class="search-target">Target: <strong>Real AI buyers</strong> — not GPT wrapper devs.</div>
      </div>

      <div class="search-block">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;color:var(--ember);margin-bottom:6px;">STRING 02 — BROKEN FLOWS</div>
        <div class="search-string" data-copy='(automation) AND (agent OR reasoning OR autonomous) NOT (zapier OR n8n)'>(automation) AND (agent OR reasoning OR autonomous) NOT (zapier OR n8n)</div>
        <div class="search-target">Target: <strong>Companies that outgrew no-code</strong>.</div>
      </div>

      <div class="search-block">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;color:var(--ember);margin-bottom:6px;">STRING 03 — GALAXYLEADS</div>
        <div class="search-string" data-copy='(lead generation) AND (AI agent OR autonomous OR agentic)'>(lead generation) AND (AI agent OR autonomous OR agentic)</div>
        <div class="search-target">Target: <strong>Lead gen operators</strong> who know scrapers are dead.</div>
      </div>

      <div class="search-block">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;color:var(--ember);margin-bottom:6px;">STRING 04 — ORCHESTRATION</div>
        <div class="search-string" data-copy='"multi-agent" OR "agent orchestration" OR "LangGraph" OR "CrewAI"'>"multi-agent" OR "agent orchestration" OR "LangGraph" OR "CrewAI"</div>
        <div class="search-target">Target: <strong>Technical founders</strong> who know the terminology.</div>
      </div>

      <div class="search-block">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;color:var(--ember);margin-bottom:6px;">STRING 05 — DIAGNOSTIC</div>
        <div class="search-string" data-copy='(hallucination OR "broken agent" OR "AI workflow" OR "agent loop") AND (fix OR debug OR improve OR help)'>(hallucination OR "broken agent" OR "AI workflow" OR "agent loop") AND (fix OR debug OR improve OR help)</div>
        <div class="search-target">Target: <strong>Pain = budget.</strong></div>
      </div>

      <p class="section-label">// SECTION 02 — THE PITCH</p>
      <h2 class="section-title">THE OVERNIGHT PROPOSAL</h2>
      
      <div class="proposal-box">
        <div class="proposal-text">
          <span class="highlight">Subject: Agentic Architect — 24/7 Throughput, U.S.-Based, Ready Now</span><br><br>
          I'll be direct: <span class="action">I build AI agents that operate autonomously</span> — not Zapier flows dressed up as AI.<br><br>
          You brief me at <span class="highlight">5 PM EST</span>. Your workflow is <span class="highlight">tested by 9 AM EST</span>.
        </div>
      </div>

      <p class="section-label">// SECTION 03 — YOUR MOAT</p>
      <h2 class="section-title">THE ANTI-ZAPIER EDGE</h2>
      <div class="vs-grid">
        <div class="vs-col bad">
          <div class="vs-col-header">❌ NO-CODE</div>
          <div class="vs-item neg">Brittle trigger-action chains</div>
          <div class="vs-item neg">No reasoning or adaptability</div>
        </div>
        <div class="vs-center">VS</div>
        <div class="vs-col good">
          <div class="vs-col-header">✓ AGENTIC</div>
          <div class="vs-item pos">Stateful reasoning loops</div>
          <div class="vs-item pos">Autonomous decision-making</div>
        </div>
      </div>

      <p class="section-label">// SECTION 04 — REVENUE</p>
      <h2 class="section-title">QUICK CASH PRODUCTS</h2>
      <div class="quick-cash-grid">
        <div class="cash-card">
          <div class="cash-price">$200</div>
          <div class="cash-badge">AGENT AUDIT</div>
        </div>
        <div class="cash-card">
          <div class="cash-price">$350</div>
          <div class="cash-badge">AGENTIC POC</div>
        </div>
        <div class="cash-card">
          <div class="cash-price">$500</div>
          <div class="cash-badge">LEAD GEN SPRINT</div>
        </div>
      </div>

      <p class="section-label">// SECTION 05 — ROADMAP</p>
      <h2 class="section-title">14-DAY BLITZ</h2>
      <div class="roadmap-grid">
        <div class="day-card critical">
          <div class="day-num">DAY 01</div>
          <div class="day-title">PROFILE SETUP</div>
        </div>
        <div class="day-card critical">
          <div class="day-num">DAY 02</div>
          <div class="day-title">FIRST PITCHES</div>
        </div>
        <div class="day-card milestone">
          <div class="day-num">DAY 05</div>
          <div class="day-title">FIRST $200 IN</div>
        </div>
        <div class="day-card scale">
          <div class="day-num">DAY 14</div>
          <div class="day-title">MISSION COMPLETE</div>
        </div>
      </div>
    </div>

    <div class="mindset">
      <p>THEY PAY SCOTTSDALE. <span>YOU LIVE PHILIPPINES.</span></p>
    </div>

    <footer class="war-footer">
      <p>TONY LEADS · EXPATBUILDR SYSTEMS · SCOTTSDALE, AZ</p>
      <p>$800 / 14-DAY MISSION</p>
    </footer>

    <script is:inline>
      const flash = document.getElementById('copy-flash');
      document.querySelectorAll('.search-string').forEach(el => {
        el.addEventListener('click', () => {
          const text = el.getAttribute('data-copy');
          navigator.clipboard.writeText(text).then(() => {
            flash.style.display = 'block';
            setTimeout(() => { flash.style.display = 'none'; }, 2000);
          });
        });
      });
    </script>
  </div>
</Layout>
