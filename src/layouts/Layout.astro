---
import { ShoppingCart, ArrowRight, Github, Twitter, Linkedin, Mail, Cpu, LineChart, Code2, Rocket, Sun, Moon, Menu, X, ChevronDown, ArrowUp, Music, Youtube, Instagram, Rss, FileJson, Layers, Hammer, Briefcase, Send, Target, TrendingUp, MonitorPlay } from 'lucide-astro';
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
import DevPanel from '../components/dev/DevPanel.jsx';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	noindex?: boolean;
	minimal?: boolean;
	canonicalUrl?: string;
	noAnimations?: boolean;
}

const { 
	title, 
	description = "Institutional-grade SaaS platforms, autonomous AI workflows, and proprietary trading systems. Built by ExpatBuildr.", 
	ogImage = "/expatbuildr_og_banner.png",
	noindex = false,
	minimal = false,
	canonicalUrl,
	noAnimations = false
} = Astro.props;

// Ensure absolute URL for OG image
const ogImageUrl = ogImage.startsWith('http')
    ? ogImage
    : new URL(ogImage, Astro.site || 'https://expatbuildr.com').toString();

// Schema.org structured data — computed in frontmatter so set:html can JSON.stringify them
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://expatbuildr.com';
const logoUrl = `${siteUrl}/images/logo.jpg`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Expat Buildr',
  url: siteUrl,
  image: logoUrl,
  jobTitle: 'Developer & Systems Architect',
  description: 'Lead generation systems, geographic arbitrage protocols, and remote income frameworks.',
  sameAs: [
    'https://github.com/expatbuildr',
    'https://x.com/expatbuildr',
    'https://www.youtube.com/@expatbuildr',
    'https://www.instagram.com/expatbuildr',
    'https://www.linkedin.com/in/expatbuildr/',
    'https://tiktok.com/@expatbuildr'
  ]
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Expat Buildr',
  alternateName: 'Galaxy Arbitrage',
  url: siteUrl,
  logo: logoUrl,
  sameAs: personSchema.sameAs
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Expat Buildr',
  url: siteUrl,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string'
  }
};
---

<!doctype html>
<html lang="en" prefix="og: https://ogp.me/ns#">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		
		<Analytics />

		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<meta name="generator" content={Astro.generator} />
		<title>{(title.includes('Expat Buildr') || title.includes('ExpatBuildr')) ? title : `${title} | Expat Buildr`}</title>
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow, noarchive" />}
		<link rel="canonical" href={(() => { const u = canonicalUrl || new URL(Astro.url.pathname, Astro.site).toString(); return u.endsWith('/') && u !== (Astro.site?.toString() ?? '') ? u.slice(0, -1) : u; })()} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

		<!-- OG Meta Tags -->
		<meta property="og:site_name" content="Expat Buildr" />
		<meta property="og:title" content={title.includes('Expat Buildr') ? title : `${title} | Expat Buildr`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:url" content={ogImageUrl} />
		<meta property="og:image:secure_url" content={ogImageUrl} />
		<meta property="og:image:type" content={ogImageUrl.endsWith('.png') ? 'image/png' : 'image/jpeg'} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Expat Buildr - Institutional-Grade AI & SaaS Infrastructure" />
		<meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="en_US" />
		
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@expatbuildr" />
		<meta name="twitter:creator" content="@expatbuildr" />
		<meta name="twitter:title" content={title.includes('Expat Buildr') ? title : `${title} | Expat Buildr`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				// New visitors default to light mode
				return 'light';
			})();

			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}
			window.localStorage.setItem('theme', theme);
		</script>
		<slot name="head" />
	</head>
	<body class="selection:bg-accent-blue/30 selection:text-white transition-colors duration-500">
		{!noAnimations && (
			<div id="cursor" class="custom-cursor hidden md:block">
				<div class="galaxy-core"></div>
				<div class="galaxy-arm galaxy-arm-1"></div>
				<div class="galaxy-arm galaxy-arm-2"></div>
				<div class="galaxy-arm galaxy-arm-3"></div>
				<div class="galaxy-arm galaxy-arm-4"></div>
				<div class="galaxy-arm galaxy-arm-5"></div>
				<div class="galaxy-arm galaxy-arm-6"></div>
			</div>
		)}
		
		{!minimal && !noAnimations && (
			<div class="hidden md:flex fixed top-0 w-full z-[60] bg-white/90 dark:bg-galaxy-950/80 backdrop-blur-md border-b border-accent-purple/20 py-1.5 overflow-hidden shadow-[0_0_15px_rgba(217,70,239,0.1)]">
				<div class="flex whitespace-nowrap animate-marquee">
