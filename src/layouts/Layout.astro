						<a href="/contact" class="btn-primary text-[10px] md:text-xs tracking-widest uppercase px-4 md:px-6">
							Contact me
						</a>
					</div>

					<!-- Mobile Controls -->
					<div class="flex md:hidden items-center gap-2">
						<button id="themeToggleMobile" class="p-2 rounded-xl bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 text-slate-500 dark:text-slate-400 hover:text-accent-blue transition-all cursor-pointer">
