						<span>[GALAXY BUILT PROTOCOL: <span class="text-slate-900 dark:text-white">ESTABLISHED</span>]</span>
						<span>[INFRASTRUCTURE: <span class="text-slate-900 dark:text-white">INSTITUTIONAL GRADE</span>]</span>
					</div>
				</div>
			</div>
		)}

		{!minimal && !noAnimations && <div class="mesh-bg"></div>}
		{!minimal && !noAnimations && <div class="noise-overlay"></div>}
		{!minimal && !noAnimations && (
			<div class="starfield">
				<div class="stars-1"></div>
				<div class="stars-2"></div>
			</div>
		)}
		
		{!minimal && (
			<nav class="fixed top-9 w-full z-[70] px-4 md:px-6 py-4 flex justify-center">
				<div class="max-w-7xl w-full flex items-center justify-between px-4 md:px-6 py-3 glass-card rounded-2xl relative shadow-2xl transition-all duration-300">
					<!-- Brand -->
					<a href="/" class="flex items-center gap-2 md:gap-3 group floating">
						<img src="/logo.jpg" alt="Expat Buildr Logo" class="w-10 h-10 md:w-12 md:h-12 rounded-lg md:rounded-xl object-cover ring-2 ring-white/10 group-hover:ring-accent-blue/50 transition-all" />
						<span class="text-lg md:text-2xl font-black font-display tracking-tight text-black dark:text-white">Expat<span class="text-gradient">Buildr</span></span>
