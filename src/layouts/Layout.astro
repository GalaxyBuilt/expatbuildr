						<a href="https://x.com/expatbuildr" class="hover:text-slate-900 dark:hover:text-white transition-colors">X / Twitter</a>
						<a href="https://www.youtube.com/@expatbuildr" class="hover:text-slate-900 dark:hover:text-white transition-colors">YouTube</a>
						<a href="https://www.instagram.com/expatbuildr" class="hover:text-slate-900 dark:hover:text-white transition-colors">Instagram</a>
						<a href="https://tiktok.com/@expatbuildr" target="_blank" rel="noopener noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">TikTok</a>
