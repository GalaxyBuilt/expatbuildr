						<button id="themeToggle" class="p-2 rounded-xl bg-slate-900/5 dark:bg-white/5 hover:bg-slate-900/10 dark:hover:bg-white/10 text-slate-700 dark:text-slate-400 hover:text-accent-blue transition-all cursor-pointer">
