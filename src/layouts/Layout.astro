										<Rocket size={16} /> Founders Launch
									</a>
									<a href="/portfolio#saas" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-white/10 hover:text-accent-blue transition-all group">
										<Rocket size={16} /> SaaS Platforms
									</a>
									<a href="/portfolio#trading" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-white/10 hover:text-accent-blue transition-all group">
										<LineChart size={16} /> Trading Systems
									</a>
									<a href="/portfolio#software" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-white/10 hover:text-accent-blue transition-all group">
