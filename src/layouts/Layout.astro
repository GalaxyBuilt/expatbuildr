									</a>
									<!-- Automation -->
									<a href="/automation-systems/automation" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 hover:text-accent-blue transition-all group">
										<div class="p-2 rounded-lg bg-accent-blue/10 text-accent-blue group-hover:scale-110 transition-transform">
											<Cpu size={18} />
										</div>
										<div>
											<div class="text-xs font-bold">Automation Systems</div>
											<div class="text-[10px] text-slate-500">Autonomous Workflows</div>
										</div>
									</a>
								</div>
							</div>
						</div>

						<!-- Teleport Dropdown -->
						<div class="relative group/dropdown">
							<button class="flex items-center gap-1.5 hover:text-accent-blue transition-colors cursor-pointer py-2">
								Explore <ChevronDown size={14} />
							</button>
							<div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-56 opacity-0 translate-y-2 pointer-events-none group-hover/dropdown:opacity-100 group-hover/dropdown:translate-y-0 group-hover/dropdown:pointer-events-auto transition-all duration-300">
								<div class="glass-card rounded-2xl p-2 border border-slate-200 dark:border-white/10 shadow-2xl backdrop-blur-2xl bg-white/95 dark:bg-slate-900/95 overflow-hidden">
									<a href="/portfolio" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-white/10 hover:text-accent-cyan transition-all group font-bold">
										<Layers size={16} /> Portfolio
