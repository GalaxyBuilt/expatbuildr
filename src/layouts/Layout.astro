										</div>
									</a>
									<a href="/geo-arbitrage/arbjobs" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-white/10 hover:text-emerald-500 transition-all group">
										<div class="p-2 rounded-lg bg-emerald-500/10 text-emerald-500 group-hover:scale-110 transition-transform">
											<Briefcase size={18} />
										</div>
										<div>
