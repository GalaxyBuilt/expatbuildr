					<div class="max-w-7xl mx-auto px-6 py-12 space-y-8">
						<div class="grid grid-cols-1 gap-4">
							<a href="/lead-gen/edge" class="mobile-nav-link text-accent-cyan"><Target size={20} /> Lead Gen</a>
							<a href="/founders/strategy" class="mobile-nav-link text-accent-purple"><Rocket size={20} /> Founders</a>
							<a href="/geo-arbitrage/arbjobs" class="mobile-nav-link text-emerald-600 dark:text-emerald-500"><Briefcase size={20} /> Jobs</a>
							<a href="/remote-income/sniper" class="mobile-nav-link text-amber-500"><TrendingUp size={20} /> Remote Income</a>
							<a href="/automation-systems/automation" class="mobile-nav-link text-accent-blue"><Cpu size={20} /> Automation</a>
