						<span>[TOPICAL AUTHORITY: <span class="text-slate-900 dark:text-white">SCALING</span>]</span>
						<span>[GENESIS TRADING: <span class="text-slate-900 dark:text-white">ACTIVE</span>]</span>
						<span>[AI NEURAL SYNC: <span class="text-accent-blue">STRIKE READY</span>]</span>
						<span>[GALAXY BUILT PROTOCOL: <span class="text-slate-900 dark:text-white">ESTABLISHED</span>]</span>
						<span>[INFRASTRUCTURE: <span class="text-slate-900 dark:text-white">INSTITUTIONAL GRADE</span>]</span>
					</div>
					<div class="flex items-center gap-8 px-4 text-[9px] font-mono tracking-[0.2em] text-slate-900 dark:text-accent-cyan/60 uppercase">
						<span>[SYSTEM: <span class="text-emerald-600 dark:text-emerald-500">ONLINE</span>]</span>
						<span>[TOPICAL AUTHORITY: <span class="text-slate-900 dark:text-white">SCALING</span>]</span>
