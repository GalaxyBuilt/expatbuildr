						<div id="iosA2hsHint" class="hidden rounded-2xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 px-5 py-4 text-sm text-slate-600 dark:text-slate-400 text-center leading-relaxed">
