				<ArrowUp size={24} />
			</button>
		)}

		<script>
			// Theme Toggle
			const handleToggleClick = () => {
				const element = document.documentElement;
				element.classList.toggle("dark");

				const isDark = element.classList.contains("dark");
				localStorage.setItem("theme", isDark ? "dark" : "light");

				// Preserve scrollbar space during theme switch to prevent layout shift
				document.documentElement.style.overflowY = 'scroll';
				document.body.style.overflowY = 'scroll';

				// Android Chrome/Firefox overlay scrollbar workaround - comprehensive reflow
				if (/Android/i.test(navigator.userAgent)) {
					const scrollPos = window.scrollY;
					const body = document.body;

					// Force multiple reflows with requestAnimationFrame for better timing
					requestAnimationFrame(() => {
						// Trigger reflow by accessing offsetHeight
						void document.documentElement.offsetHeight;

						// Force overflow recalculation
						document.documentElement.style.overflow = 'hidden';
						void body.offsetHeight;

						// Reset and restore scroll position
						document.documentElement.style.overflow = '';

						requestAnimationFrame(() => {
							window.scrollTo(0, scrollPos);
						});
					});
				}
			};

			document.getElementById("themeToggle")?.addEventListener("click", handleToggleClick);
			document.getElementById("themeToggleMobile")?.addEventListener("click", handleToggleClick);

			// Fix Android address bar layout shift on scroll
			let lastViewportHeight = window.innerHeight;
			const preserveAndroidLayout = () => {
				if (/Android/i.test(navigator.userAgent)) {
					// Ensure consistent layout on Android
					document.documentElement.style.overflowY = 'scroll';
					document.body.style.overflowY = 'scroll';
					document.documentElement.style.width = '100%';
					document.body.style.width = '100%';
				}
			};

			window.addEventListener('resize', () => {
				const currentHeight = window.innerHeight;
				if (Math.abs(lastViewportHeight - currentHeight) > 50) {
					// Address bar appeared/disappeared, ensure scrollbar space is preserved
					preserveAndroidLayout();
					lastViewportHeight = currentHeight;
				}
			}, { passive: true });

			// Also check on visibility change (when returning to tab)
			document.addEventListener('visibilitychange', () => {
				if (!document.hidden) {
					preserveAndroidLayout();
				}
			}, { passive: true });

			// Interactive Mesh Background
			document.addEventListener('mousemove', (e) => {
				const meshBg = document.querySelector('.mesh-bg');
				if (!meshBg) return;
				
				const x = (e.clientX / window.innerWidth) * 100;
				const y = (e.clientY / window.innerHeight) * 100;
				
				document.documentElement.style.setProperty('--x', `${x}%`);
				document.documentElement.style.setProperty('--y', `${y}%`);
				document.documentElement.style.setProperty('--nx', `${100 - x}%`);
				document.documentElement.style.setProperty('--ny', `${y}%`);
			}, { passive: true });

			// Reveal on Scroll
			const observerOptions = {
				threshold: 0.1,
				rootMargin: '0px 0px -50px 0px'
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('active');
						
						// Dynamic Accent Shift Logic
						if (entry.target.tagName === 'SECTION') {
							const id = entry.target.id;
							const root = document.documentElement;
							
							if (id === 'trading') {
								root.style.setProperty('--color-accent-blue', '#8b5cf6'); // Purple
								root.style.setProperty('--color-accent-cyan', '#10b981'); // Green
							} else if (id === 'music') {
								root.style.setProperty('--color-accent-blue', '#f43f5e'); // Rose
								root.style.setProperty('--color-accent-cyan', '#e879f9'); // Pink
							} else {
								// Reset to default
								root.style.setProperty('--color-accent-blue', '#3b82f6'); 
								root.style.setProperty('--color-accent-cyan', '#22d3ee');
							}
						}
					}
				});
			}, observerOptions);

			document.querySelectorAll('.reveal-on-scroll, section[id]').forEach(el => observer.observe(el));

			// Custom Cursor Logic
			const cursor = document.getElementById('cursor');
			document.addEventListener('mousemove', (e) => {
				if (cursor) {
					cursor.style.left = e.clientX + 'px';
					cursor.style.top = e.clientY + 'px';
				}
			});

			document.querySelectorAll('a, button, [data-modal-target]').forEach(el => {
				el.addEventListener('mouseenter', () => cursor?.classList.add('hover'));
				el.addEventListener('mouseleave', () => cursor?.classList.remove('hover'));
			});

			// Mobile Menu Logic
			const mobileMenuToggle = document.getElementById('mobileMenuToggle');
			const mobileMenuOverlay = document.getElementById('mobileMenuOverlay');
			const menuIcon = document.getElementById('menuIcon');
			const closeIcon = document.getElementById('closeIcon');
			const navBar = document.querySelector('[class*="fixed top-0 w-full"]');

			// Set dynamic menu position based on nav height
			const updateMenuPosition = () => {
				if (navBar && mobileMenuOverlay) {
					const navHeight = navBar.offsetHeight;
					mobileMenuOverlay.style.top = navHeight + 'px';
				}
			};

			updateMenuPosition();
			window.addEventListener('resize', updateMenuPosition);

			let isMenuOpen = false;

			const toggleMenu = () => {
				isMenuOpen = !isMenuOpen;
				if (isMenuOpen) {
					mobileMenuOverlay.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
					menuIcon.classList.add('hidden');
					closeIcon.classList.remove('hidden');
					document.body.style.overflow = 'hidden';
					document.documentElement.style.overflowY = 'scroll';
				} else {
					mobileMenuOverlay.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
					menuIcon.classList.remove('hidden');
					closeIcon.classList.add('hidden');
					document.body.style.overflow = '';
					document.documentElement.style.overflowY = '';
				}
			};
			
			mobileMenuToggle?.addEventListener('click', toggleMenu);
			
			// Close mobile menu on link click
			document.querySelectorAll('.mobile-nav-link').forEach(link => {
				link.addEventListener('click', () => {
					if (isMenuOpen) toggleMenu();
				});
			});

			// Add to Home Screen Logic
			const a2hsSection = document.getElementById('a2hsSection');
			const a2hsBtn = document.getElementById('a2hsBtn');
			const iosHint = document.getElementById('iosA2hsHint');
			let deferredInstallPrompt = null;

			const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
			const isInStandaloneMode = window.matchMedia('(display-mode: standalone)').matches || ('standalone' in navigator && (navigator as any).standalone);

			if (!isInStandaloneMode) {
				if (isIOS) {
					iosHint?.classList.remove('hidden');
				}
				window.addEventListener('beforeinstallprompt', (e: Event) => {
					e.preventDefault();
					deferredInstallPrompt = e as any;
					a2hsSection?.classList.remove('hidden');
				});
				a2hsBtn?.addEventListener('click', async () => {
					if (!deferredInstallPrompt) return;
					deferredInstallPrompt.prompt();
					const { outcome } = await deferredInstallPrompt.userChoice;
					if (outcome === 'accepted') {
						a2hsSection?.classList.add('hidden');
					}
					deferredInstallPrompt = null;
				});
			}

			// Back to Top Logic
			const backToTop = document.getElementById('backToTop');
			window.addEventListener('scroll', () => {
				if (window.scrollY > 500) {
					backToTop.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-10', 'scale-90');
				} else {
					backToTop.classList.add('opacity-0', 'pointer-events-none', 'translate-y-10', 'scale-90');
				}
			});
			
			backToTop?.addEventListener('click', () => {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});
		</script>

