---
import type { Author } from '../../config/authors';

interface Props {
  author: Author;
}

const { author } = Astro.props;
---

<div class="max-w-4xl mx-auto mt-12">
  <div class="glass-card p-8 md:p-10 rounded-[2.5rem] border border-slate-200 dark:border-white/5 bg-slate-50/50 dark:bg-white/[0.02]">
    <p class="text-[9px] font-mono uppercase tracking-[0.25em] text-institutional-muted mb-6">Written By</p>
    <div class="flex flex-col sm:flex-row items-start gap-6">
      <img
        src={author.avatar}
        alt={author.name}
        class="w-20 h-20 rounded-2xl object-cover ring-2 ring-accent-blue/20 shrink-0"
      />
      <div class="flex-1 space-y-3">
        <div>
          <h3 class="text-xl font-black font-display text-institutional-primary uppercase tracking-tight leading-none">
            {author.name}
          </h3>
          <p class="text-[11px] font-mono text-accent-blue mt-1">{author.handle}</p>
        </div>
        <p class="text-institutional-secondary font-inter text-sm leading-relaxed">
          {author.bio}
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          {author.links.twitter && (
            <a
              href={author.links.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-900/5 dark:bg-white/5 hover:bg-accent-blue/10 hover:text-accent-blue border border-slate-200 dark:border-white/10 text-[10px] font-mono uppercase tracking-wider transition-all"
            >
              X / Twitter
            </a>
          )}
          {author.links.youtube && (
            <a
              href={author.links.youtube}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-900/5 dark:bg-white/5 hover:bg-red-500/10 hover:text-red-500 border border-slate-200 dark:border-white/10 text-[10px] font-mono uppercase tracking-wider transition-all"
            >
              YouTube
            </a>
          )}
          {author.links.newsletter && (
            <a
              href={author.links.newsletter}
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[rgba(245,200,66,0.08)] hover:bg-[rgba(245,200,66,0.15)] border border-[rgba(245,200,66,0.2)] text-[10px] font-mono uppercase tracking-wider transition-all"
              style="color: #f5c842;"
            >
              Newsletter
            </a>
          )}
          {author.links.instagram && (
            <a
              href={author.links.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-900/5 dark:bg-white/5 hover:bg-pink-500/10 hover:text-pink-500 border border-slate-200 dark:border-white/10 text-[10px] font-mono uppercase tracking-wider transition-all"
            >
              Instagram
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</div>
