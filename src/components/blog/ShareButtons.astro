---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class="flex items-center gap-3 flex-wrap">
  <span class="text-[9px] font-mono uppercase tracking-[0.25em] text-institutional-muted shrink-0">Share</span>

  <!-- Twitter/X -->
  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}&via=expatbuildr`}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-900/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 border border-slate-200 dark:border-white/10 text-[10px] font-mono uppercase tracking-wider transition-all hover:scale-105 text-slate-700 dark:text-slate-300"
    aria-label="Share on X / Twitter"
  >
    𝕏 Share
  </a>

  <!-- LinkedIn -->
  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#0077B5]/10 hover:bg-[#0077B5]/20 border border-[#0077B5]/20 text-[10px] font-mono uppercase tracking-wider transition-all hover:scale-105 text-[#0077B5]"
    aria-label="Share on LinkedIn"
  >
    LinkedIn
  </a>

  <!-- Copy Link -->
  <button
    id="copyLinkBtn"
    data-url={url}
    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent-blue/10 hover:bg-accent-blue/20 border border-accent-blue/20 text-[10px] font-mono uppercase tracking-wider transition-all hover:scale-105 text-accent-blue cursor-pointer"
    aria-label="Copy link"
  >
    <span id="copyLinkText">Copy Link</span>
  </button>
</div>

<script>
  const btn = document.getElementById('copyLinkBtn');
  const label = document.getElementById('copyLinkText');
  btn?.addEventListener('click', async () => {
    const url = btn.getAttribute('data-url') || window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      if (label) label.textContent = 'Copied!';
      setTimeout(() => { if (label) label.textContent = 'Copy Link'; }, 2000);
    } catch {
      // fallback: select text
    }
  });
</script>
